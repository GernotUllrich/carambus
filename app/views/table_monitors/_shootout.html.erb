<%- table_monitor.get_options!(I18n.locale) %>
<%- options = table_monitor.options %>
<div class="flex overflow-x-hidden overflow-y-auto fixed inset-0 z-50 outline-none focus:outline-none justify-center items-center" id="modal-id">
  <div id="table_monitor_modal_shootout_<%= table_monitor.id %>" class="modal-content border-2  rounded-lg border-gray-500 dark:bg-black dark:text-gray-200 bg-gray-100 space-y-4 flex-col h-1/2" data-game-id="<%= table_monitor.game_id %>">
    <div class="flex h-1/2 flex-col space-x-4 items-center">
      <%- gps = table_monitor.game.andand.game_participations.andand.order(:role).to_a %>
      <div class="flex h-1/2 flex-row items-center">
        <%- left_player = options[:current_left_player] == "playera" ? options[:player_a] : options[:player_b] %>
        <%- right_player = options[:current_left_player] == "playera" ? options[:player_b] : options[:player_a] %>
        <%- left_player_name = left_player[:fullname] %>
        <%- right_player_name = right_player[:fullname] %>
        <%- left_player_id = options[:current_left_player] == "playera" ? "playera" : "playerb" %>
        <%- right_player_id = options[:current_left_player] == "playera" ? "playerb" : "playera" %>
        <%- kickoff_player_key = options["current_kickoff_player"] == "playera" ? "playera" : "playerb" %>
        <%- aftershot_player_key = kickoff_player_key == "playera" ? "playerb" : "playera" %>
        <%- kickoff_player = kickoff_player_key == "playera" ? options[:player_a] : options[:player_b] %>
        <%- aftershot_player = aftershot_player_key == "playera" ? options[:player_a] : options[:player_b] %>
        <%- kickoff_player_name = kickoff_player[:fullname] %>
        <%- aftershot_player_name = aftershot_player[:fullname] %>
        <%- left_player_active = options[:current_left_player] == "playera" ? options[:player_a_active] : options[:player_b_active] %>
        <%- right_player_active = options[:current_left_player] == "playera" ? options[:player_b_active] : options[:player_a_active] %>
        <div class="grid grid-cols-3 gap-4">
          <div class="flex-auto text-3vw mt-10 <%= options[:free_game_form] == 'pool' || options[:current_left_color] == "white" ? "dark:bg-black  dark:text-gray-200 text-black" : "dark:bg-black  text-yellow-400" %> items-center text-center font-semibold"><%= left_player[:fullname] %></div>
          <%= render partial: 'table_monitors/menu', locals: { table_monitor: table_monitor } %>
          <div class="flex-auto text-3vw mt-10 <%= options[:free_game_form] == 'pool' || options[:current_left_color] == "yellow" ? "dark:bg-black  dark:text-gray-200 text-black" : "dark:bg-black  text-yellow-400" %> items-center text-center font-semibold"><%= right_player[:fullname] %></div>
        </div>
      </div>
    </div>
    <%- is_bk2 = options[:free_game_form] == "bk2_kombi" %>
    <%- if is_bk2 %>
      <%# Phase 38.3-05 D-18: BK2-Kombi shootout — 4 buttons (Anstoß × first_set_mode).
          Replaces the generic 2 Karambol "Spieler stößt an" buttons when the live match
          is BK2-Kombi. Each click writes bk2_options[first_set_mode] via reflex-dataset
          (see start_game / switch_players_and_start_game reflex augmentations), then
          transitions via the Karambol start-game AASM path. %>
      <div class="flex flex-col h-1/2 w-full px-4 space-y-3">
        <div class="text-2vw text-center font-semibold"><%= t("table_monitor.bk2_kombi.first_set_mode.legend") %></div>
        <div class="grid grid-cols-2 gap-3 h-full">
          <%= content_tag "div",
                class: "text-2vw flex items-center justify-center btn btn-primary bg-amber-600 hover:bg-amber-700 text-white rounded",
                data: { turbo: false, reflex: "click->TableMonitorReflex#start_game", id: table_monitor.id, bk2_first_set_mode: "direkter_zweikampf" },
                id: "bk2_start_a_dz", tabindex: 6 do %>
            <%= t("table_monitor.bk2_kombi.first_set_mode.button_direkter_zweikampf_a") %>
          <%- end %>
          <%= content_tag "div",
                class: "text-2vw flex items-center justify-center btn btn-primary bg-sky-600 hover:bg-sky-700 text-white rounded",
                data: { turbo: false, reflex: "click->TableMonitorReflex#start_game", id: table_monitor.id, bk2_first_set_mode: "serienspiel" },
                id: "bk2_start_a_sp", tabindex: 6 do %>
            <%= t("table_monitor.bk2_kombi.first_set_mode.button_serienspiel_a") %>
          <%- end %>
          <%= content_tag "div",
                class: "text-2vw flex items-center justify-center btn btn-primary bg-amber-600 hover:bg-amber-700 text-white rounded",
                data: { turbo: false, reflex: "click->TableMonitorReflex#switch_players_and_start_game", id: table_monitor.id, bk2_first_set_mode: "direkter_zweikampf" },
                id: "bk2_start_b_dz", tabindex: 6 do %>
            <%= t("table_monitor.bk2_kombi.first_set_mode.button_direkter_zweikampf_b") %>
          <%- end %>
          <%= content_tag "div",
                class: "text-2vw flex items-center justify-center btn btn-primary bg-sky-600 hover:bg-sky-700 text-white rounded",
                data: { turbo: false, reflex: "click->TableMonitorReflex#switch_players_and_start_game", id: table_monitor.id, bk2_first_set_mode: "serienspiel" },
                id: "bk2_start_b_sp", tabindex: 6 do %>
            <%= t("table_monitor.bk2_kombi.first_set_mode.button_serienspiel_b") %>
          <%- end %>
        </div>
      </div>
    <%- else %>
      <div class="flex h-1/2 flex-row w-full space-x-4">
        <div class="flex-1 h-full text-center">
          <%= content_tag "div", class: "text-2vw h-2/3 btn btn-primary", data: { turbo: false, reflex: "click->TableMonitorReflex#start_game", id: table_monitor.id }, id: "start_game", tabindex: 6 do %>
            <%= "#{left_player[:fullname]} stößt an!" %>
          <%- end %>
        </div>
        <div class="flex-1 h-full text-center">
          <%= content_tag "div", class: "text-2vw h-2/3 btn btn-primary", data: { turbo: false, reflex: "click->TableMonitorReflex#switch_players_and_start_game", id: table_monitor.id }, id: "switch_and_start", tabindex: 6 do %>
            <%= "#{right_player[:fullname]} stößt an!" %>
          <%- end %>
        </div>
      </div>
    <%- end %>
  </div>
</div>
