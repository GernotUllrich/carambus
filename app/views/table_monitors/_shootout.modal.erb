<div class="flex overflow-x-hidden overflow-y-auto fixed inset-0 z-50 outline-none focus:outline-none justify-center items-center" id="modal-id">
  <div id="table_monitor_modal_shootout_<%= table_monitor.id %>" class="modal-content bg-gray-100 space-y-4 flex-col h-1/2">
    <div class="flex h-1/3 flex-col space-x-4">
      <%- gps = table_monitor.game.andand.game_participations.andand.order(:role).to_a %>
      <div class="flex h-1/2 flex-row items-center text-black space-x-4 m-4 mb-8">
        <div class="flex-auto text-3vw <%= !table_monitor.data["switch_colors"] ? "" : "bg-yellow-500" %> items-center text-center font-semibold"><%= table_monitor.tournament_monitor_id.present? ? gps[0].andand.player.andand.fullname : gps[0].andand.player.andand.simple_firstname || "Spieler A" %></div>
        <div class="flex-auto items-center bg-white text-2vw text-center font-bold">
          <%= link_to toggle_dark_mode_table_monitor_path(table_monitor), :"data-turbolinks" => false do %>
            <%= render_svg "icons/adjust", styles: "focus:outline-none focus:ring-8 focus:ring-green-500 focus:ring-opacity-90 border-0 fill-current z-0 icon-lg mb-4 lg:m-4 mr-0 hover:text-black text-gray-400 inline-block", title: "home" %>
          <% end %>
          <%= link_to scoreboard_location_path(table_monitor.table.location.md5, sb_state: "welcome", :"data-turbolinks" => false) do %>
            <%= render_svg "icons/home", styles: "focus:outline-none focus:ring-8 focus:ring-green-500 focus:ring-opacity-90 border-0 fill-current icon-lg lg:m-4 mb-4 mr-0 hover:text-black text-gray-400 inline-block", title: "home" %>
          <% end %>
          <%= link_to "#", :onclick => "warning_mode()", :"data-turbolinks" => false do %>
            <%= render_svg "icons/arrow-outline-left", styles: "focus:outline-none focus:ring-8 focus:ring-green-500 focus:ring-opacity-90 border-0 fill-current icon-lg mb-4 lg:m-4 hover:text-black text-gray-400 inline-block", title: "home" %>
          <% end %>
        </div>
        <div class="flex-auto text-3vw <%= table_monitor.data["switch_colors"] ? "" : "bg-yellow-500 " %> items-center text-center font-semibold"><%= table_monitor.tournament_monitor_id.present? ? gps[1].andand.player.andand.fullname : gps[1].andand.player.andand.simple_firstname || "Spieler B" %></div>
      </div>
    </div>
    <div class="flex h-1/3 flex-row w-full space-x-4">
      <h3 class="flex-1 text-right text-black">
        <%= t('table_monitor.status.shootout_result') %>:
      </h3>
      <div class="flex-1">
        <%= content_tag "div", class: "btn btn-primary", data: { turbolinks: false, reflex: "click->TableMonitorReflex#switch_players", id: table_monitor.id }, id: "change", tabindex: 6 do %>
          <%= t('table_monitor.status.exchange_players') %>
        <%- end %>
      </div>
        <h3 class="flex-1 text-right text-black">
        <%= t('table_monitor.status.shootout_change_colors') %>:
      </h3>
      <div class="flex-1">
        <%= content_tag "div", class: "btn btn-primary", data: { turbolinks: false, reflex: "click->TableMonitorReflex#switch_colors", id: table_monitor.id }, id: "change", tabindex: 6 do %>
          <%= t('table_monitor.status.exchange_colors') %>
        <%- end %>
      </div>
    </div>
    <div class="flex h-1/3 mt-4 flex-col space-x-4">
      <div class="flex flex-1 justify-center ">
        <%= content_tag "div", class: "focus:outline-none focus:ring-8 focus:ring-green-500 focus:ring-opacity-90 border-0 btn btn-primary", data: { turbolinks: false, reflex: "click->TableMonitorReflex#start_game", id: table_monitor.id }, id: "start_game", tabindex: 6 do %>
          <%= t('table_monitor.status.start_game') %>
        <%- end %>
      </div>
    </div>
  </div>
</div>
