<div id="table_monitor_modal_<%= table_monitor.id %>" class="modal-content bg-gray-100 dark:bg-gray-800 space-y-4 flex-col h-1/2">
  <div class="flex h-1/3 flex-col space-x-4">
    <%- gps = table_monitor.game.andand.game_participations.andand.order(:role).to_a %>
    <div class="flex h-1/2 flex-row items-center text-black dark:text-white  space-x-4 m-4 mb-8">
      <div class="flex-1 text-3vw items-center text-center font-semibold"><%= gps[0].andand.player.andand.fullname %></div>
      <div class="flex-1 text-3vw bg-yellow-200 dark:text-yellow-200 dark:bg-black items-center text-center font-semibold"><%= gps[1].andand.player.andand.fullname %></div>
    </div>
  </div>
  <div class="flex h-1/3 flex-row w-full space-x-4">
    <h3 class="flex-1 text-right">
      Ausstossergebnis:
    </h3>
    <div class="flex-1">
      <%= content_tag "div", class: "btn btn-primary", data: {reflex: "click->TableMonitorReflex#switch_players", id: table_monitor.id} do %>
        Spieler tauschen
      <%- end %>
    </div>
  </div>
  <div class="flex h-1/3 mt-4 flex-col space-x-4">
    <div class="flex flex-1 justify-center ">
      <%= content_tag "div", class: "btn btn-primary", data: {reflex: "click->TableMonitorReflex#start_game", id: table_monitor.id} do %>
        Spielbeginn
      <%- end %>
    </div>
  </div>
</div>
