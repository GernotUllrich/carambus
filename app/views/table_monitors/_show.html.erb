<!--suppress RubyScope, RubyScope, RubyScope -->
<script src="https://unpkg.com/hotkeys-js/dist/hotkeys.js"></script>
<script type="text/javascript">
  <%- previous_panel, previous_element = [table_monitor.panel_state, table_monitor.current_element] %>
  <%- panel_state, current_element = evaluate_panel_and_current(table_monitor) %>
  var panel_nav_b = {
    "undo": "minus_one",
    "minus_one": "minus_ten",
    "minus_ten": "next_step",
    "next_step": "add_ten",
    "add_ten": "add_one",
    "add_one": "numbers",
    "numbers": "undo",
    "pause": "stop",
    "play": "stop",
    "stop": "pause",
    "pointer_mode": "pointer_mode",
    "nnn_1": "nnn_2",
    "nnn_2": "nnn_3",
    "nnn_3": "nnn_1",
    "nnn_4": "nnn_5",
    "nnn_5": "nnn_6",
    "nnn_6": "nnn_4",
    "nnn_7": "nnn_8",
    "nnn_8": "nnn_9",
    "nnn_9": "nnn_7",
    "nnn_0": "nnn_c",
    "nnn_c": "nnn_enter",
    "nnn_enter": "nnn_0",
    "start_game": "change",
    "change": "start_game",
    "continue": "practice_a",
    "practice_a": "practicet_b",
    "practice_b": "continue",
  }
  var panel_nav_d = {
    "pointer_mode": "inputs",
    "inputs": "timer",
    "timer": "pointer_mode",
    "nnn_1": "nnn_4",
    "nnn_2": "nnn_5",
    "nnn_3": "nnn_6",
    "nnn_4": "nnn_7",
    "nnn_5": "nnn_8",
    "nnn_6": "nnn_9",
    "nnn_7": "nnn_0",
    "nnn_8": "nnn_c",
    "nnn_9": "nnn_enter",
    "nnn_0": "nnn_1",
    "nnn_c": "nnn_2",
    "nnn_enter": "nnn_3",
  }
  var keyMap = {
    33: "key_a",
    37: "key_a",
    34: "key_b",
    39: "key_b",
    66: "key_c",
    38: "key_c",
    116: "key_d",
    27: "key_d",
    40: "key_d",
  }

  function focus_or_reset_element() {
    var el = document.getElementById(get_current_element())
    if (el != null) {
      document.getElementById(get_current_element()).focus()
      return true
    } else {
      reset_to_pointer_mode()
      return false
    }
  }

  function click_or_reset_element() {
    var el = document.getElementById(get_current_element())
    if (el != null) {
      document.getElementById(get_current_element()).click()
      return true
    } else {
      reset_to_pointer_mode()
      return false
    }
  }

  function isHidden(el) {
    return (el === null || el.offsetParent === null)
  }

  function backout() {
    set_panel_state(get_previous_panel())
    set_current_element(get_previous_element())
    focus_or_reset_element()
  }

  function set_panel_state(panel_state) {
    var el = document.getElementById("panel_state")
    if (el != null) {
      el.setAttribute("panel_state", panel_state)
      el.innerHTML = panel_state
    }
  }

  function get_panel_state() {
    var el = document.getElementById("panel_state")
    return el.getAttribute("panel_state")
  }

  function set_previous_panel(previous_panel) {
    var el = document.getElementById("previous_panel")
    el.setAttribute("previous_panel", previous_panel)
    el.innerHTML = previous_panel
  }

  function get_previous_panel() {
    var el = document.getElementById("previous_panel")
    return el.getAttribute("previous_panel")
  }

  function set_current_element(current_element) {
    var el = document.getElementById("current_element")
    el.setAttribute("current_element", current_element)
    el.innerHTML = current_element
  }

  function get_current_element() {
    var el = document.getElementById("current_element")

    return el == null ? null : el.getAttribute("current_element")
  }

  function set_previous_element(previous_element) {
    var el = document.getElementById("previous_element")
    el.setAttribute("previous_element", previous_element)
    el.innerHTML = previous_element
  }

  function get_previous_element() {
    var el = document.getElementById("previous_element")
    return el.getAttribute("previous_element")
  }

  function reset_to_pointer_mode() {
    set_panel_state("pointer_mode")
    set_current_element("pointer_mode")
    var el = document.getElementById(get_current_element())
    if (el != null)
      el.focus()
  }

  window.onload = function () {
    console.log("active: " + get_current_element());
    if (get_current_element() != "" && get_current_element() != null) {
      console.log("active now: " + get_current_element());
      focus_or_reset_element()
    } else
      reset_to_pointer_mode()
  };
  // backspace, tab, clear, enter, return, esc, escape, space, up, down, left, right, home, end, pageup, pagedown, del, delete and f1 through f19
  hotkeys('*', function (event, handler) {
// Prevent the default refresh event under WINDOWS system
    set_previous_element(get_current_element())
    set_previous_panel(get_panel_state())
    event.preventDefault();
    console.log(hotkeys.getPressedKeyCodes());
    //alert('you pressed ' + hotkeys.getPressedKeyCodes());
    if (event.keyCode in keyMap) {
      var keyCode = keyMap[event.keyCode]
      if (keyCode == "key_c") window.history.back()
      else if (keyCode == "key_d") {
        if (get_panel_state() == "pointer_mode") { // => inputs
          set_panel_state(panel_nav_d[get_panel_state()])
          set_current_element("numbers")
          if (!focus_or_reset_element())
            backout()
        } else if (get_panel_state() == "inputs") { // goto => timer
          set_panel_state(panel_nav_d[get_panel_state()])
          var play = isHidden(document.getElementById("pause"))
          set_current_element(play ? "play" : "pause")
          if (!focus_or_reset_element())
            backout()
        } else if (get_panel_state() == "timer") { // goto pointer_mode
          set_current_element("pointer_mode")
          set_panel_state(panel_nav_d[get_panel_state()])
          var el = document.getElementById(get_current_element());
          if (!focus_or_reset_element())
            backout()
        } else if (get_panel_state() == "shootout") { // => shootout
          set_current_element("start_game")
          if (!click_or_reset_element())
            backout()
          set_panel_state("pointer_mode")
          set_current_element("pointer_mode")
        } else if (get_panel_state() == "setup") { // => setu
          set_current_element("continue")
          if (!click_or_reset_element())
            backout()
          set_panel_state("shootout")
          set_current_element("start_game")
        } else if (get_panel_state() == "numbers") {
          set_current_element(panel_nav_d[get_current_element()])
          if (!focus_or_reset_element())
            backout()
        }
      } else if (keyCode == "key_b") {
        if (get_panel_state() == "pointer_mode" || get_panel_state() == "setup") {
          document.getElementById(keyCode + '_table_monitor_<%= table_monitor.id %>').click();
        } else if (get_panel_state() == "inputs" || get_panel_state() == "numbers") {
          set_current_element(panel_nav_b[get_current_element()])
          if (!focus_or_reset_element())
            backout()
        } else if (get_panel_state() == "timer") {
          var play = isHidden(document.getElementById("pause"))
          var next = (panel_nav_b[get_current_element()] == "pause" ? (play ? "play" : "pause") : panel_nav_b[get_current_element()])
          set_current_element(next)
          if (!focus_or_reset_element())
            backout()
        } else if (get_panel_state() == "shootout") {
          set_current_element("change")
          document.getElementById("change")
          if (!click_or_reset_element())
            backout()
        }
      } else if (keyCode == "key_a") {
        if (get_panel_state() == "pointer_mode" || get_panel_state() == "setup") {
          document.getElementById(keyCode + '_table_monitor_<%= table_monitor.id %>').click()
        } else if (get_panel_state() == "timer" || get_panel_state() == "inputs" || get_panel_state() == "numbers") {
          if (!click_or_reset_element())
            backout()
        } else if (get_panel_state() == "shootout") {
          set_current_element("change")
          if (!click_or_reset_element())
            backout()
        }
      }
    }
    console.log("active panel_state: " + get_panel_state());
    console.log("active current_element: " + get_current_element());
    return true
  })
  ;
</script>
<%- if table_monitor.present? %>
  <%- time_counter, green_bars = table_monitor.get_progress_bar_status(18) %>
  <%- gps = table_monitor.game.andand.game_participations.andand.order(:role).to_a %>
  <%- options = {
    id: table_monitor.id,
    name: table_monitor.name,
    game_name: table_monitor.game.andand.display_gname,
    tournament_title: table_monitor.andand.tournament_monitor.andand.tournament.andand.title,
    current_round: table_monitor.tournament_monitor.andand.current_round,
    active_timer: table_monitor.active_timer,
    start_at: table_monitor.timer_start_at,
    finish_at: table_monitor.timer_finish_at,
    player_a_active: table_monitor.playing_game? && (table_monitor.data["current_inning"].andand["active_player"] == gps[0].andand.role),
    player_b_active: table_monitor.playing_game? && (table_monitor.data["current_inning"].andand["active_player"] == gps[1].andand.role),
    player_a: {
      logo: gps[0].andand.player.andand.club.andand.logo,
      fullname: gps[0].andand.player.andand.fullname,
      balls_goal: table_monitor.data[gps[0].andand.role].andand["balls_goal"].to_i,
      result: table_monitor.data[gps[0].andand.role].andand["result"].to_i,
      hs: table_monitor.data[gps[0].andand.role].andand["hs"],
      gd: table_monitor.data[gps[0].andand.role].andand["gd"],
      innings: table_monitor.data[gps[0].andand.role].andand["innings"],
      innings_goal: table_monitor.data[gps[0].andand.role].andand["innings_goal"]
    },
    player_b: {
      logo: gps[1].andand.player.andand.club.andand.logo,
      fullname: gps[1].andand.player.andand.fullname,
      balls_goal: table_monitor.data[gps[1].andand.role].andand["balls_goal"].to_i,
      result: table_monitor.data[gps[1].andand.role].andand["result"].to_i,
      hs: table_monitor.data[gps[1].andand.role].andand["hs"],
      gd: table_monitor.data[gps[1].andand.role].andand["gd"],
      innings: table_monitor.data[gps[1].andand.role].andand["innings"],
      innings_goal: table_monitor.data[gps[1].andand.role].andand["innings_goal"]
    },
    current_inning: {
      balls: table_monitor.data["current_inning"].andand["balls"].to_i
    }
  } %>
  <%- if full_screen %>
    <%= content_tag "div", id: "panel_state", panel_state: panel_state, style: "display: none" do %>
      <%= panel_state %>
    <%- end %>
    <%= content_tag "div", id: "current_element", current_element: current_element, style: "display: none" do %>
      <%= current_element %>
    <%- end %>
    <%= content_tag "div", id: "previous_panel", previous_panel: previous_panel, style: "display: none" do %>
      <%= previous_panel %>
    <%- end %>
    <%= content_tag "div", id: "previous_element", previous_element: previous_element, style: "display: none" do %>
      <%= previous_element %>
    <%- end %>
    <%= content_tag "div", class: "mr-1 min-w-1/3 flex items-center justify-center inline-block spacing-0 rounded-full font-bold leading-none text-4vw bg-gray-100 dark:bg-gray-800 hover:bg-gray-300 text-gray-400", title: "Add one to current Inning", data: { reflex: "click->TableMonitorReflex#key_a", id: options[:id] }, id: "key_a_table_monitor_#{table_monitor.id}", style: "display: none" do %>
      A
    <%- end %>
    <%= content_tag "div", class: "mr-1 min-w-1/3 flex items-center justify-center inline-block spacing-0 rounded-full font-bold leading-none text-4vw bg-gray-100 dark:bg-gray-800 hover:bg-gray-300 text-gray-400", title: "Add one to current Inning", data: { reflex: "click->TableMonitorReflex#key_b", id: options[:id] }, id: "key_b_table_monitor_#{table_monitor.id}", style: "display: none" do %>
      B
    <%- end %>
    <%= content_tag "div", class: "mr-1 min-w-1/3 flex items-center justify-center inline-block spacing-0 rounded-full font-bold leading-none text-4vw bg-gray-100 dark:bg-gray-800 hover:bg-gray-300 text-gray-400", title: "Add one to current Inning", data: { reflex: "click->TableMonitorReflex#key_c", id: options[:id] }, id: "key_c_table_monitor_#{table_monitor.id}", style: "display: none" do %>
      C
    <%- end %>
    <%= content_tag "div", class: "mr-1 min-w-1/3 flex items-center justify-center inline-block spacing-0 rounded-full font-bold leading-none text-4vw bg-gray-100 dark:bg-gray-800 hover:bg-gray-300 text-gray-400", title: "Add one to current Inning", data: { reflex: "click->TableMonitorReflex#key_d", id: options[:id] }, id: "key_d_table_monitor_#{table_monitor.id}", style: "display: none" do %>
      D
    <%- end %>
    <%- if table_monitor.setup_modal_should_be_open? %>
      <%= render partial: "table_monitors/game_setup",
                 locals: {
                   modal_hidden: false,
                   full_screen: full_screen,
                   table_monitor: table_monitor },
                 formats: :modal,
                 layout: "layouts/application"
      %>
    <%- end %>
    <%- if table_monitor.shootout_modal_should_be_open? %>
      <%= render partial: "table_monitors/shootout", locals: { table_monitor: table_monitor,
                                                               full_screen: full_screen,
                                                               modal_hidden: false },
                 formats: :modal,
                 layout: "layouts/application"
      %>
    <%- end %>
    <%- if table_monitor.numbers_modal_should_be_open? %>
      <%= render partial: "table_monitors/numbers", locals: { table_monitor: table_monitor,
                                                              full_screen: full_screen,
                                                              modal_hidden: false },
                 formats: :modal,
                 layout: "layouts/application"
      %>
    <%- end %>
  <%- end %>
  <%- if full_screen %>
    <div class="flex flex-col h-full bg-white dark:bg-black rounded shadow table_monitor_body_<%= options[:id] %>">
      <div class="flex h-5/6 bg-gray-200">
        <div class="w-2/5 bg-white dark:bg-black">
          <div class="flex h-1/6 bg-white dark:bg-black items -center">
            <div class="p-2"><%= image_tag(options[:player_a][:logo]) if options[:player_a][:logo].present? %></div>
            <div class="flex-nowrap <%= "p-4" if options[:player_a][:fullname].andand.length.to_i < 15 %> text-4vw"><%= options[:player_a][:fullname] %></div>
          </div>
          <div class="flex flex-col h-5/6 bg-white dark:bg-black border-solid <%= options[:player_a_active] ? "border-red-400 border-4" : "border-gray dark:border-gray-700 border-4" %>">
            <%- unless table_monitor.game_show_result? %>
              <div class="flex h-1/6">
                <div class="flex-1 text-left font-bold text-red-400">
                  <div class="text-8vw p-4">
                    <%= options[:player_a_active] ? table_monitor.data["playera"].andand["innings_redo_list"].andand[-1] : "" %>
                  </div>
                  <div class="text-2vw">
                    <%- to_play = options[:player_a][:balls_goal].to_i - (options[:player_a][:result].to_i + Array(table_monitor.data["playera"].andand["innings_redo_list"])[-1].to_i) %>
                    <%- if options[:player_a_active] && to_play <= 3 %>
                      pour <%= to_play %>
                    <%- end %>
                  </div>
                </div>
                <div class="flex flex-col flex-1 text-right text-gray-500 text-3vw">
                  <div class="flex-1 mb-1">
                    Ziel <%= options[:player_a][:balls_goal].to_i %>
                  </div>
                  <div class="flex-1 mb-1">GD: <%= options[:player_a][:gd] %></div>
                  <div class="flex-1">HS: <%= options[:player_a][:hs] %></div>
                </div>
              </div>
              <div class="flex h-4/6 text-center text-20vw justify-center items-center font-bold">
                <%= options[:player_a][:result].to_i + table_monitor.data["playera"].andand["innings_redo_list"].andand[-1].to_i %>
              </div>
              <%- showing_timer = (options[:player_a_active] && table_monitor.playing_game? && table_monitor.timer_finish_at.present?) ? "" : "hidden" %>
              <%- if showing_timer.blank? %>
                <div class="flex flex-1 flex-col">
                  <div class="flex flex-1 flex-row items-center <%= showing_timer %>" id="timer_table_monitor_<%= showing_timer %><%= table_monitor.id %>">
                    <div class="w-1/6 font-bold text-4vw p-2"><%= time_counter %></div>
                    <div class="flex flex-1 flex-row w-5/6">
                      <div class="flex text-6vw font-bold text-green-400"><%= "I" * green_bars %></div>
                      <div class="flex text-6vw font-bold text-red-400"><%= "I" * (18 - green_bars) %></div>
                    </div>
                  </div>
                </div>
              <%- else %>
                <div class="flex h-1/6 w-full flex-row">
                  <div class="flex items-end justify-end">
                    <%= link_to "#{@dark ? "Light<br>Mode" : "Dark<br>Mode"}".html_safe, toggle_dark_mode_table_monitor_path(table_monitor), :"data-turbolinks" => false %>
                  </div>
                  <div class="flex w-full items-end justify-end text-gray-500 text-3vw p-2">
                    <%= table_monitor.render_last_innings(6, gps[0].andand.role) %>
                  </div>
                </div>
              <%- end %>
            <%- else %>
              <%= table_monitor.render_innings_list(gps[0].andand.role) %>
            <%- end %>
          </div>
        </div>
        <div class="w-1/5 bg-grey">
          <%= content_tag "div", data: { reflex: "dblclick->TableMonitorReflex#force_next_state", id: options[:id] }, class: "flex flex-col h-1/6 items-center font-bold text-red-400 text-3vw p-2 text-center bg-white dark:bg-black" do %>
            <%= table_monitor.state_display(I18n.locale) %>
          <%- end %>
          <div class="flex flex-col h-5/6 bg-gray-100 dark:bg-gray-800">
            <div class="flex flex-col h-2/6" tabindex="3" id="pointer_mode">
              <div class="h-5/6 p-4 text-10vw font-bold text-center"><%= options[:player_a][:innings].to_i %></div>
              <%- unless table_monitor.tournament_monitor.andand.tournament.andand.handicap_tournier? %>
                <div class="h-1/6 items-center text-2vw justify-center text-center">von <%= options[:player_a][:innings_goal].to_i %></div>
              <%- end %>
            </div>
            <div class="flex flex-col h-3/6 bg-white dark:bg-black p-4 items-center ">
              <div class="flex flex-1 items-center font-bold text-center text-2vw"><%= options[:tournament_title] %></div>
              <div class="flex flex-1 items-center text-center text-2vw"><%= options[:name] %></div>
              <div class="flex flex-1 items-center text-center text-2vw">Runde <%= options[:current_round] %></div>
              <div class="flex flex-1 items-center text-center text-2vw"><%= options[:game_name] %></div>
            </div>
            <div class="flex flex-col items-center h-1/6">
              <div class="flex h-2/3 flex-row space-x-3 rounded-full">
                <%- if table_monitor.playing_game? %>
                  <%= content_tag "div", data: { reflex: "click->TableMonitorReflex#stop", id: options[:id] }, class: "mr-2 w-full flex items-center justify-center inline-block spacing-0 rounded-full font-bold leading-none bg-gray-100 dark:bg-gray-800 hover:bg-gray-300 text-gray-400 #{"hidden" if table_monitor.timer_finish_at.blank?}", title: "Stop", style: "letter-spacing: -3px;", id: "stop", tabindex: 1 do %>
                    <%= render_svg "icons/287-stop2", styles: "svg-red fill-current icon-2xl text-red-400 inline-block" %>
                  <%- end %>
                  <%= content_tag "div", data: { reflex: "click->TableMonitorReflex#pause", id: options[:id] }, class: "mr-2 w-full flex items-center justify-center inline-block spacing-0 rounded-full font-bold leading-none  bg-gray-100 dark:bg-gray-800 hover:bg-gray-300 text-gray-400 #{"hidden" if (table_monitor.timer_finish_at.present? && table_monitor.timer_halt_at.present?) || table_monitor.timer_finish_at.blank?}", title: "Pause", style: "letter-spacing: -3px;", id: "pause", tabindex: 1 do %>
                    <%= render_svg "icons/286-pause2", styles: "svg-red fill-current icon-2xl text-red-400 inline-block" %>
                  <%- end %>
                  <%= content_tag "div", data: { reflex: "click->TableMonitorReflex#play", id: options[:id] }, class: "mr-2 w-full flex items-center justify-center inline-block spacing-0 rounded-full font-bold leading-none bg-gray-100 dark:bg-gray-800 hover:bg-gray-300 text-gray-400 #{"hidden" if table_monitor.timer_finish_at.present? && table_monitor.timer_halt_at.blank?}", title: "Play", style: "letter-spacing: -3px;", id: "play", tabindex: 1 do %>
                    <%= render_svg "icons/285-play3", styles: "svg-red fill-current icon-2xl text-red-400 inline-block" %>
                  <%- end %>
                <%- end %>
              </div>
              <div class="flex h-1/3 font-bold text-2vw text-red-500"><%= "Halted" if table_monitor.timer_halt_at.present? %></div>
            </div>
          </div>
        </div>
        <div class="w-2/5 bg-yellow-200 dark:text-yellow-200 dark:bg-black">
          <div class="flex h-1/6 bg-white dark:bg-black items -center">
            <div class="p-2"><%= image_tag(options[:player_b][:logo]) if options[:player_b][:logo].present? %></div>
            <div class="flex-nowrap <%= "p-4" if options[:player_b][:fullname].andand.length.to_i < 15 %> text-4vw"><%= options[:player_b][:fullname] %></div>
          </div>
          <div class="flex flex-col h-5/6 bg-yellow-200 dark:text-yellow-200 dark:bg-black border-solid <%= options[:player_b_active] ? "border-red-400 border-4" : "border-gray dark:border-gray-700 border-4" %>">
            <%- unless table_monitor.game_show_result? %>
              <div class="flex h-1/6">
                <div class="flex flex-col flex-1 text-left text-gray-500 text-3vw">
                  <div class="flex-1 mb-1">
                    Ziel <%= options[:player_b][:balls_goal].to_i %>
                  </div>
                  <div class="flex-1 mb-1">GD: <%= options[:player_b][:gd] %></div>
                  <div class="flex-1"> HS: <%= options[:player_b][:hs] %></div>
                </div>
                <div class="flex-1 text-right font-bold text-red-400">
                  <div class="text-8vw p-4">
                    <%= options[:player_b_active] ? table_monitor.data["playerb"].andand["innings_redo_list"].andand[-1] : "" %>
                  </div>
                  <div class="text-2vw">
                    <%- to_play = options[:player_b][:balls_goal].to_i - (options[:player_b][:result].to_i + Array(table_monitor.data["playerb"].andand["innings_redo_list"])[-1].to_i) %>
                    <%- if table_monitor.follow_up? %>
                      Nachstoss
                    <%- end %>
                    <%- if options[:player_b_active] && to_play <= 3 %>
                      pour <%= to_play %>
                    <%- end %>
                  </div>
                </div>
              </div>
              <div class="flex h-4/6 text-center text-20vw justify-center items-center font-bold">
                <%= options[:player_b][:result].to_i + table_monitor.data["playerb"].andand["innings_redo_list"].andand[-1].to_i %>
              </div>
              <%- showing_timer = (options[:player_b_active] && table_monitor.playing_game? && table_monitor.timer_finish_at.present?) ? "" : "hidden" %>
              <%- if showing_timer.blank? %>
                <div class="flex flex-1 flex-col">
