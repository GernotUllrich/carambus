<% content_for :head do %>
<style>
  /* Klickbare Tabellenzeilen in Claude-Antworten */
  #chat-messages .prose tbody tr.tournament-row {
    cursor: pointer;
    transition: background-color 0.12s;
  }
  #chat-messages .prose tbody tr.tournament-row:hover {
    background-color: rgba(15, 95, 86, 0.08);
  }
  #chat-messages .prose tbody tr.tournament-row td:first-child::after {
    content: " →";
    opacity: 0;
    transition: opacity 0.12s;
    color: #0f5f56;
    font-size: 0.75em;
  }
  #chat-messages .prose tbody tr.tournament-row:hover td:first-child::after {
    opacity: 1;
  }

  @media print {
    * { -webkit-print-color-adjust: exact; print-color-adjust: exact; }
    @page { margin: 1.5cm; size: A4; }

    /* Alle Wrapper-Hintergründe auf Weiß — inkl. dark:bg-gray-900 auf <main> */
    html, body, main, header, .min-h-screen, .content-wrapper {
      background: white !important;
      color: #111827 !important;
      box-shadow: none !important;
    }

    /* Navbar, Header, Sidebar ausblenden */
    body > div > header,
    nav, aside, footer,
    [data-controller="sidebar"] > header,
    #chat-header, #chat-form-area { display: none !important; }

    /* Dark-Mode-Text-Reset für alle Chat-Elemente */
    #chat-messages, #chat-messages * { color: #111827 !important; }

    /* Assistenten-Bubble */
    #chat-messages .justify-start > div {
      background-color: #f3f4f6 !important;
      border: 1px solid #d1d5db !important;
    }
    /* User-Bubble */
    #chat-messages .justify-end > div,
    #chat-messages .justify-end > div * {
      background-color: #0f5f56 !important;
      color: #ffffff !important;
    }

    #chat-messages .flex { page-break-inside: avoid; margin-bottom: 0.5rem; }
  }
</style>
<% end %>

<div class="max-w-3xl mx-auto px-4 py-8">
  <div id="chat-header" class="flex items-center justify-between mb-6">
    <h1 class="text-2xl font-semibold text-gray-900 dark:text-gray-100 flex items-center gap-2">
      <%= inline_svg_tag 'icons/chat-bubble-dots.svg', class: 'w-7 h-7 text-primary-600' %>
      <%= t("spielleiter_chat.title") %>
    </h1>
    <div class="flex items-center gap-3">
      <%= link_to t("spielleiter_chat.as_pdf"), print_spielleiter_chat_path, target: "_blank",
            class: "text-sm text-gray-500 hover:text-primary-600 transition-colors" %>
      <%= button_to t("spielleiter_chat.new_conversation"), spielleiter_chat_path, method: :delete,
            class: "text-sm text-gray-500 hover:text-red-600 transition-colors" %>
    </div>
  </div>

  <!-- Nachrichtenbereich -->
  <div id="chat-messages" class="space-y-4 mb-6 min-h-[200px]">
    <% if @welcome_message %>
      <%= render 'message', message: {role: "assistant", content: @welcome_message} %>
    <% elsif @messages.empty? %>
      <p class="text-gray-400 text-center py-12">
        <%= t("spielleiter_chat.empty_hint") %>
      </p>
    <% end %>
    <% @messages.each do |msg| %>
      <%= render 'message', message: msg %>
    <% end %>
  </div>

  <!-- Eingabefeld -->
  <div id="chat-form-area">
    <%= form_with url: spielleiter_chat_path, method: :post, data: {turbo: false} do |f| %>
      <div class="flex gap-2">
        <%= f.text_field :message,
              placeholder: t("spielleiter_chat.input_placeholder"),
              autocomplete: "off",
              id: "chat-input",
              class: "flex-1 rounded-lg border border-gray-300 dark:border-gray-600 px-4 py-2 text-sm focus:outline-none focus:ring-2 focus:ring-primary-500 dark:bg-gray-700 dark:text-gray-100" %>
        <%= f.submit t("spielleiter_chat.send"),
              class: "px-4 py-2 bg-primary-600 text-white text-sm rounded-lg hover:bg-primary-700 transition-colors" %>
      </div>
    <% end %>

    <% if flash[:alert] %>
      <p class="mt-3 text-sm text-red-600"><%= flash[:alert] %></p>
    <% end %>
  </div>
</div>

<script>
  (function() {
    var input = document.getElementById('chat-input');
    if (input) {
      input.scrollIntoView({ block: 'end' });
      input.focus();
    }

    // Turniertabellen klickbar machen: Klick auf eine Zeile → Turniernahme ins Eingabefeld + absenden
    var chatMessages = document.getElementById('chat-messages');
    var chatForm = document.querySelector('#chat-form-area form');
    if (chatMessages && chatForm) {
      chatMessages.querySelectorAll('.prose table tbody tr').forEach(function(row) {
        var firstCell = row.querySelector('td');
        if (!firstCell) return;
        var name = firstCell.textContent.trim();
        if (!name) return;
        row.classList.add('tournament-row');
        row.title = '"' + name + '" auswählen';
        row.addEventListener('click', function() {
          var inp = document.getElementById('chat-input');
          if (inp) { inp.value = name; chatForm.submit(); }
        });
      });
    }
  })();
</script>
