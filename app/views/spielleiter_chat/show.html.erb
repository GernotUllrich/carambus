<div class="max-w-3xl mx-auto px-4 py-8">
  <div class="flex items-center justify-between mb-6">
    <h1 class="text-2xl font-semibold text-gray-900 dark:text-gray-100 flex items-center gap-2">
      <%= inline_svg_tag 'icons/chat-bubble-dots.svg', class: 'w-7 h-7 text-blue-600' %>
      Sportwart-Assistent
    </h1>
    <%= button_to "Neues Gespräch", spielleiter_chat_path, method: :delete,
          class: "text-sm text-gray-500 hover:text-red-600 transition-colors" %>
  </div>

  <!-- Nachrichtenbereich -->
  <div id="chat-messages" class="space-y-4 mb-6 min-h-[200px]">
    <% if @welcome_message %>
      <%= render 'message', message: {role: "assistant", content: @welcome_message} %>
    <% elsif @messages.empty? %>
      <p class="text-gray-400 text-center py-12">
        Stelle eine Frage — z.B. „Welche Turniere sind aktuell offen?"
      </p>
    <% end %>
    <% @messages.each do |msg| %>
      <%= render 'message', message: msg %>
    <% end %>
  </div>

  <!-- Eingabefeld -->
  <%= form_with url: spielleiter_chat_path, method: :post, data: {turbo: false} do |f| %>
    <div class="flex gap-2">
      <%= f.text_field :message,
            placeholder: "Nachricht eingeben...",
            autocomplete: "off",
            id: "chat-input",
            class: "flex-1 rounded-lg border border-gray-300 dark:border-gray-600 px-4 py-2 text-sm focus:outline-none focus:ring-2 focus:ring-blue-500 dark:bg-gray-700 dark:text-gray-100" %>
      <%= f.submit "Senden",
            class: "px-4 py-2 bg-blue-600 text-white text-sm rounded-lg hover:bg-blue-700 transition-colors" %>
    </div>
  <% end %>

  <% if flash[:alert] %>
    <p class="mt-3 text-sm text-red-600"><%= flash[:alert] %></p>
  <% end %>
</div>

<script>
  (function() {
    var input = document.getElementById('chat-input');
    if (input) {
      input.scrollIntoView({ block: 'end' });
      input.focus();
    }
  })();
</script>
