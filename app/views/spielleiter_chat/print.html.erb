<!DOCTYPE html>
<html lang="de">
<head>
  <meta charset="UTF-8">
  <title>Sportwart-Assistent – Gesprächsprotokoll</title>
  <style>
    body {
      font-family: system-ui, -apple-system, sans-serif;
      font-size: 13px;
      line-height: 1.5;
      color: #111827;
      background: white;
      margin: 0;
      padding: 2cm;
    }
    h1 {
      font-size: 16px;
      font-weight: 600;
      color: #111827;
      margin: 0 0 4px 0;
    }
    .meta {
      font-size: 11px;
      color: #6b7280;
      margin-bottom: 24px;
      border-bottom: 1px solid #e5e7eb;
      padding-bottom: 12px;
    }
    .message { margin-bottom: 12px; display: flex; }
    .message.user { justify-content: flex-end; }
    .message.assistant { justify-content: flex-start; }
    .bubble {
      max-width: 75%;
      border-radius: 8px;
      padding: 10px 14px;
      font-size: 13px;
    }
    .bubble.user {
      background: #2563eb;
      color: white;
    }
    .bubble.assistant {
      background: #f3f4f6;
      color: #111827;
      border: 1px solid #e5e7eb;
    }
    /* Markdown-Elemente */
    .bubble p { margin: 0 0 6px 0; }
    .bubble p:last-child { margin-bottom: 0; }
    .bubble ul, .bubble ol { margin: 4px 0 6px 0; padding-left: 20px; }
    .bubble li { margin-bottom: 2px; }
    .bubble strong { font-weight: 600; }
    .bubble table { border-collapse: collapse; width: 100%; margin: 6px 0; font-size: 12px; }
    .bubble th, .bubble td { border: 1px solid #d1d5db; padding: 4px 8px; text-align: left; }
    .bubble th { background: #e5e7eb; font-weight: 600; }
    .bubble.user table, .bubble.user th { border-color: rgba(255,255,255,0.3); }
    .bubble.user th { background: rgba(255,255,255,0.15); }
    @page { margin: 1.5cm; size: A4; }
    @media print { body { padding: 0; } }
  </style>
</head>
<body>
  <h1>Sportwart-Assistent – Gesprächsprotokoll</h1>
  <div class="meta">Exportiert: <%= Time.current.strftime("%d.%m.%Y %H:%M") %></div>

  <% @messages.each do |msg| %>
    <% role = msg[:role].to_s %>
    <% content = msg[:content] %>
    <% next if role == "tool" %>
    <% text = content.is_a?(String) ? content : Array(content).select { |b| b.is_a?(Hash) && b[:type].to_s == "text" }.map { |b| b[:text] }.join %>
    <% next if text.blank? %>
    <div class="message <%= role %>">
      <div class="bubble <%= role %>">
        <%= markdown(text) %>
      </div>
    </div>
  <% end %>

  <script>window.onload = function() { window.print(); }</script>
</body>
</html>
