<h1>Listing TournamentPlan Games</h1>

<table>
  <thead>
    <tr>
      <th>Name</th>
      <th>TournamentPlan</th>
      <th>Remarks</th>
      <th colspan="3"></th>
    </tr>
  </thead>

  <tbody>
    <% @tournament_plan_games.each do |tournament_plan_game| %>
      <tr>
        <td><%= tournament_plan_game.name %></td>
        <td><%= tournament_plan_game.tournament_plan_id %></td>
        <td><%= tournament_plan_game.remarks %></td>
        <td><%= link_to image_tag("ansehen.gif", :width => 26, :height => 22, :border => 0), tournament_plan_game %></td>
        <td><%= link_to image_tag("bearbeiten.gif", :width => 26, :height => 22, :border => 0), edit_tournament_plan_game_path(tournament_plan_game) %></td>
        <td><%= link_to image_tag("loeschen.gif", :width => 26, :height => 22, :border => 0), tournament_plan_game, method: :delete, data: { confirm: 'Are you sure?' } %></td>
      </tr>
    <% end %>
  </tbody>
</table>

<br>

<%= link_to 'New TournamentPlan game', new_tournament_plan_game_path %>
