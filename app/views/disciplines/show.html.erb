<%# 14-03: auf die generische Detail-Card migriert. Sub-Disziplinen (has_many) im details-Slot,
    nur wenn vorhanden (H9: kein leerer Kasten). Erbt H1 (leere Felder aus), H5 (Titel=Name),
    H30 (Edit-Gate) aus shared/_detail_card + ScaffoldHelper. %>
<% details = capture do %>
  <% subs = @discipline.sub_disciplines.order(:name) %>
  <% if subs.any? %>
    <div class="bg-surface-card dark:bg-gray-800 rounded-card border border-gray-200 dark:border-gray-700 p-6 text-gray-900 dark:text-gray-100">
      <h2 class="text-xs uppercase tracking-wide text-gray-400 dark:text-gray-500 font-normal mb-2"><%= Discipline.human_attribute_name(:sub_disciplines) %></h2>
      <ul class="list-disc list-inside">
        <% subs.each do |sub| %>
          <li><%= custom_link_to sub.name, discipline_path(sub) %></li>
        <% end %>
      </ul>
    </div>
  <% end %>
<% end %>
<%= render "shared/detail_card", record: @discipline, details: details.presence %>
