        <%= @region_cc.cc_id %>
      </div>
            <div class="mb-4">
        <h5>Context</h5>
        <%= @region_cc.context %>
      </div>
            <div class="mb-4">
        <h5>Region</h5>
        <%= @region_cc.region_id %>
      </div>
            <div class="mb-4">
        <h5>Shortname</h5>
        <%= @region_cc.shortname %>
      </div>
            <div class="mb-4">
        <h5>Name</h5>
        <%= @region_cc.name %>
      </div>
          </div>
