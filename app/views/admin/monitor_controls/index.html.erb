<div class="container mx-auto my-8 px-4">
  <div class="max-w-4xl mx-auto">
    <h1 class="text-3xl font-bold mb-6">Monitor Controls</h1>
    
    <% if flash[:success] %>
      <div class="bg-green-100 border border-green-400 text-green-700 px-4 py-3 rounded mb-4">
        <%= flash[:success] %>
      </div>
    <% end %>
    
    <% if flash[:error] %>
      <div class="bg-red-100 border border-red-400 text-red-700 px-4 py-3 rounded mb-4">
        <%= flash[:error] %>
      </div>
    <% end %>
    
    <div class="bg-white rounded-lg shadow p-6">
      <h2 class="text-xl font-semibold mb-4">Force Monitor Reload</h2>
      <p class="text-gray-600 mb-6">
        Trigger a page reload on all monitors connected to a specific location.
        Use this to refresh frozen displays or apply updates.
      </p>
      
      <div class="space-y-4">
        <% @locations.each do |location| %>
          <div class="flex items-center justify-between border-b pb-3">
            <div>
              <div class="font-medium"><%= location.name %></div>
              <div class="text-sm text-gray-500">Location #<%= location.id %></div>
            </div>
            <%= button_to 'Force Reload', 
                admin_monitor_controls_force_reload_path(location_id: location.id), 
                method: :post,
                class: "btn btn-primary",
                data: { confirm: "Reload all monitors for #{location.name}?" } %>
          </div>
        <% end %>
      </div>
    </div>
    
    <div class="mt-6 bg-blue-50 border border-blue-200 rounded-lg p-4">
      <h3 class="font-semibold text-blue-900 mb-2">ℹ️ How it works</h3>
      <ul class="text-sm text-blue-800 space-y-1">
        <li>• Sends reload signal via ActionCable to all connected monitors</li>
        <li>• Monitors reload within ~1 second of receiving signal</li>
        <li>• Useful for applying updates or recovering frozen displays</li>
        <li>• Only affects monitors showing table_scores for the selected location</li>
      </ul>
    </div>
  </div>
</div>
