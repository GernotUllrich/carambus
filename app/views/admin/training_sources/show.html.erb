<%#
# Show

This view is the template for the show page.
It renders the attributes of a resource,
as well as a link to its edit page.
%>

<% content_for(:title) { t("administrate.actions.show_resource", name: page.page_title) } %>

<header class="main-content__header">
  <h1 class="main-content__page-title">
    <%= content_for(:title) %>
  </h1>

  <div>
    <%= link_to(
      t("administrate.actions.edit_resource", name: page.page_title),
      [:edit, namespace, page.resource],
      class: "button",
    ) if accessible_action?(page.resource, :edit) %>

    <%= link_to(
      t("administrate.actions.destroy"),
      [namespace, page.resource],
      class: "button button--danger",
      method: :delete,
      data: { confirm: t("administrate.actions.confirm") }
    ) if accessible_action?(page.resource, :destroy) %>
  </div>
</header>

<section class="main-content__body">
  <dl>
    <% page.attributes.each do |attribute| %>
      <dt class="attribute-label" id="<%= attribute.name %>">
      <%= t(
        "helpers.label.#{resource_name}.#{attribute.name}",
        default: page.resource.class.human_attribute_name(attribute.name),
      ) %>
      </dt>

      <dd class="attribute-data attribute-data--<%= attribute.html_class %>">
        <%= render_field attribute, page: page %>
      </dd>
    <% end %>
  </dl>

  <%# Custom section for source files %>
  <% if page.resource.source_files.attached? %>
    <div class="mt-10 p-5 rounded-lg border-2 border-gray-300 bg-gray-50 dark:border-gray-700 dark:bg-gray-800">
      <h3 class="mt-0 mb-5 pb-2.5 border-b-2 border-gray-400 dark:border-gray-600 text-gray-800 dark:text-gray-100">
        📎 Quelldateien (<%= page.resource.source_files.count %>)
      </h3>

      <div class="source-files-grid grid gap-4">
        <% page.resource.source_files.each do |file| %>
          <div class="p-4 rounded-md border-l-4 border-success-500 bg-white dark:bg-gray-900">
            <div class="flex justify-between items-start gap-4">
              <div class="flex-1">
                <strong class="text-gray-800 dark:text-gray-100 text-lg">
                  <%= file.filename %>
                </strong>
                <br>
                <span class="text-gray-500 dark:text-gray-400 text-sm">
                  <%= file.content_type %> • <%= number_to_human_size(file.byte_size) %>
                </span>

                <% if file.representable? %>
                  <div class="mt-2.5">
                    <%= image_tag file.representation(resize_to_limit: [300, 300]),
                                 class: "max-w-full rounded shadow" %>
                  </div>
                <% end %>
              </div>

              <div class="flex flex-col gap-2">
                <%= link_to "👁️ Ansehen",
                           rails_blob_path(file, disposition: "inline"),
                           target: "_blank",
                           class: "inline-block px-4 py-2 rounded text-white text-sm font-medium no-underline whitespace-nowrap bg-success-600 hover:bg-success-700" %>

                <%= link_to "⬇️ Download",
                           rails_blob_path(file, disposition: "attachment"),
                           class: "inline-block px-4 py-2 rounded text-white text-sm font-medium no-underline whitespace-nowrap bg-info-600 hover:bg-info-700" %>

                <%= button_to "🗑️ Löschen",
                             delete_attachment_admin_training_source_path(page.resource, attachment_id: file.id),
                             method: :delete,
                             data: { confirm: "Datei '#{file.filename}' wirklich löschen?" },
                             class: "px-4 py-2 rounded text-white text-sm font-medium cursor-pointer whitespace-nowrap border-0 bg-danger-600 hover:bg-danger-700",
                             form: { class: "inline" } %>
              </div>
            </div>
          </div>
        <% end %>
      </div>
    </div>
  <% end %>
</section>
