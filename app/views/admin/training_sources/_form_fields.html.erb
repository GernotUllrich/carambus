<%# Use default Administrate form fields %>
<% page.attributes(action_name).each do |attribute| %>
  <div class="field-unit field-unit--<%= attribute.html_class %> field-unit--<%= requireness(attribute) %>">
    <%= render_field attribute, f: form %>
  </div>
<% end %>

<%# Custom file upload field %>
<div class="mt-8 p-5 rounded-lg border-2 border-gray-300 bg-gray-50 dark:border-gray-700 dark:bg-gray-800">
  <h4 class="mt-0 mb-4 pb-2 border-b-2 border-gray-400 dark:border-gray-600 text-gray-800 dark:text-gray-100">
    📎 Quelldateien
  </h4>

  <%= form.label :source_files, "PDFs, Videos, Bilder hochladen", class: "block font-bold text-gray-800 dark:text-gray-100 mb-2" %>
  <%= form.file_field :source_files,
                      multiple: true,
                      class: "block w-full text-gray-800 dark:text-gray-200" %>
  <p class="field-hint mt-2 text-sm text-gray-500 dark:text-gray-400">
    Mehrere Dateien gleichzeitig möglich. Unterstützte Formate: PDF, JPG, PNG, MP4
  </p>

  <% if page.resource.source_files.attached? %>
    <div class="attached-files mt-5">
      <p class="font-bold text-gray-600 dark:text-gray-300 mb-2.5">Vorhandene Dateien:</p>
      <% page.resource.source_files.each do |file| %>
        <div class="flex justify-between items-center p-3 mb-2 rounded-md border-l-4 border-success-500 bg-white dark:bg-gray-900">
          <div>
            <strong class="text-gray-800 dark:text-gray-100"><%= file.filename %></strong>
            <span class="text-gray-500 dark:text-gray-400 text-sm ml-2">
              (<%= number_to_human_size(file.byte_size) %>)
            </span>
            <% if file.representable? %>
              <br>
              <%= image_tag file.representation(resize_to_limit: [200, 200]),
                           class: "max-w-[200px] mt-2 rounded" %>
            <% end %>
          </div>
          <%= link_to "⬇️ Download",
                      rails_blob_path(file, disposition: "attachment"),
                      class: "inline-block px-3 py-1 rounded text-white text-sm no-underline whitespace-nowrap bg-info-600 hover:bg-info-700" %>
        </div>
      <% end %>
    </div>
  <% end %>
</div>
