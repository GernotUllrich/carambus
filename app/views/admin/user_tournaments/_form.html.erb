<%# Phase 37-03: Custom-Form fuer TL-Zuordnung. Ersetzt das Administrate-Default-Form,
    damit (1) das Turnier scoped + handhabbar gewaehlt wird (Saison+Region statt ~2300)
    und (2) kein TournamentDashboard fuer das tournament-BelongsTo noetig ist. %>
<%= form_for([namespace, page.resource], html: { class: "form" }) do |f| %>
  <% if page.resource.errors.any? %>
    <div id="error_explanation">
      <ul>
        <% page.resource.errors.full_messages.each do |message| %>
          <li class="flash-error"><%= message %></li>
        <% end %>
      </ul>
    </div>
  <% end %>

  <div class="field-unit field-unit--belongs-to">
    <div class="field-unit__label"><%= f.label :tournament_id, "Turnier" %></div>
    <div class="field-unit__field">
      <%= f.select :tournament_id,
            options_for_select(assignable_tournaments, page.resource.tournament_id),
            { include_blank: "— Turnier wählen —" },
            { class: "text-input" } %>
      <p class="field-unit__help text-[0.85em] text-gray-500 dark:text-gray-400">
        Turniere der aktuellen Saison in der Server-Region.
      </p>
    </div>
  </div>

  <div class="field-unit field-unit--belongs-to">
    <div class="field-unit__label"><%= f.label :user_id, "Turnierleiter (Benutzer)" %></div>
    <div class="field-unit__field">
      <%= f.collection_select :user_id, assignable_users, :id, :email,
            { include_blank: "— Benutzer wählen —" },
            { class: "text-input" } %>
    </div>
  </div>

  <div class="field-unit field-unit--select">
    <div class="field-unit__label"><%= f.label :role, "Rolle" %></div>
    <div class="field-unit__field">
      <%= f.select :role, UserTournament::ROLES,
            { selected: page.resource.role.presence || "turnier_leiter" },
            { class: "text-input" } %>
    </div>
  </div>

  <div class="form-actions">
    <%= f.submit %>
  </div>
<% end %>
