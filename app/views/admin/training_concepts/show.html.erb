<%#
# Show
%>

<% content_for(:title) { t("administrate.actions.show_resource", name: page.page_title) } %>

<header class="main-content__header">
  <h1 class="main-content__page-title">
    <%= content_for(:title) %>
  </h1>

  <div>
    <%= link_to(
      t("administrate.actions.edit_resource", name: page.page_title),
      [:edit, namespace, page.resource],
      class: "button",
    ) if accessible_action?(page.resource, :edit) %>

    <%= button_to(
      "🌐 Translate",
      translate_admin_training_concept_path(page.resource),
      method: :post,
      class: "inline-block ml-2.5 px-4 py-2 rounded text-white font-medium bg-success-600 hover:bg-success-700",
      title: "Übersetze in DE und EN",
      form: { class: "inline-block" }
    ) if valid_action?(:translate) %>

    <%= link_to(
      t("administrate.actions.destroy"),
      [namespace, page.resource],
      class: "button button--danger",
      method: :delete,
      data: { confirm: t("administrate.actions.confirm") }
    ) if accessible_action?(page.resource, :destroy) %>
  </div>
</header>

<section class="main-content__body">
  <dl>
    <% page.attributes.each do |attribute| %>
      <dt class="attribute-label" id="<%= attribute.name %>">
      <%= t(
        "helpers.label.#{resource_name}.#{attribute.name}",
        default: page.resource.class.human_attribute_name(attribute.name),
      ) %>
      </dt>

      <dd class="attribute-data attribute-data--<%= attribute.html_class %>">
        <%= render_field attribute, page: page %>
      </dd>
    <% end %>
  </dl>
</section>

<!-- Trainingsbeispiele Section -->
<section class="main-content__body mt-10 clear-both">
  <header class="flex justify-between items-center mb-5 pb-2.5 w-full border-b-2 border-info-500">
    <h2 class="m-0 flex-1 text-gray-800 dark:text-gray-100">
      📚 Trainingsbeispiele
      <span class="text-gray-500 dark:text-gray-400 text-[0.8em]">(<%= page.resource.training_examples.count %>)</span>
    </h2>
    <%= link_to(
      "➕ Neues Beispiel",
      new_admin_training_concept_training_example_path(page.resource),
      class: "inline-block shrink-0 px-4 py-2 rounded text-white font-medium bg-success-600 hover:bg-success-700"
    ) %>
  </header>

  <% if page.resource.training_examples.any? %>
    <table class="table w-full border-collapse">
      <thead>
        <tr style="background: #ecf0f1;">
          <th style="padding: 10px; text-align: left; width: 60px;">#</th>
          <th style="padding: 10px; text-align: left;">Titel</th>
          <th style="padding: 10px; text-align: left;">Sprache</th>
          <th style="padding: 10px; text-align: center;">Übersetzt</th>
          <th style="padding: 10px; text-align: right; width: 200px;">Aktionen</th>
        </tr>
      </thead>
      <tbody>
        <%# v0.9 Phase D: sequence_number wanderte ins Join training_concept_examples. %>
        <% tces = page.resource.training_concept_examples.includes(:training_example).to_a.sort_by { |t| t.sequence_number || Float::INFINITY } %>
        <% tces.each_with_index do |tce, index| %>
          <% example = tce.training_example %>
          <tr style="border-bottom: 1px solid #ddd;">
            <td style="padding: 10px; font-weight: bold; color: #7f8c8d;">
              <%= tce.sequence_number || "—" %>
            </td>
            <td class="p-2.5">
              <strong><%= example.title %></strong>
              <% if example.ideal_stroke_parameters_text.present? %>
                <br>
                <span class="text-gray-500 dark:text-gray-400 text-[0.85em]">
                  <%= truncate(example.ideal_stroke_parameters_text, length: 80) %>
                </span>
              <% end %>
            </td>
            <td class="p-2.5">
              <span class="badge inline-block px-2 py-0.5 rounded text-[0.85em] bg-info-600 text-white">
                <%= example.source_language.upcase %>
              </span>
            </td>
            <td class="p-2.5 text-center">
              <% if example.translations_in_sync? %>
                <span class="text-success-600 text-xl" title="Übersetzungen synchronisiert">✅</span>
              <% else %>
                <span class="text-danger-500 text-xl" title="Übersetzungen nicht synchronisiert">⚠️</span>
              <% end %>
            </td>
            <td style="padding: 10px; text-align: right;">
              <%= link_to(
                "👁️ Anzeigen",
                admin_training_example_path(example),
                class: "inline-block mr-1.5 px-2.5 py-1 rounded text-white bg-info-600 hover:bg-info-700"
              ) %>
              <%= link_to(
                "✏️ Bearbeiten",
                edit_admin_training_example_path(example),
                class: "inline-block mr-1.5 px-2.5 py-1 rounded text-white bg-warning-500 hover:bg-warning-600"
              ) %>
              <%= button_to(
                "🗑️",
                admin_training_example_path(example),
                method: :delete,
                data: { confirm: "Trainingsbeispiel '#{example.title}' wirklich löschen?" },
                class: "inline-block px-2.5 py-1 rounded text-white bg-danger-600 hover:bg-danger-700",
                form: { class: "inline-block" }
              ) %>
            </td>
          </tr>
        <% end %>
      </tbody>
    </table>
  <% else %>
    <div class="bg-gray-100 dark:bg-gray-800 text-gray-500 dark:text-gray-400 p-8 text-center rounded-md">
      <p class="m-0 text-[1.1em]">
        📝 Noch keine Trainingsbeispiele vorhanden.
      </p>
      <p class="mt-2.5 mb-0">
        <%= link_to(
          "Erstes Beispiel hinzufügen →",
          new_admin_training_concept_training_example_path(page.resource),
          class: "text-info-600 dark:text-info-400 underline"
        ) %>
      </p>
    </div>
  <% end %>
</section>
