<%#
# Shot Form Fields
#%>

<% 
  source_language = f.object.respond_to?(:source_language) ? f.object.source_language : 'de'
%>

<!-- Basic Fields -->
<div class="field-unit">
  <%= f.label :training_example_id %>
  <%# v0.9 Phase D: sequence_number und training_concept (singular) sind weg.
      Label zeigt erstes M2M-Concept und Example-ID. %>
  <%= f.collection_select :training_example_id,
      TrainingExample.includes(:training_concepts).order(:id),
      :id,
      ->(te) { "#{te.training_concepts.first&.title || '—'} · ##{te.id} #{te.title}" },
      { include_blank: false },
      class: "field-unit__field" %>
</div>

<div class="field-unit">
  <%= f.label :shot_type %>
  <%= f.select :shot_type, 
      [['Ideal', 'ideal'], ['Alternative', 'alternative'], ['Fehler', 'error']], 
      { include_blank: false },
      class: "field-unit__field" %>
</div>

<div class="field-unit">
  <%= f.label :sequence_number %>
  <%= f.number_field :sequence_number, class: "field-unit__field" %>
</div>

<!-- Shot Image -->
<div class="field-unit">
  <%= f.label :shot_image, "Shot Image (Trajectories + EndPosition)" %>
  <%= f.file_field :shot_image, class: "field-unit__field" %>
  
  <% if f.object.shot_image.attached? %>
    <div style="margin-top: 10px;">
      <strong>Aktuelles Image:</strong>
      <%= image_tag f.object.shot_image, style: "max-width: 400px; border: 1px solid #ddd; padding: 5px;" %>
    </div>
  <% end %>
</div>

<!-- Multilingual Text Fields -->
<%= render partial: 'admin/application/multilingual_text_fields', locals: { 
  form: f, 
  field_name: 'title', 
  label: 'Title',
  source_language: source_language,
  field_type: 'text_field'
} %>

<%= render partial: 'admin/application/multilingual_text_fields', locals: { 
  form: f, 
  field_name: 'notes', 
  label: 'Notes',
  source_language: source_language,
  field_type: 'text_area',
  rows: 3
} %>

<%= render partial: 'admin/application/multilingual_text_fields', locals: { 
  form: f, 
  field_name: 'end_position_description', 
  label: 'EndPosition Description',
  source_language: source_language,
  field_type: 'text_area',
  rows: 4
} %>

<%= render partial: 'admin/application/multilingual_text_fields', locals: { 
  form: f, 
  field_name: 'shot_description', 
  label: 'Shot Description',
  source_language: source_language,
  field_type: 'text_area',
  rows: 5
} %>

<!-- Structured Data Fields -->
<div class="field-unit">
  <%= f.label :end_ball_configuration_id, "EndPosition (BallConfiguration)" %>
  <%= f.collection_select :end_ball_configuration_id,
      BallConfiguration.order(:table_variant, :gather_state, :id),
      :id,
      ->(bc) { "##{bc.id} · #{bc.table_variant}/#{bc.gather_state}" },
      { include_blank: "— keine strukturierte End-Position —" },
      class: "field-unit__field" %>
  <p class="field-unit__hint">
    Endposition als typisierte BallConfiguration (normalisierte b1/b2/b3 + table_variant + gather_state).
    Leer lassen, wenn der Stoß keine strukturierte Endposition liefert (z. B. reiner Fehlerfall, der nur textlich beschrieben wird).
  </p>
</div>

<div class="field-unit">
  <%= f.label :shot_parameters, "Shot Parameters (JSON)" %>
  <%= f.text_area :shot_parameters,
      value: f.object.shot_parameters.present? ? JSON.pretty_generate(f.object.shot_parameters) : '',
      class: "field-unit__field",
      rows: 6,
      style: "font-family: monospace;" %>
  <p class="field-unit__hint">
    JSON-Daten für Stoß-Parameter:<br>
    <code>{"ball_contact": "Halb-voll", "effect": 3, "cue_angle": 45, "energy": 0.7}</code>
  </p>
</div>

<!-- Translation Toggle -->
<div class="field-unit" style="background: #f8f9fa; padding: 15px; border-radius: 6px; border-left: 4px solid #3498db;">
  <div style="display: flex; align-items: center; gap: 20px;">
    <%= check_box_tag :translate_after_save, '1', false, 
        id: 'translate_after_save',
        style: "width: auto; margin: 0;" %>
    <%= label_tag :translate_after_save, "Nach dem Speichern übersetzen", 
        style: "margin: 0; font-weight: bold;" %>
  </div>
  
  <div style="margin-top: 10px;">
    <label style="margin-right: 15px;">
      <%= radio_button_tag :translation_method, 'deepl', true, style: "width: auto; margin: 0 5px 0 0;" %>
      DeepL (mit Glossar)
    </label>
    <label>
      <%= radio_button_tag :translation_method, 'ai', false, style: "width: auto; margin: 0 5px 0 0;" %>
      AI (Claude/GPT mit Billard-Kontext)
    </label>
  </div>
  
  <p style="margin: 10px 0 0 0; color: #7f8c8d; font-size: 0.9em;">
    ℹ️ Übersetzt automatisch alle Felder in die Zielsprachen (DE/EN).
  </p>
</div>
