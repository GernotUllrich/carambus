<% content_for(:title) do %>
  Carambol-Übersetzungen
<% end %>

<header class="main-content__header">
  <h1 class="main-content__page-title">
    <i class="fas fa-language"></i>
    Carambol-Übersetzungen
  </h1>
  <div class="header__subtitle text-gray-500 dark:text-gray-400 text-sm mt-2">
    Ad-hoc Übersetzungen mit Billard-spezifischem Glossar
  </div>
</header>

<section class="main-content__body">
  <%= form_with url: admin_translations_path, method: :get, class: "translation-form" do |f| %>

    <!-- Language Selection -->
    <div class="field-group mb-8 p-6 rounded-lg border border-gray-300 dark:border-gray-700 bg-gray-50 dark:bg-gray-800">
      <h3 class="mt-0 mb-5 text-[1.1rem] text-gray-800 dark:text-gray-100"><i class="fas fa-globe text-gray-500 dark:text-gray-400 mr-2"></i> Sprachauswahl</h3>

      <div class="language-selector flex flex-col md:flex-row md:items-center gap-4 md:gap-8">
        <div class="field-unit flex-1">
          <div class="field-unit__label">
            <%= label_tag "source_lang", "Quellsprache" %>
          </div>
          <div class="field-unit__field">
            <%= select_tag "source_lang",
                          options_for_select([
                            ['Niederländisch', 'nl'],
                            ['Französisch', 'fr'],
                            ['Englisch', 'en'],
                            ['Deutsch', 'de']
                          ], @source_lang),
                          class: "language-select w-full text-[1.1rem] p-3 rounded border border-gray-300 dark:border-gray-700 bg-white dark:bg-gray-900 text-gray-800 dark:text-gray-100 focus:border-info-500 focus:outline-none" %>
          </div>
        </div>

        <div class="arrow-icon text-[1.5rem] text-gray-400 shrink-0 rotate-90 md:rotate-0">
          <i class="fas fa-arrow-right"></i>
        </div>

        <div class="field-unit flex-1">
          <div class="field-unit__label">
            <%= label_tag "target_lang", "Zielsprache" %>
          </div>
          <div class="field-unit__field">
            <%= select_tag "target_lang",
                          options_for_select([
                            ['Deutsch', 'de'],
                            ['Englisch', 'en']
                          ], @target_lang),
                          class: "language-select w-full text-[1.1rem] p-3 rounded border border-gray-300 dark:border-gray-700 bg-white dark:bg-gray-900 text-gray-800 dark:text-gray-100 focus:border-info-500 focus:outline-none" %>
          </div>
        </div>
      </div>
    </div>

    <!-- Translation Method -->
    <div class="field-group mb-8 p-6 rounded-lg border border-gray-300 dark:border-gray-700 bg-gray-50 dark:bg-gray-800">
      <h3 class="mt-0 mb-5 text-[1.1rem] text-gray-800 dark:text-gray-100"><i class="fas fa-cog text-gray-500 dark:text-gray-400 mr-2"></i> Übersetzungsmethode</h3>

      <div class="method-selector flex flex-col md:flex-row gap-4">
        <label class="method-option flex-1 flex items-start gap-3 p-4 rounded-lg border-2 cursor-pointer hover:border-gray-400 <%= @translation_method == 'deepl' ? 'border-info-500 bg-info-50 dark:bg-info-900/30' : 'border-gray-300 dark:border-gray-700 bg-white dark:bg-gray-900 hover:bg-gray-100 dark:hover:bg-gray-800' %>">
          <%= radio_button_tag "translation_method", "deepl", @translation_method == 'deepl', class: "mt-1" %>
          <span class="method-label flex flex-col gap-1">
            <strong class="text-gray-800 dark:text-gray-100">DeepL API</strong>
            <small class="text-gray-500 dark:text-gray-400 text-[0.85rem]">Standard - Mit Billard-Glossar</small>
          </span>
        </label>

        <label class="method-option flex-1 flex items-start gap-3 p-4 rounded-lg border-2 cursor-pointer hover:border-gray-400 <%= @translation_method == 'anthropic' ? 'border-info-500 bg-info-50 dark:bg-info-900/30' : 'border-gray-300 dark:border-gray-700 bg-white dark:bg-gray-900 hover:bg-gray-100 dark:hover:bg-gray-800' %>">
          <%= radio_button_tag "translation_method", "anthropic", @translation_method == 'anthropic', class: "mt-1" %>
          <span class="method-label flex flex-col gap-1">
            <strong class="text-gray-800 dark:text-gray-100">Claude (Anthropic)</strong>
            <small class="text-gray-500 dark:text-gray-400 text-[0.85rem]">KI-basiert - Sehr präzise</small>
          </span>
        </label>
      </div>
    </div>

    <!-- Source Text Input -->
    <div class="field-group mb-8 p-6 rounded-lg border border-gray-300 dark:border-gray-700 bg-gray-50 dark:bg-gray-800">
      <h3 class="mt-0 mb-5 text-[1.1rem] text-gray-800 dark:text-gray-100"><i class="fas fa-file-import text-gray-500 dark:text-gray-400 mr-2"></i> Originaltext</h3>

      <div class="field-unit">
        <div class="field-unit__field">
          <%= text_area_tag "source_text",
                           @source_text,
                           class: "text-area w-full p-4 rounded-md border border-gray-300 dark:border-gray-700 bg-white dark:bg-gray-900 text-gray-800 dark:text-gray-100 resize-y focus:border-info-500 focus:outline-none focus:ring-2 focus:ring-info-500/20",
                           rows: 10,
                           placeholder: "Text hier einfügen..." %>
        </div>
      </div>

      <div class="form-actions flex gap-3 mt-4">
        <%= submit_tag "Übersetzen", class: "inline-block px-6 py-3 rounded-md font-medium text-white border-0 cursor-pointer bg-info-600 hover:bg-info-700", data: { disable_with: "Übersetze..." } %>
        <% if @source_text.present? %>
          <%= link_to "Zurücksetzen", admin_translations_path, class: "inline-block px-6 py-3 rounded-md font-medium text-white no-underline bg-gray-500 hover:bg-gray-600" %>
        <% end %>
      </div>
    </div>

    <!-- Translation Result -->
    <% if @translated_text.present? || @error.present? %>
      <div class="field-group result-group mb-8 p-6 rounded-lg border bg-info-50 dark:bg-info-900/20 border-info-500">
        <h3 class="mt-0 mb-5 text-[1.1rem] text-gray-800 dark:text-gray-100">
          <i class="fas <%= @error.present? ? 'fa-exclamation-triangle' : 'fa-file-export' %> text-gray-500 dark:text-gray-400 mr-2"></i>
          <%= @error.present? ? 'Fehler' : 'Übersetzung' %>
        </h3>

        <% if @error.present? %>
          <div class="error-message bg-warning-50 dark:bg-warning-900/30 border border-warning-400 text-warning-800 dark:text-warning-200 p-4 rounded-md">
            <%= @error %>
          </div>
        <% else %>
          <div class="field-unit">
            <div class="field-unit__field result-field relative">
              <div class="text-result bg-white dark:bg-gray-900 text-gray-800 dark:text-gray-100 p-6 rounded-md min-h-[100px] whitespace-pre-wrap break-words leading-relaxed border border-gray-300 dark:border-gray-700" id="translatedText">
                <%= simple_format(@translated_text, {}, sanitize: false) %>
              </div>
              <button type="button" class="copy-button mt-4 inline-flex items-center gap-2 px-6 py-3 rounded-md text-white border-0 cursor-pointer bg-info-600 hover:bg-info-700" onclick="copyTranslation()">
                <i class="fas fa-copy"></i>
                <span>In Zwischenablage kopieren</span>
              </button>
            </div>
          </div>

          <div class="translation-info mt-4 pt-4 border-t border-gray-300 dark:border-gray-700">
            <small class="text-gray-500 dark:text-gray-400">
              <i class="fas fa-info-circle mr-2"></i>
              Übersetzt von <strong><%= @source_lang.upcase %></strong> nach <strong><%= @target_lang.upcase %></strong>
              mit <strong><%=
                case @translation_method
                when 'deepl' then 'DeepL API'
                when 'anthropic' then 'Claude (Anthropic)'
                else @translation_method
                end
              %></strong>
            </small>
          </div>
        <% end %>
      </div>
    <% end %>

  <% end %>
</section>

<script>
function copyTranslation() {
  const textElement = document.getElementById('translatedText');
  const text = textElement.innerText;

  // Try modern Clipboard API first, fallback to old method
  if (navigator.clipboard && navigator.clipboard.writeText) {
    navigator.clipboard.writeText(text).then(() => {
      showCopySuccess();
    }).catch(err => {
      fallbackCopy(text);
    });
  } else {
    fallbackCopy(text);
  }
}

function fallbackCopy(text) {
  // Create temporary textarea
  const textarea = document.createElement('textarea');
  textarea.value = text;
  textarea.style.position = 'fixed';
  textarea.style.opacity = '0';
  document.body.appendChild(textarea);
  textarea.select();

  try {
    const successful = document.execCommand('copy');
    document.body.removeChild(textarea);

    if (successful) {
      showCopySuccess();
    } else {
      alert('Fehler beim Kopieren. Bitte manuell markieren und kopieren.');
    }
  } catch (err) {
    document.body.removeChild(textarea);
    alert('Fehler beim Kopieren: ' + err);
  }
}

function showCopySuccess() {
  const button = document.querySelector('.copy-button');
  const originalContent = button.innerHTML;
  button.innerHTML = '<i class="fas fa-check"></i> <span>Kopiert!</span>';
  button.classList.remove('bg-info-600', 'hover:bg-info-700');
  button.classList.add('bg-success-600');

  setTimeout(() => {
    button.innerHTML = originalContent;
    button.classList.remove('bg-success-600');
    button.classList.add('bg-info-600', 'hover:bg-info-700');
  }, 2000);
}
</script>
