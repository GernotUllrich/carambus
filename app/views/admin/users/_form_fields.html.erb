<% if current_user&.system_admin? %>
  <div class="field-unit">
    <div class="field-unit__label">
      <%= form.label :role %>
    </div>
    <div class="field-unit__field">
      <%= form.select :role, User.roles.keys %>
    </div>
  </div>
<% end %>

<div class="field-unit">
  <div class="field-unit__label">
    <%= form.label :name %>
  </div>
  <div class="field-unit__field">
    <%= text_field_tag :name_display, page.resource.name, class: "text-input", disabled: true, autocomplete: "off" %>
  </div>
</div>

<div class="field-unit">
  <div class="field-unit__label">
    <%= form.label :first_name %>
  </div>
  <div class="field-unit__field">
    <%= form.text_field :first_name %>
  </div>
</div>

<div class="field-unit">
  <div class="field-unit__label">
    <%= form.label :last_name %>
  </div>
  <div class="field-unit__field">
    <%= form.text_field :last_name %>
  </div>
</div>

<% if current_user&.system_admin? %>
  <%#
    D-38: Sportwart-Persona ist EXPLIZIT (Spalte persona_grants, nur system_admin). sportwart? folgt
    NICHT mehr aus Disziplin-/Location-Joins — die verfeinern nur den Wirkbereich. Daraus folgt
    cc_write_access?. persona_grants wird als jsonb-Array permittet (UserDashboard#permitted_attributes).
  %>
  <div class="field-unit">
    <div class="field-unit__label">
      <%= form.label :persona_grants, "Sportwart-Persona" %>
      <p class="field-unit__help" style="font-size: 0.85em; color: #666;">
        Macht den Nutzer zum <strong>Sportwart</strong> (CC-Schreibrecht im Chat).
        <strong>Landessportwart</strong> = region-weit (ALLE Spielorte); <strong>Sportwart</strong> = nur die unten gewählten Spielorte.
        Ohne Persona: read-only (Disziplinen/Spielorte allein genügen nicht).
      </p>
    </div>
    <div class="field-unit__field">
      <%# leeres Fallback: alle Personas abwählen leert die Liste %>
      <input type="hidden" name="user[persona_grants][]" value="">
      <% User::PERSONA_GRANTS.each do |pg| %>
        <label style="display:block; margin:3px 0;">
          <%= check_box_tag "user[persona_grants][]", pg, Array(page.resource.persona_grants).include?(pg) %>
          <%= pg == "landessportwart" ? "Landessportwart (region-weit, alle Spielorte)" : "Sportwart (standortgebunden)" %>
        </label>
      <% end %>
    </div>
  </div>

  <%# Disziplinen + Spielorte VERFEINERN den Wirkbereich (greifen nur bei gesetzter Persona). %>
  <div class="field-unit">
    <div class="field-unit__label">
      <%= form.label :sportwart_disciplines, "Sportwart-Disziplinen" %>
      <p class="field-unit__help" style="font-size: 0.85em; color: #666;">
        Schränkt den Wirkbereich auf diese Disziplinen ein (leer = alle Disziplinen).
        Eine Oberdisziplin (z.B. <em>Karambol</em>) deckt automatisch alle Unterdisziplinen ab — zum Aufklappen auf das ▶ klicken.
      </p>
    </div>
    <div class="field-unit__field">
      <ul style="margin: 0; padding: 0;">
        <% discipline_tree_roots.each do |root| %>
          <%= render "admin/users/discipline_node", discipline: root, selected_ids: page.resource.sportwart_discipline_ids %>
        <% end %>
      </ul>
    </div>
  </div>

  <div class="field-unit">
    <div class="field-unit__label">
      <%= form.label :sportwart_locations, "Sportwart-Spielorte" %>
      <p class="field-unit__help" style="font-size: 0.85em; color: #666;">
        <% if server_region %>
          Nur Spielorte der Region <strong><%= server_region.shortname %></strong>, gruppiert nach Verein.
        <% else %>
          Kein fester Region-Kontext auf diesem Server — erst Region wählen, dann Spielorte (gruppiert nach Verein).
        <% end %>
        Klick auf einen Spielort fügt ihn oben hinzu; am Chip auf „×" entfernt ihn wieder.
      </p>
    </div>
    <% selected_locs = page.resource.sportwart_locations.to_a %>
    <% selected_location_ids = selected_locs.map(&:id) %>
    <% grouped = region_locations_grouped_options %>
    <div class="field-unit__field" data-controller="location-picker"
         data-location-picker-locations-url-value="<%= locations_by_region_admin_users_path %>">
      <%# Kontrast erzwingen: globale .btn-*-Regeln setzen color:white !important auf Buttons —
          unsere Picker-Buttons in allen Zustaenden auf lesbares Dunkel ueberschreiben. %>
      <style>
        [data-controller="location-picker"] .lp-available-item {
          color: #1f2937 !important; -webkit-text-fill-color: #1f2937 !important;
          background-color: transparent !important;
        }
        [data-controller="location-picker"] .lp-available-item:hover {
          background-color: #dbeafe !important;
          color: #1e3a8a !important; -webkit-text-fill-color: #1e3a8a !important;
        }
        [data-controller="location-picker"] .lp-chip,
        [data-controller="location-picker"] .lp-chip button {
          color: #1e3a8a !important; -webkit-text-fill-color: #1e3a8a !important;
        }
      </style>
      <%# leeres Fallback-Input: damit "alle Chips entfernt" die Zuordnung wirklich leert %>
      <input type="hidden" name="user[sportwart_location_ids][]" value="">

      <%# Ausgewählt-Block (Chips, entfernbar) %>
      <div data-location-picker-target="selected"
           style="min-height: 38px; padding: 4px; border: 1px solid #d1d5db; border-radius: 6px; margin-bottom: 8px; background: #fff;">
        <% selected_locs.each do |loc| %>
          <span class="lp-chip" data-chip-id="<%= loc.id %>" style="display:inline-flex;align-items:center;gap:4px;padding:3px 8px;margin:2px;border:1px solid #2563eb;border-radius:12px;background:#eff6ff;font-size:0.9em;">
            <input type="hidden" name="user[sportwart_location_ids][]" value="<%= loc.id %>">
            <span><%= loc.name %></span>
            <button type="button" data-action="location-picker#remove" style="border:0;background:transparent;cursor:pointer;color:#2563eb;font-weight:bold;line-height:1;">&times;</button>
          </span>
        <% end %>
        <span data-location-picker-target="empty" <%= "hidden" if selected_locs.any? %>
              style="color:#9ca3af;font-size:0.9em;padding:4px;">Keine Spielorte gewählt</span>
      </div>

      <%# Server OHNE festen Region-Context: Region wählen → Verfügbar-Liste wird per JSON geladen. %>
      <% unless server_region %>
        <%= select_tag :sportwart_region_picker,
              options_for_select(region_picker_options),
              include_blank: "— Region wählen —",
              class: "text-input",
              style: "margin-bottom: 8px; width: 100%;",
              data: { location_picker_target: "region", action: "location-picker#loadRegion" } %>
      <% end %>

      <%# Verfügbar-Liste, nach Verein gruppiert — Klick fügt hinzu %>
      <div data-location-picker-target="availableList"
           style="max-height: 220px; overflow-y: auto; border: 1px solid #e5e7eb; border-radius: 6px; padding: 4px; background: #fafafa;">
        <% grouped.each do |club_name, locs| %>
          <div data-location-picker-target="group" <%= "hidden" if locs.all? { |_n, id| selected_location_ids.include?(id) } %>
               style="margin-bottom: 6px;">
            <div style="font-weight: 600; font-size: 0.8em; color: #6b7280; padding: 2px 4px;"><%= club_name %></div>
            <% locs.each do |loc_name, loc_id| %>
              <button type="button" class="lp-available-item"
                      data-location-picker-target="available"
                      data-id="<%= loc_id %>" data-name="<%= loc_name %>"
                      data-action="location-picker#add"
                      <%= "hidden" if selected_location_ids.include?(loc_id) %>
                      style="display:block;width:100%;text-align:left;border:0;background:transparent;cursor:pointer;padding:3px 8px;border-radius:4px;font-size:0.9em;">
                + <%= loc_name %>
              </button>
            <% end %>
          </div>
        <% end %>
      </div>
    </div>
  </div>

  <% current_player = page.resource.player %>
  <% selected_club = current_player && (
       SeasonParticipation.where(player_id: current_player.id, season_id: Season.current_season&.id).first&.club ||
       (current_player.respond_to?(:club) ? current_player.club : nil)
     ) %>
  <% if server_region %>
    <div class="field-unit" data-controller="dependent-select"
         data-dependent-select-url-value="<%= players_by_club_admin_users_path %>">
      <div class="field-unit__label">
        <%= form.label :player_id, "Verknüpfter Spieler" %>
        <p class="field-unit__help" style="font-size: 0.85em; color: #666;">
          Für „Mein Billard": erst Verein der Region wählen, dann Spieler (aktuelle Saison).
          Alternativ verknüpft sich der Nutzer im Chat selbst (cc_link_my_player).
        </p>
      </div>
      <div class="field-unit__field" style="display: flex; gap: 8px; flex-wrap: wrap;">
        <%= select_tag :player_club_picker,
              options_from_collection_for_select(region_clubs, :id, :name, selected_club&.id),
              include_blank: "— Verein wählen —",
              class: "text-input",
              data: { dependent_select_target: "source", action: "dependent-select#load" } %>
        <%= select_tag "user[player_id]",
              options_for_select(
                current_player ? [[current_player.fullname, current_player.id]] : [],
                page.resource.player_id
              ),
              include_blank: "— Spieler wählen —",
              class: "text-input",
              data: { dependent_select_target: "dest" } %>
      </div>
    </div>
  <% else %>
    <% selected_region = selected_club&.region %>
    <div class="field-unit" data-controller="region-player-picker"
         data-region-player-picker-clubs-url-value="<%= clubs_by_region_admin_users_path %>"
         data-region-player-picker-players-url-value="<%= players_by_club_admin_users_path %>">
      <div class="field-unit__label">
        <%= form.label :player_id, "Verknüpfter Spieler" %>
        <p class="field-unit__help" style="font-size: 0.85em; color: #666;">
          Kein fester Region-Kontext auf diesem Server — erst Region, dann Verein, dann Spieler (aktuelle Saison).
          Alternativ verknüpft sich der Nutzer im Chat selbst (cc_link_my_player).
        </p>
      </div>
      <div class="field-unit__field" style="display: flex; gap: 8px; flex-wrap: wrap;">
        <%= select_tag :player_region_picker,
              options_for_select(region_picker_options, selected_region&.id),
              include_blank: "— Region wählen —",
              class: "text-input",
              data: { region_player_picker_target: "region", action: "region-player-picker#loadClubs" } %>
        <%= select_tag :player_club_picker,
              options_for_select(
                selected_club ? [[selected_club.name, selected_club.id]] : [],
                selected_club&.id
              ),
              include_blank: "— Verein wählen —",
              class: "text-input",
              data: { region_player_picker_target: "club", action: "region-player-picker#loadPlayers" } %>
        <%= select_tag "user[player_id]",
              options_for_select(
                current_player ? [[current_player.fullname, current_player.id]] : [],
                page.resource.player_id
              ),
              include_blank: "— Spieler wählen —",
              class: "text-input",
              data: { region_player_picker_target: "player" } %>
      </div>
    </div>
  <% end %>
<% end %>
