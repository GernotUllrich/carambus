<div class="source-attributions-section bg-gray-50 dark:bg-gray-800 p-5 rounded-lg mt-8 border-2 border-gray-300 dark:border-gray-700">
  <h3 class="text-gray-800 dark:text-gray-100 m-0 mb-4 pb-2 border-b-2 border-gray-400 dark:border-gray-600">
    📚 Quellenangaben
  </h3>

  <% if resource.training_sources.any? %>
    <div class="existing-sources mb-5">
      <p class="font-bold text-gray-600 dark:text-gray-300">Zugeordnete Quellen:</p>
      <% resource.source_attributions.each do |attribution| %>
        <div class="bg-white dark:bg-gray-900 p-3 rounded-md mb-2.5 border-l-4 border-success-500">
          <div class="flex justify-between items-start">
            <div>
              <strong class="text-gray-800 dark:text-gray-100"><%= attribution.training_source.display_name %></strong>
              <% if attribution.reference.present? %>
                <br>
                <span class="text-gray-500 dark:text-gray-400 text-[0.9em]">
                  📍 <%= attribution.reference %>
                </span>
              <% end %>
              <% if attribution.notes.present? %>
                <br>
                <span class="text-gray-500 dark:text-gray-400 text-[0.85em] italic">
                  <%= truncate(attribution.notes, length: 100) %>
                </span>
              <% end %>
            </div>
            <%= link_to "🗑️",
                        [:admin, attribution],
                        method: :delete,
                        data: { confirm: "Quellenangabe wirklich entfernen?" },
                        class: "!text-danger-600 no-underline text-[1.2em]" if false %>
          </div>
        </div>
      <% end %>
    </div>
  <% else %>
    <p class="text-gray-500 dark:text-gray-400 italic mb-4">
      Noch keine Quellen zugeordnet.
    </p>
  <% end %>

  <div class="add-source-form bg-white dark:bg-gray-900 p-4 rounded-md border border-dashed border-gray-400 dark:border-gray-600">
    <p class="font-bold text-gray-600 dark:text-gray-300 m-0 mb-2.5">Neue Quelle hinzufügen:</p>

    <%= form.fields_for :source_attributions, resource.source_attributions.build do |sa_form| %>
      <div class="grid grid-cols-[2fr_1fr] gap-2.5 mb-2.5">
        <div>
          <%= sa_form.label :training_source_id, "Quelle auswählen", class: "block text-[0.9em] text-gray-600 dark:text-gray-300 mb-1" %>
          <%= sa_form.collection_select :training_source_id,
                                        TrainingSource.order(:title),
                                        :id,
                                        :display_name,
                                        { include_blank: "-- Quelle auswählen --" },
                                        { class: "w-full p-2 rounded border border-gray-300 dark:border-gray-700 bg-white dark:bg-gray-900 text-gray-800 dark:text-gray-100" } %>
        </div>

        <div>
          <%= sa_form.label :reference, "Referenz (z.B. S. 23-25)", class: "block text-[0.9em] text-gray-600 dark:text-gray-300 mb-1" %>
          <%= sa_form.text_field :reference,
                                 placeholder: "z.B. Seiten 23-25",
                                 class: "w-full p-2 rounded border border-gray-300 dark:border-gray-700 bg-white dark:bg-gray-900 text-gray-800 dark:text-gray-100" %>
        </div>
      </div>

      <div class="mb-2.5">
        <%= sa_form.label :notes, "Notizen (optional)", class: "block text-[0.9em] text-gray-600 dark:text-gray-300 mb-1" %>
        <%= sa_form.text_area :notes,
                              rows: 2,
                              placeholder: "Zusätzliche Notizen zur Quelle...",
                              class: "w-full p-2 rounded border border-gray-300 dark:border-gray-700 bg-white dark:bg-gray-900 text-gray-800 dark:text-gray-100 text-[0.9em]" %>
      </div>
    <% end %>

    <p class="field-hint text-gray-500 dark:text-gray-400 text-[0.85em] mt-2.5">
      💡 Tipp: Legen Sie zuerst eine neue Quelle unter <a href="/admin/training_sources/new" target="_blank" class="text-info-600 dark:text-info-400">Training Sources</a> an, falls diese noch nicht existiert.
    </p>
  </div>
</div>
