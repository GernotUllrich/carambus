<% if resource.persisted? && resource.translations.present? %>
  <div class="translations-display bg-success-50 dark:bg-success-900/20 p-5 rounded-lg my-6">
    <h3 class="text-gray-800 dark:text-gray-100 mt-5 mb-4 pb-1 border-b-2 border-success-500">
      🌐 Automatische Übersetzungen
    </h3>

    <% Translatable::TARGET_LANGUAGES.each do |lang| %>
      <% next if lang == resource.source_language %>
      <% if resource.translations[lang].present? %>
        <div class="translation-block bg-white dark:bg-gray-900 p-4 rounded-md mb-4 border-l-4 border-success-500">
          <h4 class="text-success-700 dark:text-success-400 mb-2.5">
            <%= {'de' => '🇩🇪 Deutsch', 'en' => '🇬🇧 English', 'nl' => '🇳🇱 Nederlands', 'fr' => '🇫🇷 Français'}[lang] %>
            <span class="text-[0.8em] text-gray-500 dark:text-gray-400">
              (Übersetzt am <%= Time.parse(resource.translations[lang]['translated_at']).strftime('%d.%m.%Y %H:%M') %>)
            </span>
          </h4>

          <div class="translation-content text-[0.95em] leading-relaxed">
            <% resource.translatable_fields.each do |field| %>
              <% if resource.translations[lang][field.to_s].present? %>
                <p class="my-2.5">
                  <strong><%= field.to_s.humanize %>:</strong><br>
                  <%= simple_format(resource.translations[lang][field.to_s]) %>
                </p>
              <% end %>
            <% end %>
          </div>
        </div>
      <% end %>
    <% end %>

    <p class="field-hint text-gray-500 dark:text-gray-400 mt-4">
      💡 Um neu zu übersetzen, klicke nach dem Speichern auf "Translate" (falls verfügbar) oder speichere erneut.
    </p>
  </div>
<% end %>
