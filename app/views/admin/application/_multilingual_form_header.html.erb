<div class="language-selector-banner bg-gradient-to-br from-indigo-500 to-purple-800 text-white p-5 rounded-lg mb-6 shadow">
  <div class="field-unit field-unit--source-language">
    <%= form.label :source_language, "🌍 Eingabesprache", class: "field-unit__label text-white font-bold text-[1.1em]" %>
    <div class="field-unit__field">
      <%= form.select :source_language,
                     [['🇩🇪 Deutsch', 'de'], ['🇬🇧 English', 'en'], ['🇳🇱 Nederlands', 'nl'], ['🇫🇷 Français', 'fr']],
                     {},
                     class: "field-unit__select language-select text-[1.1em] p-2.5 rounded bg-white dark:bg-gray-900 text-gray-800 dark:text-gray-100 border-2 border-purple-700" %>
      <p class="field-hint text-gray-100 mt-2">
        Wählen Sie die Sprache, in der Sie die Texte eingeben. Nach dem Speichern wird automatisch in DE und EN übersetzt.
      </p>
    </div>
  </div>
</div>
