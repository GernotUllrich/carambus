<style>
    th, td {
        padding: 3px;
    }
</style>
<div style="clear:both;">
  <%= render :partial => "show", locals: {tournament: @tournament, subtitle: "", show_edit_back: true} %>
</div>
<div style="float:left;">
  <%= button_to "Order By Ranking", order_by_ranking_tournament_path(@tournament), method: :post, class: "btn btn-flat btn-primary", style: "float: left; margin-right: 10px;", disabled: !%w{new_tournament accreditation_finished}.include?(@tournament.state) %>

</div><span style="float:left;;margin-top:10px">--->&nbsp;</span>
<div style="float:left;">
  <%= button_to "Finalize Tournament Modus", finalize_modus_tournament_path(@tournament), method: :get, class: "btn btn-flat btn-primary", style: "float: left; margin-right: 10px;", disabled: !%w{accreditation_finished tournament_seeding_finished}.include?(@tournament.state) %>

</div>
</div><span style="float:left;;margin-top:10px">--->&nbsp;</span>
<div >
  <%= button_to "Mangage Tournament Group Phase", tournament_monitor_tournament_path(@tournament), method: :get, class: "btn btn-flat btn-primary", disabled: %w{new_tournament accreditation_finished tournament_seeding_finished finals_finished results_published closed}.include?(@tournament.state) %>
</div>
<h2>Registrations</h2>
<table>
  <thead>
  <tr>
    <th>Position</th>
    <th colspan=2>Reorder</th>
    <th>Name</th>
    <th>Club</th>
    <th><%= "Rank<br/>#{@tournament.discipline.name}<br/>Season #{@tournament.season.previous.name}".html_safe %></th>
    <% if @tournament.handicap_tournier? %>
      <th>Balls Goal</th>
      <th>Discipline</th>
    <% end %>
  </tr>
  <tbody>
  <% @tournament.seedings.joins(:player).order(@tournament.tournament_seeding_finished? ? "seedings.position" : "players.lastname asc, players.firstname asc").each do |seeding| %>
    <% club = @tournament.season.season_participations.where("season_participations.player_id = ?", seeding.player.id).first.club %>
    <tr>
      <td><%= seeding.position %></td>
      <td><%= link_to image_tag("up-icon.png"), up_seeding_path(seeding), method: :post %></td>
      <td><%= link_to image_tag("down-icon.png"), down_seeding_path(seeding), method: :post %></td>
      <td><%= link_to("#{seeding.player.lastname}, #{seeding.player.firstname}", player_path(seeding.player)) %></td>
      <td><%= link_to("#{club.shortname}", club_path(club)) %></td>
      <td><%= seeding.player.player_rankings.where(discipline_id: Discipline.find_by_name("Freie Partie klein"), season_id: Season.find_by_ba_id(Season.current_season.ba_id - 1)).first.andand.rank.presence || 999 %></td>
      <% if @tournament.handicap_tournier? %>
        <td><%= seeding.balls_goal %></td>
        <td><%= seeding.playing_discipline.andand.shortname %></td>
      <% end %>
    </tr>
  <% end %>
  </tbody>
</table>
<h2>Rankings</h2>
<% lists = @tournament.seedings.joins(:player).order("players.lastname, players.firstname").map { |s| s.data["result"].keys rescue [] }.inject([]) { |a, memo| memo |= a; memo } %>
<% lists.each do |list| %>
  <h3><%= list %></h3>
  <table>
    <thead>
    <tr>
      <% @tournament.seedings.select { |seeding| seeding.data["result"].andand[list].present? }.first.data["result"][list].keys.each do |k| %>
        <% next if k == "Rank" %>
        <th><%= k %></th>
      <% end %>
    </tr>
    </thead>
    <tbody>
    <% @tournament.seedings.select { |seeding| seeding.data["result"].andand[list].present? }.sort_by { |seeding| seeding.data["result"][list]["#"].to_i }.each do |seeding| %>
      <tr>
        <% seeding.data["result"][list].each do |k, v| %>
          <% next if k == "Rank" %>
          <td><%= v %></td>
        <% end %>
      </tr>
    <% end %>
    </tbody>
  </table>
<% end %>

<h2>Games</h2>
<% if @tournament.games.present? %>
  <table>
    <thead>
    <tr>
      <% @tournament.games.first.data.keys.each do |k| %>
        <th><%= k %></th>
      <% end %>
    </tr>
    </thead>
    <tbody>
    <% @tournament.games.each do |game| %>
      <tr>
        <% skip = false %>
        <% game.data.each do |k, v| %>
          <% skip = true if %w{Heim Gast}.include?(k) && v.blank? %>
          <% unless skip %>
            <td><%= v %></td>
          <% end %>
        <% end %>
      </tr>
    <% end %>
    </tbody>
  </table>
<% end %>
<% games = @tournament.games.order(seqno: :asc) %>
<% if !@tournament.tournament_started %>
  <%= button_to "Reset Tournament Monitor", reset_tournament_path(@tournament), method: :post, class: "btn btn-flat btn-primary", data: {confirm: 'Are you sure?'}, style: "float: left; margin-right: 10px;" %>
<% end %>
<% if current_user.email.downcase == "gernot.ullrich@gmx.de" %>
  <%= button_to "Debugging: Force Reset Tournament Monitor", reset_tournament_path(@tournament, force_reset: true), method: :post, class: "btn btn-flat btn-primary", style: "float: left; margin-right: 10px;" %>
<% end %>
