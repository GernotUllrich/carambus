<%#
  Partial für einzelne Wizard-Schritte

  Parameter:
  - number: Schrittnummer (1-6)
  - title: Titel des Schritts
  - status: :completed, :active, :pending
  - action: Hash mit :text, :path, :method, :confirm, :class
  - info: Zusätzliche Info (optional)
  - warning: Boolean - zeigt Warnung (optional)
  - danger: Boolean - markiert als gefährliche Aktion (optional)
  - help: Hilfetext (optional)
  - docs_path: MkDocs-Pfad für Detaillink im Handbuch (optional, z.B. 'managers/tournament-management')
  - docs_anchor: Anker-ID für Deep-Link (optional, z.B. 'seeding-list')
%>
<%
  # Set defaults for optional parameters using local_assigns
  info = local_assigns.fetch(:info, nil)
  warning = local_assigns.fetch(:warning, false)
  danger = local_assigns.fetch(:danger, false)
  help = local_assigns.fetch(:help, nil)
  action = local_assigns.fetch(:action, nil)
  docs_path = local_assigns.fetch(:docs_path, nil)
  docs_anchor = local_assigns.fetch(:docs_anchor, nil)
%>

<div class="wizard-step <%= step_class(status) %> <%= 'wizard-step-danger' if danger %>">
  <div class="wizard-step-header">
    <div class="wizard-step-icon">
      <%= step_icon(status) %>
    </div>
    <div class="wizard-step-content">
      <div class="wizard-step-number-title">
        <h4 class="step-title"><%= title %></h4>
      </div>

      <% if info.present? %>
        <div class="step-info">
          <%= info %>
        </div>
      <% end %>

      <% if warning %>
        <div class="step-warning">
          <span class="warning-icon">⚠️</span>
          <%= warning.is_a?(String) ? warning : t('tournaments.wizard_step.pending_default') %>
        </div>
      <% end %>

      <% if help.present? %>
        <div class="step-help">
          <details<%= " open" if status == :active %>>
            <summary><%= t('tournaments.wizard_step.help_summary') %></summary>
            <p><%= help.html_safe %></p>
            <% if docs_path.present? %>
              <p class="step-docs-link mt-2">
                <%= mkdocs_link(docs_path, anchor: docs_anchor, text: t('tournaments.docs.walkthrough_link'), options: { class: 'text-blue-600 dark:text-blue-400 underline text-sm' }) %>
              </p>
            <% end %>
          </details>
        </div>
      <% end %>
    </div>
  </div>

  <div class="wizard-step-actions">
    <% if action && status == :active %>
      <%= button_to action[:text], action[:path],
          method: action[:method] || :get,
          class: "btn btn-primary #{action[:class]} #{status == :active ? 'btn-pulse' : ''}",
          data: { confirm: action[:confirm] } %>
    <% elsif action && status == :completed %>
      <%= button_to action[:text], action[:path],
          method: action[:method] || :get,
          class: "btn btn-secondary btn-sm #{action[:class]}" %>
    <% elsif status == :pending %>
      <span class="disabled-text">
        <%= t('tournaments.wizard_step.pending_hint') %>
      </span>
    <% end %>
  </div>
</div>
