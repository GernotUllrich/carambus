<div data-controller="tournament" class="container mx-auto my-8 px-4">
  <div class="max-w-3xl mx-auto">

    <!-- LINK-03: Detailanleitung im Handbuch -->
    <div class="bg-blue-50 dark:bg-blue-900/20 border border-blue-200 dark:border-blue-700 rounded-lg p-4 mb-6">
      <p class="text-sm text-blue-900 dark:text-blue-200">
        📖 <strong><%= t('tournaments.docs.form_help_prefix') %></strong>
        <%= mkdocs_link('managers/tournament-management', anchor: 'participants', text: t('tournaments.docs.form_help_link'), options: { class: 'underline font-medium' }) %>
      </p>
    </div>

    <div class="flex-col justify-between items-center mb-4">
      <%- if @tournament.team_size > 1 %>
        <h1 class="h3"><%= @tournament.title %> - <%= @tournament.season.name %>
          - <%= @tournament.organizer.shortname %>
          <br/><%= t('tournaments.define_participants.team_list_heading') %></h1>
        <table>
          <thead>
          <tr>
            <th><%= t('tournaments.define_participants.col_team') %></th>
            <th><%= t('tournaments.define_participants.col_participation') %></th>
            <th><%= t('tournaments.define_participants.col_points_or_ranking') %></th>
          </tr>
          </thead>
          <tbody>
          <%= custom_link_to t('tournaments.define_participants.back'), @tournament %>
          <%- @tournament.teams.each do |team| %>
            <%- seeding = @tournament.seedings.where(player_id: team.id).first %>
            <tr>
              <td><%= team.fullname %></td>
              <%= content_tag "td", class: "w-1/4", style: "text-align: center" do %>
                <%= check_box_tag "participate-#{team.id}", "1", seeding.present?, data: { reflex: "change->TournamentReflex#change_seeding", id: @tournament.id } %></td>
              <%- end %>
              <%= content_tag "td", id: "balls-wrapper-#{team.id}", class: "w-1/4", style: "text-align: right" do %>
                <%= number_field_tag("balls-#{team.id}", seeding.andand.balls_goal, data: { reflex: "change->TournamentReflex#change_point_goal", id: @tournament.id }, style: "#{seeding.present? ? "" : "display: none"}") %>
              <%- end %>
            </tr>
          <% end %>
          </tbody>
        </table>
        <%= custom_link_to t('tournaments.define_participants.new_team'), new_team_tournament_path %>
      <%- else %>
        <%- # Berechne Rankings basierend auf effective_gd (wie in rankings_controller.rb) %>
        <%- current_season = Season.current_season %>
        <%- seasons = Season.where('id <= ?', current_season.id).order(id: :desc).limit(3).reverse %>

        <%- # Lade alle Rankings für die Disziplin und Region %>
        <%- if @tournament.organizer.is_a?(Region) %>
          <%- all_rankings = PlayerRanking.joins(:player)
                                          .where(season_id: seasons.pluck(:id),
                                                 discipline_id: @tournament.discipline_id,
                                                 region_id: @tournament.organizer_id)
                                          .to_a %>
          <%- # Gruppiere nach Spieler %>
          <%- rankings_by_player = all_rankings.group_by(&:player_id) %>

          <%- # Berechne effective_gd für jeden Spieler (neueste Saison zuerst) %>
          <%- player_effective_gd = {} %>
          <%- rankings_by_player.each do |player_id, rankings| %>
            <%- gd_values = seasons.map do |season| %>
              <%- ranking = rankings.find { |r| r.season_id == season.id } %>
              <%- ranking&.gd %>
            <%- end %>
            <%- # effective_gd = aktuellste Saison || Saison davor || Saison davor-1 %>
            <%- effective_gd = gd_values[2] || gd_values[1] || gd_values[0] %>
            <%- player_effective_gd[player_id] = effective_gd if effective_gd.present? %>
          <%- end %>

          <%- # Sortiere Spieler nach effective_gd (absteigend) und ermittle Rang %>
          <%- sorted_players = player_effective_gd.sort_by { |player_id, gd| -gd } %>
          <%- player_rank = {} %>
          <%- sorted_players.each_with_index do |(player_id, gd), index| %>
            <%- player_rank[player_id] = index + 1 %>
          <%- end %>
        <%- else %>
          <%- player_rank = {} %>
        <%- end %>

        <div class="flex items-center justify-between mb-4">
          <h1 class="h3"><%= @tournament.title %> - <%= @tournament.season.name %>
            - <%= @tournament.organizer.shortname %>
            - <%= t('tournaments.define_participants.heading') %></h1>
          <%= custom_link_to t('tournaments.define_participants.back'), @tournament %>
        </div>

        <div class="mb-4 p-4 dark:bg-gray-800 bg-green-50 border border-green-200 rounded">
          <h4 class="font-semibold text-green-900 mb-2"><%= t('tournaments.define_participants.edit_heading') %></h4>
          <ul class="list-disc list-inside dark:text-green-400 text-green-800 text-sm space-y-1">
            <li><%= t('tournaments.define_participants.tip_check_boxes_html').html_safe %></li>
            <li><% if @tournament.handicap_tournier %><%= t('tournaments.define_participants.tip_handicap_html').html_safe %><% else %><%= t('tournaments.define_participants.tip_auto_save') %><% end %></li>
            <li><%= t('tournaments.define_participants.tip_position_html').html_safe %></li>
            <li><%= t('tournaments.define_participants.tip_ranking_html', discipline: @tournament.discipline.name).html_safe %></li>
            <li><%= t('tournaments.define_participants.tip_late_registration') %></li>
          </ul>
        </div>

        <table class="w-full">
          <thead>
          <tr>
            <th class="w-16"><%= t('tournaments.define_participants.col_pos') %></th>
            <th class="w-20"><%= t('tournaments.define_participants.col_new_pos') %></th>
            <th class="w-24"><%= t('tournaments.define_participants.col_order') %></th>
            <th><%= t('tournaments.define_participants.col_name') %></th>
            <th class="w-20 text-center"><%= t('tournaments.define_participants.col_ranking') %></th>
            <th class="w-32 text-center"><%= t('tournaments.define_participants.col_participant') %></th>
            <th class="w-32 text-right"><% if @tournament.handicap_tournier %><%= t('tournaments.define_participants.col_handicap') %><% else %><%= t('tournaments.define_participants.col_points_goal') %><% end %></th>
          </tr>
          </thead>
          <tbody>
          <%- seeding_scope = @tournament.seedings.where("seedings.id >= #{Seeding::MIN_ID}").count > 0 ? "seedings.id >= #{Seeding::MIN_ID}" : "seedings.id < #{Seeding::MIN_ID}" %>
          <%- active_seedings = @tournament.seedings.where(seeding_scope).to_a %>

          <%# Sortiere und aktualisiere Positionen NUR wenn keine Einladung hochgeladen wurde %>
          <%# UND nur wenn Positionen noch nicht gesetzt sind (erstes Mal) %>
          <%- if @tournament.data['invitation_filename'].blank? %>
            <%# Prüfe ob Positionen bereits manuell gesetzt wurden %>
            <%- positions_already_set = active_seedings.all? { |s| s.position.present? } %>

            <%- if !positions_already_set %>
              <%# Sortiere Seedings nach berechnetem Ranking (falls vorhanden), sonst 999 %>
              <%- active_seedings.sort_by! do |seeding| %>
                <%- rank = player_rank[seeding.player_id] %>
                <%- rank.present? ? rank : 999 %>
              <%- end %>

              <%# Setze initiale Positionen basierend auf Ranking-Sortierung %>
              <%- active_seedings.each_with_index do |seeding, index| %>
                <%- if seeding.position != (index + 1) %>
                  <%- seeding.update_column(:position, index + 1) %>
                <%- end %>
              <%- end %>
            <%- end %>

            <%# Sortiere nach Position (respektiert manuelle Änderungen) %>
            <%- active_seedings.sort_by! { |s| s.position || 999 } %>
          <%- else %>
            <%# Mit Einladung: Sortiere nach Position aus der Einladung %>
            <%- active_seedings.sort_by! { |s| s.position || 999 } %>
          <%- end %>

          <%# Zeige aktive Seedings (sortiert nach position) %>
          <%- active_seedings.each_with_index do |seeding, index| %>
            <%- player = seeding.player %>
            <%- prev_seeding = index > 0 ? active_seedings[index - 1] : nil %>
            <%- next_seeding = index < active_seedings.length - 1 ? active_seedings[index + 1] : nil %>
            <%- rank = player_rank[player.id] %>
            <%- player_region = @tournament.organizer.is_a?(Region) ? @tournament.organizer : player.player_rankings.where(discipline_id: @tournament.discipline_id, season_id: seasons.pluck(:id)).first&.region %>
            <tr data-seeding-id="<%= seeding.id %>" class="<%= seeding.state == 'no_show' ? 'opacity-50' : '' %>">
              <td class="text-center font-semibold"><%= seeding.position || (index + 1) %></td>
              <td class="text-center">
                <%= number_field_tag "new_position-#{player.id}", nil,
                    placeholder: seeding.position,
                    style: "width:60px",
                    min: 1,
                    max: active_seedings.length,
                    class: "text-center",
                    data: { reflex: "change->TournamentReflex#change_position", id: @tournament.id } %>
              </td>
              <td class="text-center">
                <div class="flex flex-col gap-1">
                  <% if prev_seeding.present? %>
                    <button class="btn btn-xs btn-outline-secondary"
                            title="<%= t('tournaments.define_participants.move_up') %>"
                            data-reflex="click->TournamentReflex#move_up"
                            data-tournament-id="<%= @tournament.id %>"
                            data-seeding-id="<%= seeding.id %>">
                      ↑
                    </button>
                  <% else %>
                    <span class="btn btn-xs btn-disabled opacity-50 cursor-not-allowed" title="<%= t('tournaments.define_participants.already_top') %>">↑</span>
                  <% end %>
                  <% if next_seeding.present? %>
                    <button class="btn btn-xs btn-outline-secondary"
                            title="<%= t('tournaments.define_participants.move_down') %>"
                            data-reflex="click->TournamentReflex#move_down"
                            data-tournament-id="<%= @tournament.id %>"
                            data-seeding-id="<%= seeding.id %>">
                      ↓
                    </button>
                  <% else %>
                    <span class="btn btn-xs btn-disabled opacity-50 cursor-not-allowed" title="<%= t('tournaments.define_participants.already_bottom') %>">↓</span>
                  <% end %>
                </div>
              </td>
              <td><%= player.fullname %></td>
              <td class="text-center">
                <% if rank.present? && player_region.present? %>
                  <%= link_to rank,
                      ranking_path(player_region) + "#discipline-#{@tournament.discipline_id}",
                      class: 'text-blue-600 dark:text-blue-200 hover:text-blue-800 underline',
                      title: t('tournaments.define_participants.rank_title', rank: rank, discipline: @tournament.discipline.name, region: player_region.shortname),
                      target: '_blank' %>
                <% else %>
                  <span class="text-gray-400">-</span>
                <% end %>
              </td>
              <td class="text-center">
                <%= check_box_tag "participate-#{player.id}", "1", seeding.present? && seeding.state != 'no_show',
                    data: { reflex: "change->TournamentReflex#change_seeding", id: @tournament.id } %>
              </td>
              <td class="text-right" id="balls-wrapper-<%= player.id %>">
                <%= number_field_tag("balls-#{player.id}", seeding.balls_goal,
                    data: { reflex: "change->TournamentReflex#change_point_goal", id: @tournament.id },
                    style: seeding.present? && seeding.state != 'no_show' ? "" : "display: none",
                    class: "w-20 text-right") %>
              </td>
            </tr>
          <% end %>

          <%# Zeige Spieler ohne Seeding (falls vorhanden) %>
          <%- seeding_scope = @tournament.seedings.where("seedings.id >= #{Seeding::MIN_ID}").count > 0 ? "seedings.id >= #{Seeding::MIN_ID}" : "seedings.id < #{Seeding::MIN_ID}" %>
          <%- players_with_seedings = active_seedings.map(&:player_id).to_set %>
          <%- players = @tournament.organizer.is_a?(Region) ? Player.all.joins(:seedings).where(seedings: { tournament_id: @tournament.id }).where(seeding_scope) : @tournament.organizer.season_participations.where(season: Season.current_season).map(&:player).compact %>
          <%- club_players = players.uniq.reject { |p| players_with_seedings.include?(p.id) }.sort_by { |player| player.fl_name }.to_a %>
          <%- guest_players = @tournament.organizer.is_a?(Region) ? [] : @tournament.organizer.players.where(guest: true).order(:lastname).to_a.reject { |p| players_with_seedings.include?(p.id) } %>

          <%- (club_players + guest_players).each do |player| %>
            <%- rank = player_rank[player.id] %>
            <%- player_region = @tournament.organizer.is_a?(Region) ? @tournament.organizer : player.player_rankings.where(discipline_id: @tournament.discipline_id, season_id: seasons.pluck(:id)).first&.region %>
            <tr>
              <td class="text-center text-gray-400">-</td>
              <td></td>
              <td></td>
              <td class="text-gray-500"><%= player.fullname %></td>
              <td class="text-center">
                <% if rank.present? && player_region.present? %>
                  <%= link_to rank,
                      ranking_path(player_region) + "#discipline-#{@tournament.discipline_id}",
                      class: 'text-blue-600 dark:text-blue-200 hover:text-blue-800 underline text-sm',
                      title: t('tournaments.define_participants.rank_title', rank: rank, discipline: @tournament.discipline.name, region: player_region.shortname),
                      target: '_blank' %>
                <% else %>
                  <span class="text-gray-400 text-sm">-</span>
                <% end %>
              </td>
              <td class="text-center">
                <%= check_box_tag "participate-#{player.id}", "1", false,
                    data: { reflex: "change->TournamentReflex#change_seeding", id: @tournament.id } %>
              </td>
              <td class="text-right" id="balls-wrapper-<%= player.id %>">
                <%= number_field_tag("balls-#{player.id}", nil,
                    data: { reflex: "change->TournamentReflex#change_point_goal", id: @tournament.id },
                    style: "display: none",
                    class: "w-20 text-right") %>
              </td>
            </tr>
          <% end %>
          </tbody>
        </table>

        <!-- Sortier-Buttons -->
        <div class="mt-6 p-4 bg-gray-50 dark:bg-gray-800 border border-gray-300 rounded">
          <h4 class="font-semibold text-gray-900 dark:text-gray-200 mb-3"><%= t('tournaments.define_participants.sort_heading') %></h4>
          <div class="flex gap-3">
            <button class="btn btn-primary"
                    data-reflex="click->TournamentReflex#sort_by_ranking"
                    data-id="<%= @tournament.id %>"
                    title="<%= t('tournaments.define_participants.sort_by_ranking_title') %>">
              <%= t('tournaments.define_participants.sort_by_ranking') %>
            </button>
            <% if @tournament.handicap_tournier %>
              <button class="btn btn-secondary"
                      data-reflex="click->TournamentReflex#sort_by_handicap"
                      data-id="<%= @tournament.id %>"
                      title="<%= t('tournaments.define_participants.sort_by_handicap_title') %>">
                <%= t('tournaments.define_participants.sort_by_handicap') %>
              </button>
            <% end %>
          </div>
          <p class="text-xs text-gray-600 dark:text-gray-400 mt-2">
            <%= t('tournaments.define_participants.sort_info') %>
          </p>
        </div>
        
        <!-- Turnierpläne und Gruppenzuordnungen Vorschau -->
        <% if @participant_count > 0 && @proposed_discipline_tournament_plan.present? %>
          <div class="mt-6 p-4 bg-blue-50 dark:bg-gray-800 border border-blue-200 rounded">
            <h4 class="font-semibold text-blue-900 dark:text-blue-200 mb-3">
              <%= t('tournaments.define_participants.possible_plans_heading', count: @participant_count) %>
            </h4>

            <!-- Vorgeschlagener Plan (aus Einladung oder automatisch) -->
            <div class="mb-4 p-3 dark:bg-black bg-white border border-blue-300 rounded">
              <div class="flex items-center justify-between mb-2">
                <div class="flex-1">
                  <% if @tournament.data['extracted_plan_info'].present? %>
                    <span class="text-sm font-semibold text-green-700"><%= t('tournaments.define_participants.from_invitation_label') %></span>
                  <% else %>
                    <span class="text-sm font-semibold dark:text-blue-400 text-blue-700"><%= t('tournaments.define_participants.auto_suggested_label') %></span>
                  <% end %>
                  <span class="text-sm font-bold ml-2"><%= @proposed_discipline_tournament_plan.name %></span>
                  <% if @groups_source == :extracted_differs_from_nbv %>
                    <span class="ml-2 text-xs bg-red-100 text-red-700 px-2 py-1 rounded"><%= t('tournaments.define_participants.differs_from_nbv') %></span>
                  <% elsif @groups_source == :extracted_matches_nbv %>
                    <span class="ml-2 text-xs bg-green-100 text-green-700 px-2 py-1 rounded"><%= t('tournaments.define_participants.nbv_conform') %></span>
                  <% end %>
                </div>
                <% rounds = @proposed_discipline_tournament_plan.rounds_count %>
                <% if rounds.present? %>
                  <span class="text-xs dark:bg-gray-800 bg-gray-100 dark:text-gray-100 text-gray-700 px-2 py-1 rounded ml-2">
                    <%= t('tournaments.define_participants.rounds', count: rounds) %>
                  </span>
                <% end %>
              </div>
              <p class="text-xs dark:text-gray-100 text-gray-600 mb-2"><%= @proposed_discipline_tournament_plan.rulesystem %></p>
              <%= render partial: "groups_compact", locals: { tournament_plan: @proposed_discipline_tournament_plan, groups: @groups } %>
            </div>

            <!-- Alternative Pläne (gleiche Disziplin) -->
            <% if @alternatives_same_discipline.any? %>
              <details class="text-sm mb-3">
                <summary class="cursor-pointer text-blue-800 dark:text-blue-400 hover:text-blue-900 font-semibold">
                  <%= t('tournaments.define_participants.show_alternatives_same_discipline', count: @alternatives_same_discipline.count, discipline: @tournament.discipline.name) %>
                </summary>
                <div class="mt-3 space-y-2">
                  <% @alternatives_same_discipline.each do |alternative| %>
                    <div class="p-3 dark:bg-black bg-white border border-gray-300 rounded">
                      <div class="flex items-center justify-between mb-2">
                        <div class="flex-1">
                          <span class="text-sm font-bold"><%= alternative.name %></span>
                          <span class="text-xs text-gray-500 ml-2"><%= alternative.rulesystem %></span>
                        </div>
                        <% rounds = alternative.rounds_count %>
                        <% if rounds.present? %>
                          <span class="text-xs bg-gray-100 text-gray-700 dark:text-gray-200 px-2 py-1 rounded ml-2">
                            <%= t('tournaments.define_participants.rounds', count: rounds) %>
                          </span>
                        <% end %>
                      </div>
                      <% alternative_groups = TournamentMonitor.distribute_to_group(
                           @tournament.seedings.where.not(state: "no_show").where(@seeding_scope).order(:position).map(&:player),
                           alternative.ngroups,
                           alternative.group_sizes) %>
                      <%= render partial: "groups_compact", locals: { tournament_plan: alternative, groups: alternative_groups } %>
                    </div>
                  <% end %>
                </div>
              </details>
            <% end %>

            <!-- Weitere Pläne (andere Disziplinen, Jeder-gegen-Jeden, KO) -->
            <% if @alternatives_other_disciplines.any? %>
              <details class="text-sm">
                <summary class="cursor-pointer text-gray-700 dark:text-gray-200 hover:text-gray-900 font-semibold">
                  <%= t('tournaments.define_participants.show_other_plans', count: @alternatives_other_disciplines.count) %>
                  <% if @participant_count <= 6 %>
                    <span class="ml-1 text-green-700"><%= t('tournaments.define_participants.incl_round_robin') %></span>
                  <% end %>
                </summary>
                <div class="mt-3 space-y-2">
                  <% @alternatives_other_disciplines.each do |alternative| %>
                    <% is_round_robin = alternative.name =~ /jeder.*gegen.*jeden/i || alternative.name =~ /round.*robin/i || alternative.name == "Jgj#{@participant_count}" %>
                    <div class="p-3 dark:bg-black bg-white border <%= is_round_robin ? 'border-green-300 dark:bg-gray-600 bg-green-50' : 'border-gray-300' %> rounded">
                      <div class="flex items-center justify-between mb-2">
                        <div class="flex-1">
                          <% if is_round_robin %>
                            <span class="text-xs bg-green-100 text-green-700 px-2 py-1 rounded mr-2"><%= t('tournaments.define_participants.round_robin_tag') %></span>
                          <% end %>
                          <span class="text-sm font-bold"><%= alternative.name %></span>
                          <span class="text-xs text-gray-500 ml-2"><%= alternative.rulesystem %></span>
                        </div>
                        <% rounds = alternative.rounds_count %>
                        <% if rounds.present? %>
                          <span class="text-xs <%= is_round_robin ? 'bg-green-100 text-green-700' : 'bg-gray-100 text-gray-700 dark:text-gray-200' %> px-2 py-1 rounded ml-2">
                            <%= t('tournaments.define_participants.rounds', count: rounds) %>
                          </span>
                        <% end %>
                      </div>
                      <% alternative_groups = TournamentMonitor.distribute_to_group(
                           @tournament.seedings.where.not(state: "no_show").where(@seeding_scope).order(:position).map(&:player),
                           alternative.ngroups,
                           alternative.group_sizes) %>
                      <%= render partial: "groups_compact", locals: { tournament_plan: alternative, groups: alternative_groups } %>
                    </div>
                  <% end %>
                </div>
              </details>
            <% end %>

            <div class="text-xs dark:text-blue-400 text-blue-700 mt-3 space-y-1">
              <p><%= t('tournaments.define_participants.groups_auto_update_info') %></p>
              <% if @alternatives_other_disciplines.any? %>
                <p class="dark:text-gray-100 text-gray-600">
                  <%= t('tournaments.define_participants.reduced_mode_info_html').html_safe %>
                </p>
              <% end %>
            </div>
          </div>
        <% elsif @participant_count > 0 %>
          <div class="mt-6 p-4 bg-gray-50 border border-gray-300 rounded">
            <p class="text-sm text-gray-700 dark:text-gray-200">
              <%= t('tournaments.define_participants.no_plan_for_count', count: @participant_count, discipline: @tournament.discipline.name) %>
            </p>
          </div>
        <% end %>

        <!-- Spieler hinzufügen (kurzfristige Nachmeldung) -->
        <div class="mt-6 p-4 bg-yellow-50 border border-yellow-200 rounded">
          <h4 class="font-semibold text-yellow-900 mb-2"><%= t('tournaments.define_participants.late_registration_heading') %></h4>
          <p class="text-sm text-yellow-800 mb-3">
            <%= t('tournaments.define_participants.add_player_by_dbu_html').html_safe %>
          </p>

          <%= form_with url: add_player_by_dbu_tournament_path(@tournament), method: :post, local: true, class: 'flex gap-2 items-start' do |f| %>
            <div class="flex-1">
              <%= text_field_tag :dbu_nr, nil,
                  placeholder: t('tournaments.define_participants.dbu_nr_placeholder'),
                  class: 'form-control',
                  pattern: '[\d,\s]+',
                  required: true %>
              <p class="text-xs text-yellow-700 mt-1">
                <%= t('tournaments.define_participants.dbu_nr_hint') %>
              </p>
            </div>
            <%= f.submit t('tournaments.define_participants.add_player_button'),
                class: 'btn btn-sm btn-warning',
                data: { disable_with: t('tournaments.define_participants.searching') } %>
          <% end %>

          <details class="mt-3">
            <summary class="cursor-pointer text-sm text-yellow-800 font-semibold">
              <%= t('tournaments.define_participants.no_dbu_nr_question') %>
            </summary>
            <div class="mt-2 p-3 bg-yellow-100 rounded text-sm text-yellow-900">
              <p class="font-semibold mb-2"><%= t('tournaments.define_participants.no_dbu_nr_title') %></p>
              <p>
                <%= t('tournaments.define_participants.no_dbu_nr_reason_html').html_safe %>
              </p>
              <p class="mt-2">
                <strong><%= t('tournaments.define_participants.solution_label') %></strong>
                <ol class="list-decimal list-inside ml-2 mt-1">
                  <li><%= t('tournaments.define_participants.solution_apply_dbu_nr') %></li>
                  <li><%= t('tournaments.define_participants.solution_add_guest') %></li>
                </ol>
              </p>
            </div>
          </details>
        </div>
      <%- end %>

      <!-- Info-Box und Navigation -->
      <div class="mt-8 p-4 bg-blue-50 dark:bg-gray-800 border border-blue-200 rounded">
        <div class="flex items-center justify-between">
          <div>
            <h4 class="font-semibold text-blue-900 dark:text-blue-200"><%= t('tournaments.define_participants.important_label') %></h4>
            <p class="text-sm text-blue-800 dark:text-blue-400">
              <%= t('tournaments.define_participants.all_changes_saved_html').html_safe %><br>
              <%= t('tournaments.define_participants.can_return_anytime') %>
            </p>
            <p class="text-sm text-blue-900 dark:text-blue-200 mt-3 font-semibold bg-blue-100 dark:bg-gray-800 p-2 rounded">
              <%= t('tournaments.define_participants.when_done_html').html_safe %>
            </p>
          </div>
          <%= link_to t('tournaments.define_participants.back_to_wizard'), tournament_path(@tournament),
              class: 'btn btn-secondary' %>
        </div>
      </div>
    </div>
  </div>
</div>
