style
  |  th, td { padding: 3px; }
div
  = render :partial => "show", locals: {tournament: @tournament, subtitle: "", show_edit_back: true}
p
  .d-inline-flex.flex-wrap.align-items-start
    = button_to I18n.t("tournaments.show.reload_from_billard_area"), reload_from_ba_tournament_path(@tournament), method: :post, style: "float: left; margin-right: 10px;", class: "btn btn-flat btn-primary"
    strong*{style: "padding-top: 7px;"}
      | ===>
  .d-inline-flex.flex-wrap.align-items-start
    = button_to I18n.t("tournaments.show.order_by_ranking"), order_by_ranking_tournament_path(@tournament), method: :post, class: "btn btn-flat btn-primary", style: "float: left; margin-right: 10px;", disabled: !%w{new_tournament accreditation_finished}.include?(@tournament.state)
    strong*{style: "padding-top: 7px;"}
      | ===>
  .d-inline-flex.flex-wrap.align-items-start
    = button_to I18n.t("tournaments.show.finalize_tournament_modus"), finalize_modus_tournament_path(@tournament), method: :get, class: "btn btn-flat btn-primary", style: "float: left; margin-right: 10px;", disabled: !%w{accreditation_finished tournament_seeding_finished}.include?(@tournament.state)
    strong*{style: "padding-top: 7px;"}
      | ===>
  .d-inline-flex
    = button_to I18n.t("tournaments.show.mangage_tournament_group_phase"), tournament_monitor_tournament_path(@tournament), method: :get, class: "btn btn-flat btn-primary", style: "float: left; margin-right: 10px;", disabled: %w{new_tournament accreditation_finished tournament_seeding_finished finals_finished results_published closed}.include?(@tournament.state)
h2
  = I18n.t("tournaments.show.registrations")
table
  thead
    tr
      th
        = I18n.t("tournaments.show.position")
      th[colspan="2"]
        = I18n.t("tournaments.show.reorder")
      th
        = I18n.t("tournaments.show.name")
      th
        = I18n.t("tournaments.show.club")
      th
        = "Rank<br/>#{@tournament.discipline.name}<br/>Season #{@tournament.season.previous.name}".html_safe
      - if @tournament.handicap_tournier?
        th
          = I18n.t("tournaments.show.balls_goal")
        th
          = I18n.t("tournaments.show.discipline")
  tbody
    - @tournament.seedings.joins(:player).order(@tournament.tournament_seeding_finished? ? "seedings.position" : "players.lastname asc, players.firstname asc").each do |seeding|
      - club = @tournament.season.season_participations.where("season_participations.player_id = ?", seeding.player.id).first.club
      tr
        td
          = seeding.position
        td
          = link_to image_tag("up-icon.png"), up_seeding_path(seeding), method: :post
        td
          = link_to image_tag("down-icon.png"), down_seeding_path(seeding), method: :post
        td
          = link_to("#{seeding.player.lastname}, #{seeding.player.firstname}", player_path(seeding.player))
        td
          = link_to("#{club.shortname}", club_path(club))
        td
          = seeding.player.player_rankings.where(discipline_id: Discipline.find_by_name("Freie Partie klein"), season_id: Season.find_by_ba_id(Season.current_season.ba_id - 1)).first.andand.rank.presence || 999
        - if @tournament.handicap_tournier?
          td
            = seeding.balls_goal
          td
            = seeding.playing_discipline.andand.shortname
h2
  = I18n.t("tournaments.show.rankings")
- lists = @tournament.seedings.joins(:player).order("players.lastname, players.firstname").map { |s| s.data["result"].keys rescue [] }.inject([]) { |a, memo| memo |= a; memo }
- lists.each do |list|
  h3
    = list
  table
    thead
      tr
        - @tournament.seedings.select{ |seeding|  seeding.data["result"].andand[list].present? }.first.data["result"][list].keys.each do |k|
          - next if k == "Rank"
          th
            = k
    tbody
      - @tournament.seedings.select{ |seeding| seeding.data["result"].andand[list].present? }.sort_by { |seeding| seeding.data["result"][list]["#"].to_i }.each do |seeding|
        tr
          - seeding.data["result"][list].each do |k, v|
            - next if k == "Rank"
            td
              = v
h2
  = I18n.t("tournaments.show.games")
- if @tournament.games.present?
  table
    thead
      tr
        - @tournament.games.first.data.keys.each do |k|
          th
            = k
    tbody
      - @tournament.games.each do |game|
        tr
          - skip = false
          - game.data.each do |k, v|
            - skip = true if %w{Heim Gast}.include?(k) && v.blank?
            - unless skip
              td
                = v
- games = @tournament.games.order(seqno: :asc)
- if !@tournament.tournament_started
  = button_to I18n.t("tournaments.show.reset_tournament_monitor"), reset_tournament_path(@tournament), method: :post, class: "btn btn-flat btn-primary", data: {confirm: 'Are you sure?'}, style: "float: left; margin-right: 10px;"
- if current_user.email.downcase == "gernot.ullrich@gmx.de"
  = button_to I18n.t("tournaments.show.debugging_force_reset_tournament_monitor"), reset_tournament_path(@tournament, force_reset: true), method: :post, class: "btn btn-flat btn-primary", style: "float: left; margin-right: 10px;"
