<div class="container mx-auto my-8 px-4">
  <div class="max-w-5xl mx-auto">
    <div class="flex flex-wrap justify-between items-start gap-2 mb-4">
      <div class="min-w-0">
        <h1 class="text-xl font-semibold text-gray-900 dark:text-gray-100 break-words">
          <%= custom_link_to t('home.index.tournaments'), tournaments_path, class: "text-primary-600 hover:text-primary-700" %>
          <span class="text-gray-400 dark:text-gray-500">&gt;</span> <%= tournament.title %>
          <span class="text-gray-500 dark:text-gray-400 font-normal">— <%= tournament.organizer.shortname %> · <%= tournament.season.name %></span>
        </h1>
        <% if subtitle.present? %><h3 class="text-sm text-gray-500 dark:text-gray-400 mt-0.5"><%= subtitle %></h3><% end %>
      </div>
      <% if local_server? && !tournament.has_clubcloud_results? %>
        <%= button_to(t('tournaments.show.edit_button'), edit_tournament_path(tournament), method: :get, disabled: !current_user&.admin?, class: "btn btn-link shrink-0") %>
      <% end %>
    </div>
    <%- unless local_assigns[:drop_details].present? %>
      <%# Detail-Card-Muster (Phase 6): Token-Card + responsives Label/Wert-Grid — Referenz fuer uebrige Show-Seiten. %>
      <div class="grid grid-cols-2 md:grid-cols-3 lg:grid-cols-4 gap-x-6 gap-y-4 bg-surface-card dark:bg-gray-800 rounded-card border border-gray-200 dark:border-gray-700 p-6 text-gray-900 dark:text-gray-100">
        <div class="min-w-0"><h5 class="text-xs uppercase tracking-wide text-gray-400 dark:text-gray-500 font-normal mb-0.5"><%= t('activerecord.attributes.tournament.title') %></h5><%= tournament.title %></div>
        <div class="min-w-0 <%= "ring-2 ring-red-500 rounded-md p-1" if tournament.discipline.blank? %>">
          <h5 class="text-xs uppercase tracking-wide text-gray-400 dark:text-gray-500 font-normal mb-0.5"><%= t('tournaments.show.discipline') %></h5><%= (custom_link_to(tournament.discipline.name, discipline_path(tournament.discipline)) if tournament.discipline.present?) %>
        </div>
        <% if tournament.modus.present? %>
          <div class="min-w-0"><h5 class="text-xs uppercase tracking-wide text-gray-400 dark:text-gray-500 font-normal mb-0.5"><%= t('activerecord.attributes.tournament.modus') %></h5><%= tournament.modus %></div>
        <% end %>
        <% if tournament.age_restriction.present? %>
          <div class="min-w-0">
            <h5 class="text-xs uppercase tracking-wide text-gray-400 dark:text-gray-500 font-normal mb-0.5"><%= t('activerecord.attributes.tournament.age_restriction') %></h5><%= tournament.age_restriction %></div>
        <% end %>
        <div class="min-w-0"><h5 class="text-xs uppercase tracking-wide text-gray-400 dark:text-gray-500 font-normal mb-0.5"><%= t('activerecord.attributes.tournament.date') %></h5><%= tournament.date %></div>
        <div class="min-w-0">
          <h5 class="text-xs uppercase tracking-wide text-gray-400 dark:text-gray-500 font-normal mb-0.5"><%= t('activerecord.attributes.tournament.accredation_end') %></h5><%= tournament.accredation_end %></div>
        <div class="min-w-0">
          <%# InternationalTournament (STI) #location ist ein String (location_text) -> nur fuer echte Location verlinken. %>
          <h5 class="text-xs uppercase tracking-wide text-gray-400 dark:text-gray-500 font-normal mb-0.5"><%= t('activerecord.attributes.tournament.location') %></h5><%= custom_link_to tournament.location.display_address, location_path(tournament.location) if tournament.location.is_a?(Location) %>
        </div>
        <div class="min-w-0">
          <h5 class="text-xs uppercase tracking-wide text-gray-400 dark:text-gray-500 font-normal mb-0.5"><%= t('activerecord.attributes.tournament.season') %></h5><%= custom_link_to(tournament.season.name, season_path(tournament.season)) %>
        </div>
        <div class="min-w-0">
          <h5 class="text-xs uppercase tracking-wide text-gray-400 dark:text-gray-500 font-normal mb-0.5"><%= t('activerecord.attributes.tournament.organizer') %></h5><%= custom_link_to(tournament.organizer.name, tournament.organizer) %>
        </div>
        <% if tournament.end_date.present? %>
          <div class="min-w-0"><h5 class="text-xs uppercase tracking-wide text-gray-400 dark:text-gray-500 font-normal mb-0.5"><%= t('activerecord.attributes.tournament.end_date') %></h5><%= tournament.end_date %></div>
        <% end %>
        <div class="min-w-0"><h5 class="text-xs uppercase tracking-wide text-gray-400 dark:text-gray-500 font-normal mb-0.5"><%= t('activerecord.attributes.tournament.shortname') %></h5><%= tournament.shortname %></div>
        <% if tournament.data.present? && tournament_director?(current_user) %>
          <div class="min-w-0">
            <h5 class="text-xs uppercase tracking-wide text-gray-400 dark:text-gray-500 font-normal mb-0.5"><%= t('activerecord.attributes.tournament.data') %></h5>
            <button type="button"
                    onclick="document.getElementById('tournament-data-modal-<%= tournament.id %>').classList.remove('hidden')"
                    class="btn btn-sm btn-secondary cursor-pointer">
              <%= t('tournaments.show.show_tournament_data') %>
            </button>
          </div>
          
          <!-- Modal Popup für Turnier-Daten -->
          <div id="tournament-data-modal-<%= tournament.id %>" 
               class="hidden fixed inset-0 z-50 overflow-y-auto">
            <div class="flex items-center justify-center min-h-screen px-4 pt-4 pb-20 text-center sm:block sm:p-0">
              <!-- Hintergrund Overlay -->
              <div class="fixed inset-0 transition-opacity bg-gray-500 bg-opacity-75"></div>
              
              <!-- Modal Content - Volle Breite über alle 4 Spalten -->
              <div class="inline-block w-full max-w-7xl p-6 my-8 overflow-hidden text-left align-middle transition-all transform bg-white dark:bg-gray-800 shadow-xl rounded-lg">
                <!-- Header -->
                <div class="flex items-center justify-between pb-4 border-b border-gray-200 dark:border-gray-700">
                  <h3 class="text-2xl font-bold text-gray-900 dark:text-gray-100">
                    <%= t('tournaments.show.tournament_data_modal_title') %> <%= tournament.title %>
                  </h3>
                  <button type="button"
                          class="text-gray-400 hover:text-gray-600 transition-colors close-modal-btn">
                    <svg class="w-6 h-6" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                      <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M6 18L18 6M6 6l12 12"></path>
                    </svg>
                  </button>
                </div>
                
                <!-- Content -->
                <div class="mt-4 overflow-auto max-h-[70vh]">
                  <pre class="p-4 bg-gray-50 dark:bg-gray-900 dark:text-gray-100 rounded-lg text-sm font-mono whitespace-pre-wrap break-words"><%= JSON.pretty_generate(tournament.data) %></pre>
                </div>

                <!-- Footer -->
                <div class="flex justify-end mt-6 pt-4 border-t border-gray-200 dark:border-gray-700">
                  <button type="button"
                          class="btn btn-primary close-modal-btn">
                    <%= t('tournaments.show.close') %>
                  </button>
                </div>
              </div>
            </div>
          </div>
          
          <!-- JavaScript für ESC-Taste Unterstützung -->
          <script>
            (function() {
              const modalId = 'tournament-data-modal-<%= tournament.id %>';
              const modal = document.getElementById(modalId);
              if (!modal) return;
              
              // ESC-Taste Handler
              function handleEscape(event) {
                if (event.key === 'Escape' && !modal.classList.contains('hidden')) {
                  modal.classList.add('hidden');
                  document.removeEventListener('keydown', handleEscape);
                }
              }
              
              // Beim Öffnen: ESC-Listener hinzufügen (wenn Modal noch nicht geöffnet war)
              const openButton = document.querySelector('[onclick*="tournament-data-modal-<%= tournament.id %>"]');
              if (openButton) {
                openButton.addEventListener('click', function() {
                  setTimeout(function() {
                    document.addEventListener('keydown', handleEscape);
                  }, 100);
                });
              }
              
              // Schließen-Funktion
              function closeModal() {
                modal.classList.add('hidden');
                document.removeEventListener('keydown', handleEscape);
              }
              
              // Alle Schließen-Buttons verbinden
              modal.addEventListener('click', function(event) {
                if (event.target.classList.contains('close-modal-btn') || 
                    event.target.closest('.close-modal-btn') ||
                    event.target.classList.contains('bg-gray-500') ||
                    event.target === modal) {
                  closeModal();
                }
              });
            })();
          </script>
        <% end %>
        <% if tournament.ba_state.present? %>
          <div class="min-w-0"><h5 class="text-xs uppercase tracking-wide text-gray-400 dark:text-gray-500 font-normal mb-0.5"><%= t('activerecord.attributes.tournament.ba_state') %></h5><%= tournament.ba_state %></div>
        <% end %>
        <% if tournament.player_class.present? %>
          <div class="min-w-0 <%= "ring-2 ring-red-500 rounded-md p-1" if tournament.player_class.blank? %>">
            <h5 class="text-xs uppercase tracking-wide text-gray-400 dark:text-gray-500 font-normal mb-0.5"><%= t('activerecord.attributes.tournament.player_class') %></h5><%= tournament.player_class %></div>
        <% end %>
        <%- if tournament.tournament_plan.present? %>
          <div class="min-w-0"><h5 class="text-xs uppercase tracking-wide text-gray-400 dark:text-gray-500 font-normal mb-0.5"><%= I18n.t("tournaments.show.final_tournament_mode") %></h5>
            <%= custom_link_to(tournament.tournament_plan.name, tournament_plan_path(tournament.tournament_plan)) %>
            : <%= tournament.tournament_plan.rulesystem %>
          </div>
        <%- end %>
        <% if tournament.innings_goal.present? %>
          <div class="min-w-0"><h5 class="text-xs uppercase tracking-wide text-gray-400 dark:text-gray-500 font-normal mb-0.5"><%= t('activerecord.attributes.tournament.innings_goal') %></h5><%= tournament.innings_goal %>
          </div>
        <% end %>
        <% if tournament.tournament_monitor.present? %>
          <div class="min-w-0"><h5 class="text-xs uppercase tracking-wide text-gray-400 dark:text-gray-500 font-normal mb-0.5"><%= t('activerecord.attributes.tournament.balls_goal') %></h5><%= tournament.balls_goal %></div>
          <div class="min-w-0"><h5 class="text-xs uppercase tracking-wide text-gray-400 dark:text-gray-500 font-normal mb-0.5"><%= t('activerecord.attributes.tournament.timeouts') %></h5><%= tournament.timeouts %></div>
          <div class="min-w-0"><h5 class="text-xs uppercase tracking-wide text-gray-400 dark:text-gray-500 font-normal mb-0.5"><%= t('activerecord.attributes.tournament.timeout') %></h5><%= tournament.timeout %></div>
          <div class="min-w-0">
            <h5 class="text-xs uppercase tracking-wide text-gray-400 dark:text-gray-500 font-normal mb-0.5"><%= t('activerecord.attributes.tournament.handicap_tournier') %></h5><%= tournament.handicap_tournier %></div>
          <div class="min-w-0"><h5 class="text-xs uppercase tracking-wide text-gray-400 dark:text-gray-500 font-normal mb-0.5"><%= t('activerecord.attributes.tournament.sets_to_win') %></h5><%= tournament.sets_to_win %>
          </div>
          <div class="min-w-0"><h5 class="text-xs uppercase tracking-wide text-gray-400 dark:text-gray-500 font-normal mb-0.5"><%= t('activerecord.attributes.tournament.sets_to_play') %></h5><%= tournament.sets_to_play %>
          </div>
          <div class="min-w-0"><h5 class="text-xs uppercase tracking-wide text-gray-400 dark:text-gray-500 font-normal mb-0.5"><%= t('activerecord.attributes.tournament.team_size') %></h5><%= tournament.team_size %></div>
          <div class="min-w-0">
            <h5 class="text-xs uppercase tracking-wide text-gray-400 dark:text-gray-500 font-normal mb-0.5"><%= t('activerecord.attributes.tournament.kickoff_switches_with') %></h5><%= tournament.kickoff_switches_with %></div>
          <div class="min-w-0">
            <h5 class="text-xs uppercase tracking-wide text-gray-400 dark:text-gray-500 font-normal mb-0.5"><%= t('activerecord.attributes.tournament.allow_follow_up') %></h5><%= tournament.allow_follow_up %></div>
          <div class="min-w-0">
            <h5 class="text-xs uppercase tracking-wide text-gray-400 dark:text-gray-500 font-normal mb-0.5"><%= t('activerecord.attributes.tournament.fixed_display_left') %></h5><%= tournament.fixed_display_left.presence || "Kick-Off Player" %>
          </div>
          <div class="min-w-0">
            <h5 class="text-xs uppercase tracking-wide text-gray-400 dark:text-gray-500 font-normal mb-0.5"><%= t('activerecord.attributes.tournament.color_remains_with_set') %></h5><%= tournament.color_remains_with_set %></div>
        <% end %>
        <div class="min-w-0">
          <h5 class="text-xs uppercase tracking-wide text-gray-400 dark:text-gray-500 font-normal mb-0.5"><%= t('activerecord.attributes.tournament.source') %></h5><%= link_to_if tournament.source_url.present?, tournament.source_url.present? ? URI.parse(tournament.source_url).host : "", tournament.source_url, class: "green_link", target: :_blank %>
        </div>
        <div class="min-w-0"><h5 class="text-xs uppercase tracking-wide text-gray-400 dark:text-gray-500 font-normal mb-0.5"><%= t('tournaments.show.last_sync') %></h5><%= tournament.sync_date.andand.to_date %></div>
      </div>
      </div>
    <%- end %>
    </div>
