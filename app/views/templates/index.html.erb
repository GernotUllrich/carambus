<h1>Listing Templates</h1>

<table>
  <thead>
    <tr>
      <th>Name</th>
      <th>Rulesystem</th>
      <th>Players</th>
      <th>Tables</th>
      <th colspan="3"></th>
    </tr>
  </thead>

  <tbody>
    <% @templates.order(:players).each do |template| %>
      <tr>
        <td><%= template.name %></td>
        <td><%= template.rulesystem %></td>
        <td><%= template.players %></td>
        <td><%= template.tables %></td>
        <td><%= link_to image_tag("ansehen.gif", :width => 26, :height => 22, :border => 0), template %></td>
        <td><%= link_to image_tag("bearbeiten.gif", :width => 26, :height => 22, :border => 0), edit_template_path(template) %></td>
        <td><%= link_to image_tag("loeschen.gif", :width => 26, :height => 22, :border => 0), template, method: :delete, data: { confirm: 'Are you sure?' } %></td>
      </tr>
    <% end %>
  </tbody>
</table>

<br>

<%= link_to 'New Template', new_template_path %>
