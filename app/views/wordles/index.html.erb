<div class="container mx-auto my-8 px-4">
  <div class="flex justify-between items-center mb-4">
    <h1 class="h3">Wordles</h1>

    <% if @wordles.any? %>
      <%= link_to 'New Wordle', new_wordle_path, class: "btn btn-primary" %>
    <% end %>
  </div>

  <% if @wordles.any? %>
    <div class="bg-white rounded shadow table-responsive">
      <table class="table">
        <thead>
          <tr>
            <th class="p-3 uppercase text-left text-xs"><%= sortable @wordles, :words, 'Words', class: 'text-gray-700' %></th>
            <th class="p-3 uppercase text-left text-xs"><%= sortable @wordles, :hints, 'Hints', class: 'text-gray-700' %></th>
            <th class="p-3 uppercase text-left text-xs"><%= sortable @wordles, :data, 'Data', class: 'text-gray-700' %></th>
            <th class="p-3 uppercase text-left text-xs"><%= sortable @wordles, :seqno, 'Seqno', class: 'text-gray-700' %></th>
            <th class="p-3 uppercase text-left text-xs text-gray-700 w-20">Actions</th>
          </tr>
        </thead>

        <tbody>
        <% @wordles.each do |wordle| %>
          <tr class="group border-t border-gray-400 hover:bg-gray-100">
                      <td class="p-3"><%= wordle.words %></td>
                      <td class="p-3"><%= wordle.hints %></td>
                      <td class="p-3"><%= wordle.data %></td>
                      <td class="p-3"><%= wordle.seqno %></td>
          
            <td>
              <%= link_to "View", wordle, class: "btn btn-link no-underline" %>
            </td>
          </tr>
        <% end %>
        </tbody>
      </table>
    </div>

    <% if @pagy.pages > 1 %>
      <div class="text-center my-6">
        <%== pagy_nav(@pagy) %>
      </div>
    <% end %>

  <% else %>
    <div class="bg-white rounded shadow flex flex-col items-center justify-between p-8 lg:flex-row">
      <%= image_tag "empty.svg", class: "mb-4 lg:w-1/2" %>
      <div class="flex-1 text-center">
        <p class="h3 mb-4">Create your first Wordle</p>
        <%= link_to 'New Wordle', new_wordle_path, class: "btn btn-primary" %>
      </div>
    </div>
  <% end %>
</div>
