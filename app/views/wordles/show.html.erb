<div class="container mx-auto my-8 px-4">
  <div class="max-w-3xl mx-auto">
    <div class="flex justify-between items-center mb-4">
      <h1 class="h3"><%= link_to 'Wordles', wordles_path %> > Wordle #<%= @wordle.id %></h1>
      <%= link_to 'Edit', edit_wordle_path(@wordle), class: "btn btn-link" %>
    </div>

    <div class="bg-white rounded shadow p-8">
            <div class="mb-4">
        <h5>Words</h5>
        <%= @wordle.words %>
      </div>
            <div class="mb-4">
        <h5>Hints</h5>
        <%= @wordle.hints %>
      </div>
            <div class="mb-4">
        <h5>Data</h5>
        <%= @wordle.data %>
      </div>
            <div class="mb-4">
        <h5>Seqno</h5>
        <%= @wordle.seqno %>
      </div>
          </div>
  </div>
</div>
