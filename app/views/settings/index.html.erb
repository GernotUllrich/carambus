<div class="container mx-auto my-8 px-4">
  <div class="flex justify-between items-center mb-4">
    <h1 class="h3">Settings</h1>

    <% if @settings.any? %>
      <%= link_to 'New Setting', new_setting_path, class: "btn btn-primary" %>
    <% end %>
  </div>

  <% if @settings.any? %>
    <div class="bg-white dark:bg-black rounded shadow table-responsive">
      <table class="table">
        <thead>
          <tr>
            <th class="p-3 uppercase text-left text-xs"><%= sortable @settings, :data, 'Data', class: 'text-gray-700 dark:text-gray-200' %></th>
            <th class="p-3 uppercase text-left text-xs"><%= sortable @settings, :state, 'State', class: 'text-gray-700 dark:text-gray-200' %></th>
            <th class="p-3 uppercase text-left text-xs"><%= sortable @settings, :region_id, 'Region', class: 'text-gray-700 dark:text-gray-200' %></th>
            <th class="p-3 uppercase text-left text-xs"><%= sortable @settings, :club_id, 'Club', class: 'text-gray-700 dark:text-gray-200' %></th>
            <th class="p-3 uppercase text-left text-xs"><%= sortable @settings, :tournament_id, 'Tournament', class: 'text-gray-700 dark:text-gray-200' %></th>
            <th class="p-3 uppercase text-left text-xs text-gray-700 dark:text-gray-200 w-20"><%= t('actions') %></th>
          </tr>
        </thead>

        <tbody>
        <% @settings.each do |setting| %>
          <tr class="group border-t border-gray-400 hover:bg-gray-100 dark:bg-gray-800">
                      <td class="p-3"><%= setting.data %></td>
                      <td class="p-3"><%= setting.state %></td>
                      <td class="p-3"><%= setting.region_id %></td>
                      <td class="p-3"><%= setting.club_id %></td>
                      <td class="p-3"><%= setting.tournament_id %></td>

            <td>
              <%= link_to t('view'), setting, class: "btn btn-link no-underline" %>
            </td>
          </tr>
        <% end %>
        </tbody>
      </table>
    </div>

    <% if @pagy.pages > 1 %>
      <div class="text-center my-6">
        <%== pagy_nav(@pagy) %>
      </div>
    <% end %>

  <% else %>
    <div class="bg-white dark:bg-black rounded shadow flex flex-col items-center justify-between p-8 lg:flex-row">
      <%= image_tag "empty.svg", class: "mb-4 lg:w-1/2" %>
      <div class="flex-1 text-center">
        <p class="h3 mb-4">Create your first Setting</p>
        <%= link_to 'New Setting', new_setting_path, class: "btn btn-primary" %>
      </div>
    </div>
  <% end %>
</div>
