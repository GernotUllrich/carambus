<div class="container mx-auto my-8 px-4">
  <div class="max-w-3xl mx-auto">
    <div class="flex justify-between items-center mb-4">
      <h1 class="h3"><%= link_to 'Competition Ccs', competition_ccs_path %> > Competition Cc #<%= @competition_cc.id %></h1>
      <%= link_to 'Edit', edit_competition_cc_path(@competition_cc), class: "btn btn-link" %>
    </div>

    <div class="bg-white rounded shadow p-8">
            <div class="mb-4">
        <h5>Cc</h5>
        <%= @competition_cc.cc_id %>
      </div>
            <div class="mb-4">
        <h5>Name</h5>
        <%= @competition_cc.name %>
      </div>
            <div class="mb-4">
        <h5>Context</h5>
        <%= @competition_cc.context %>
      </div>
            <div class="mb-4">
        <h5>Branch cc</h5>
        <%= @competition_cc.branch_cc_id %>
      </div>
            <div class="mb-4">
        <h5>Discipline</h5>
        <%= @competition_cc.discipline_id %>
      </div>
          </div>
  </div>
</div>
