<%# 10-04: generische Detail-Card (09-01) + Seasons-Sub-Tabelle im details-Slot. %>
<% details_html = capture do %>
  <% if @season_ccs.any? %>
    <h3 class="text-lg font-semibold text-gray-900 dark:text-gray-100 mb-3">Seasons</h3>
    <div id="table_wrapper">
      <%= render partial: 'season_ccs/season_ccs_table', locals: { records: @season_ccs } %>
    </div>
  <% end %>
<% end %>
<%= render "shared/detail_card",
      record: @competition_cc,
      index_path: competition_ccs_path,
      index_label: "Competition Ccs",
      details: (details_html.to_s.strip.present? ? details_html : nil) %>
