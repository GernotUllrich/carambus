<div class="py-10 max-w-2xl m-auto text-center flex flex-col">
<%# p_css_add: text-xl %>

<%# wrapper_css_add: text-center %>

  <%- if request.host == "roald.carambus.de" %>
    <h1 class='font-bold mt-4'>Willkommen zum Antarktis Bildertausch Server</h1>
    Dieser Server ist nicht für die Öffentlichkeit bestimmt und dient nur dem Datentausch
    einiger ausgewählter Teilnehmer. Näheres bei <%= mail_to "gernot.ullrich@gmx.de" %>
  <%- else %>
    <%- if Carambus.config.carambus_api_url.blank? %>
      <h1 class='font-bold mt-4'><%= t('welcome_to_carambus') %>
        API Server</h1>
    <%- else %>
      <h1 class='font-bold mt-4'><%= t('welcome_to_carambus') %>
      </h1>
    <%- end %>
    <p class='text-base text-gray-700 text-xl dark:text-gray-200 leading-relaxed my-4'>
      Carambus unterstützt die Billard Disziplinen Karambol, Pool, Snooker und Kegel mit Browser-basierten Scoreboards, die in das Turniermanagement
      integriert sind.</p>
    <p class='text-base text-gray-700 text-xl dark:text-gray-200 leading-relaxed my-4'>
      Das Turniermanagement wird mit Turnierdaten und Setzlisten aus der ClubCloud (früher aus der BillardArea) gespeist. Turnierergebnisse können
      automatisiert in die ClubCloud zurückgeführt werden.</p>
    <p class='text-base text-gray-700 text-xl dark:text-gray-200 leading-relaxed my-4'>
      Carambus unterstützt bei der Übertragung historischer Daten aus der BillardArea in die ClubCloud.</p>

    <!-- International Teaser -->
    <div class="mt-8 mb-6 p-6 bg-gradient-to-r from-primary-500 to-primary-700 rounded-lg shadow-xl hover:shadow-2xl transition-all duration-300 transform hover:scale-105">
      <%= link_to international_path, class: "block no-underline" do %>
        <div class="flex items-center justify-center space-x-4">
          <div class="text-5xl">🌍</div>
          <div class="text-left">
            <h2 class="text-2xl font-bold text-white mb-1">Neu - Billard International</h2>
            <p class="text-primary-100 text-lg">Entdecke Turniere, Videos & Spieler aus der ganzen Welt</p>
          </div>
          <div class="text-3xl text-white">→</div>
        </div>
        <div class="mt-3 text-center">
      <span class="inline-block px-4 py-2 bg-white bg-opacity-20 rounded-full text-white text-sm font-semibold backdrop-blur-sm">
        Über 40.000 Billard-Videos, vorwiegend Karambol
      </span>
        </div>
      <% end %>
    </div>

    <%- unless ApplicationRecord.local_server? %>
      <p class='text-base text-gray-700 text-sm dark:text-gray-200 leading-relaxed my-4'>
        Auf diesem Server werden historische Daten aus verschiedenen Quellen wie BillardArea, ClubCloud, LigaManager und NuLiga gesammelt. Der Server
        dient als Datenquelle für regionale und lokale Carambus-Server. Unter <%= link_to "carambus.de", "https: //carambus.de" %> finden Sie die
        offizielle
        Carambus-Website und unter <%= link_to "nbv.carambus.de", "https://nbv.carambus.de" %> eine NBV-Teilmenge. Weitere Details
        unter <%= mail_to "gernot.ullrich@gmx.de" %>. Im Zweifelsfall finden Sie verbindliche Daten in den angegebenen Quellen.
      </p>
    <%- end %>
  <%- end %>
</div>
