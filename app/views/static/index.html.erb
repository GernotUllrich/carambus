<div class="p-14 w-full m-auto flex items-end flex-col bg-cover h-screen bg-center bg-no-repeat" style="background-image: url('/Karambol.jpg')">
  <% if I18n.locale.to_s == "en" %>
    <%= link_to image_tag("flag_de.png"), { :locale=>'de' } %>

  <% else %>
    <%= link_to image_tag("flag_en.png"), { :locale=>'en' } %>

  <%end%>
  <h1 class="flex mb-2 text-gray-200 "><%= t('welcome_to_carambus') %></h1>
  <p class="mb-6 text-gray-200 leading-normal text-xl"><%= t('carambus_manages') %></p>
  <span>
    <%= link_to "Start", start_path, data: { turbolinks: false }, class: "btn btn-primary lg:mr-4 mr-0 lg:mt-4 mt-2 p-1" %>
    <%= link_to "Intro", intro_path, data: { turbolinks: false }, class: "btn btn-primary lg:mr-4 mr-0 lg:mt-4 mt-2 p-1" %>

  </span>
  <% if false && Rails.env.development? %>
    <div class="flex flex-col items-center md:flex-row">
      <div class="w-full md:w-auto">
        <%= link_to "Configure Jumpstart", jumpstart_path, data: { turbolinks: false }, class: "btn btn-primary lg:mr-4 mr-0 lg:mt-4 mt-2 p-1" %>
      </div>

      <div>
        <span class="hidden md:inline border border-gray-200 h-10 mr-4"></span>
        <%= link_to "Create a User", new_user_registration_path, class: "btn btn-tertiary outline lg:mr-4 mr-0 lg:mt-4 mt-2 p-1" %>
        <%= link_to "Read the Docs", jumpstart.docs_path, target: :_blank, data: { turbolinks: false }, class: "btn btn-tertiary outline lg:mr-4 mr-0 lg:mt-4 mt-2 p-1" %>
      </div>
    </div>
  <% end %>
</div>
