<div class="bg-surface-card dark:bg-gray-800 rounded-card border border-gray-200 dark:border-gray-700 overflow-hidden">
  <% @clubs ||= records %>
  <% @pagy ||= defined?(pagy) ? pagy : nil %>
  <% @clubs.each do |club| %>
    <div class="group flex items-center gap-3 px-4 py-3 border-t border-gray-100 dark:border-gray-700 first:border-t-0 hover:bg-surface-page dark:hover:bg-gray-700/60">
      <div class="flex-1 min-w-0">
        <%= custom_link_to(club.shortname.presence || club.name.presence || "—", club,
              class: "font-medium text-gray-900 dark:text-gray-100 hover:text-primary-600") %>
        <div class="text-xs text-gray-500 dark:text-gray-400 mt-0.5">
          <%# Subzeile = Ort aus der Adresse (PLZ-Zeile), nicht die volle mehrzeilige Adresse/Namenszeile. %>
          <% lines = club.address.to_s.split(/<br>|\n/).map(&:strip).reject(&:blank?) %>
          <%= lines.find { |l| l =~ /\d{5}/ } || lines.last %>
        </div>
      </div>
      <%# Region-Badge nur bei Abweichung: Club-Region ≠ Scope-Region (greift bei Toggle an / global_context). %>
      <% if club.region.present? && club.region_id != current_region_id %>
        <%= region_badge(club.region) %>
      <% end %>
    </div>
  <% end %>
</div>

<%- if current_user&.admin? %>
  <%= form_tag merge_clubs_path, method: :post, class: "mt-4 flex flex-wrap items-center gap-2" do %>
    <%= label_tag "merge" %><%= number_field_tag "merge", nil, placeholder: "master club id", class: "px-4 py-2 rounded-md border border-gray-300 bg-white text-gray-800 placeholder-gray-400 shadow-sm focus:outline-none focus:ring-2 focus:ring-blue-500 dark:bg-gray-800 dark:border-gray-600 dark:text-gray-200 dark:placeholder-gray-400" %>
    <%= label_tag "with duplicates (comma-separated ids)" %><%= text_field_tag "with", nil, placeholder: "slave club id", class: "px-4 py-2 rounded-md border border-gray-300 bg-white text-gray-800 placeholder-gray-400 shadow-sm focus:outline-none focus:ring-2 focus:ring-blue-500 dark:bg-gray-800 dark:border-gray-600 dark:text-gray-200 dark:placeholder-gray-400" %>
    <%= submit_tag "merge and delete slave", class: "btn btn-primary" %>
  <% end %>
<% end %>

<% if @pagy.present? && @pagy.pages > 1 %>
  <div class="text-center my-6">
    <%= pagy_nav(@pagy).html_safe %>
  </div>
<% end %>
