<div class="container mx-auto my-8 px-4">
  <div class="max-w-3xl mx-auto">
    <div class="flex justify-between items-center mb-4">
      <h1 class="h3"><%= custom_link_to 'Tables', tables_path %> > Table #<%= @table.id %></h1>
      <%= button_to( 'Edit', edit_table_path(@table), method: :get, disabled: !current_user&.admin?, class: "btn btn-link") %>
      <%= custom_link_to( 'Löschen', table_path(@table), method: :delete, class: "btn btn-link") %>
    </div>

    <dl class="grid grid-cols-2 md:grid-cols-3 gap-x-6 gap-y-4 bg-surface-card dark:bg-gray-800 rounded-card border border-gray-200 dark:border-gray-700 p-6 text-gray-900 dark:text-gray-100">
      <div class="min-w-0">
        <dt class="text-xs uppercase tracking-wide text-gray-400 dark:text-gray-500 font-normal mb-0.5">Location</dt>
        <dd class="break-words"><%= custom_link_to @table.location.display_address, location_path(@table.location) if @table.present? %></dd>
      </div>
      <div class="min-w-0">
        <dt class="text-xs uppercase tracking-wide text-gray-400 dark:text-gray-500 font-normal mb-0.5">Table kind</dt>
        <dd class="break-words"><%= custom_link_to @table.table_kind.name, table_kind_path(@table.table_kind) if @table.table_kind.present? %></dd>
      </div>
      <div class="min-w-0">
        <dt class="text-xs uppercase tracking-wide text-gray-400 dark:text-gray-500 font-normal mb-0.5">Name</dt>
        <dd class="break-words"><%= @table.name %></dd>
      </div>
      <div class="min-w-0">
        <dt class="text-xs uppercase tracking-wide text-gray-400 dark:text-gray-500 font-normal mb-0.5">Ip address</dt>
        <dd class="break-words"><%= @table.ip_address %></dd>
      </div>
      <div class="min-w-0 col-span-full">
        <dt class="text-xs uppercase tracking-wide text-gray-400 dark:text-gray-500 font-normal mb-0.5">Data</dt>
        <dd class="break-words"><%= pretty_json(@table.data) %></dd>
      </div>
    </dl>
  </div>
</div>
