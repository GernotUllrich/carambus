<%= form_with(model: tournament_monitor) do |form| %>
  <%= render "error_messages", resource: form.object %>

  <div class="form-group">
    <%= form.label :tournament_id %>
    <%= form.number_field :tournament_id, class: "form-control" %>
  </div>

  <div class="form-group">
    <%= form.label :data %>
    <%= form.text_area :data, class: "form-control" %>
  </div>

  <div class="form-group">
    <%= form.label :state %>
    <%= form.text_field :state, class: "form-control" %>
  </div>

  <div class="form-group">
    <%= form.label :innings_goal %>
    <%= form.number_field :innings_goal, class: "form-control" %>
  </div>

  <div class="form-group">
    <%= form.label :timeouts %>
    <%= form.select :timeouts, options_for_select([0, 1, 2, 3, 4, 5], @timeouts), class: "form-control" %>
  </div>

  <div class="form-group">
    <%= form.label :timeout %>
    <%= form.select :timeout, options_for_select([["-", 0], 30, 40, 45], @timeout), class: "form-control" %>
  </div>

  <div class="form-group">
    <%= form.label :balls_goal %>
    <%= form.number_field :balls_goal, class: "form-control" %>
  </div>

  <%# Phase 38.7 Plan 12 (Gap-04): TournamentMonitor startup-form tiebreak override.
      Persists onto Tournament.data['tiebreak_on_draw'] (resolver Level 1) when the
      form submits via UPDATE — NOT onto TournamentMonitor.data (different model).
      On CREATE the param is intentionally ignored (auth surface — :create is not
      director-gated; see TournamentMonitorsController#create comment). The
      checkbox still renders in `new` for UX continuity. Default value comes from
      @tiebreak_on_draw_default (set in controller new/edit actions: reads
      Tournament.data first, then TournamentPlan.executor_params['g1'] Level 2,
      then false). Operator's pick wins over plan default once they edit the
      monitor. %>
  <div class="form-group">
    <%= label_tag :tournament_tiebreak_on_draw, t("tournament_monitors.form.tiebreak_on_draw") %>
    <%= hidden_field_tag :tournament_tiebreak_on_draw, "0" %>
    <%= check_box_tag :tournament_tiebreak_on_draw, "1", @tiebreak_on_draw_default, class: "form-control" %>
  </div>

  <div class="form-group flex justify-between">
    <%= form.button class: "btn btn-primary" %>

    <% if form.object.persisted? %>
      <%= custom_link_to 'Delete', form.object, class: "btn btn-danger outline", method: :delete, data: { remote: true, confirm: "Are you sure?" } %>
    <% end %>
  </div>
<% end %>
