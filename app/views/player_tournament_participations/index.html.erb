<p id="notice"><%= notice %></p>

<h1>Listing Player Tournament Participations</h1>

<table>
  <thead>
    <tr>
      <th>Player</th>
      <th>Tournament</th>
      <th>Data</th>
      <th colspan="3"></th>
    </tr>
  </thead>

  <tbody>
    <% @player_tournament_participations.each do |player_tournament_participation| %>
      <tr>
        <td><%= player_tournament_participation.player_id %></td>
        <td><%= player_tournament_participation.tournament_id %></td>
        <td><%= player_tournament_participation.data %></td>
        <td><%= link_to 'Show', player_tournament_participation %></td>
        <td><%= link_to 'Edit', edit_player_tournament_participation_path(player_tournament_participation) %></td>
        <td><%= link_to 'Destroy', player_tournament_participation, method: :delete, data: { confirm: 'Are you sure?' } %></td>
      </tr>
    <% end %>
  </tbody>
</table>

<br>

<%= link_to 'New Player tournament participation', new_player_tournament_participation_path %>
