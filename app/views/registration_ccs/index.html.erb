<div class="container mx-auto my-8 px-4">
  <div class="flex justify-between items-center mb-4">
    <h1 class="h3">Registration Ccs</h1>

    <% if @registration_ccs.any? %>
      <%= link_to 'New Registration Cc', new_registration_cc_path, class: "btn btn-primary" %>
    <% end %>
  </div>

  <% if @registration_ccs.any? %>
    <div class="bg-white rounded shadow table-responsive">
      <table class="table">
        <thead>
          <tr>
            <th class="p-3 uppercase text-left text-xs"><%= sortable @registration_ccs, :registration_list_cc_id, 'Registration list cc', class: 'text-gray-700' %></th>
            <th class="p-3 uppercase text-left text-xs"><%= sortable @registration_ccs, :player_id, 'Player', class: 'text-gray-700' %></th>
            <th class="p-3 uppercase text-left text-xs"><%= sortable @registration_ccs, :status, 'Status', class: 'text-gray-700' %></th>
            <th class="p-3 uppercase text-left text-xs text-gray-700 w-20">Actions</th>
          </tr>
        </thead>

        <tbody>
        <% @registration_ccs.each do |registration_cc| %>
          <tr class="group border-t border-gray-400 hover:bg-gray-100">
                      <td class="p-3"><%= registration_cc.registration_list_cc_id %></td>
                      <td class="p-3"><%= registration_cc.player_id %></td>
                      <td class="p-3"><%= registration_cc.status %></td>
          
            <td>
              <%= link_to "View", registration_cc, class: "btn btn-link no-underline" %>
            </td>
          </tr>
        <% end %>
        </tbody>
      </table>
    </div>

    <% if @pagy.pages > 1 %>
      <div class="text-center my-6">
        <%== pagy_nav(@pagy) %>
      </div>
    <% end %>

  <% else %>
    <div class="bg-white rounded shadow flex flex-col items-center justify-between p-8 lg:flex-row">
      <%= image_tag "empty.svg", class: "mb-4 lg:w-1/2" %>
      <div class="flex-1 text-center">
        <p class="h3 mb-4">Create your first Registration Cc</p>
        <%= link_to 'New Registration Cc', new_registration_cc_path, class: "btn btn-primary" %>
      </div>
    </div>
  <% end %>
</div>
