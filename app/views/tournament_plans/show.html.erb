<%# 14-09 (H29): auf die generische Detail-Card migriert. executor_params (JSON-Text) via details-Slot
    als pretty_json (volle Breite) — aus dem Grid ausgenommen, damit kein roher Einzeiler entsteht. %>
<% details = capture do %>
  <% if @tournament_plan.executor_params.present? %>
    <div class="min-w-0">
      <h5 class="text-xs uppercase tracking-wide text-gray-400 dark:text-gray-500 font-normal mb-0.5"><%= TournamentPlan.human_attribute_name(:executor_params) %></h5>
      <%= pretty_json(@tournament_plan.executor_params) %>
    </div>
  <% end %>
<% end %>
<%= render "shared/detail_card", record: @tournament_plan, except: %w[executor_params], details: details %>
