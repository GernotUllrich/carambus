<h1>Listing TournamentPlans</h1>

<table>
  <thead>
    <tr>
      <th>Name</th>
      <th>Rulesystem</th>
      <th>Formula</th>
      <th>Players</th>
      <th>Groups</th>
      <th>Tables</th>
      <th colspan="3"></th>
    </tr>
  </thead>

  <tbody>
    <% @tournament_plans.order(:name).each do |tournament_plan| %>
      <tr>
        <td><%= tournament_plan.name %></td>
        <td><%= tournament_plan.rulesystem %></td>
        <td><%= tournament_plan.executor_params %></td>
        <td><%= tournament_plan.players %></td>
        <td><%= tournament_plan.ngroups %></td>
        <td><%= tournament_plan.tables %></td>
        <td><%= link_to image_tag("ansehen.gif", :width => 26, :height => 22, :border => 0), tournament_plan %></td>
        <td><%= link_to image_tag("bearbeiten.gif", :width => 26, :height => 22, :border => 0), edit_tournament_plan_path(tournament_plan) %></td>
        <td><%= link_to image_tag("loeschen.gif", :width => 26, :height => 22, :border => 0), tournament_plan, method: :delete, data: { confirm: 'Are you sure?' } %></td>
      </tr>
    <% end %>
  </tbody>
</table>

<br>

<%= link_to 'New TournamentPlan', new_tournament_plan_path %>
