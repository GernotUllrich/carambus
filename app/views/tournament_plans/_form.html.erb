<style>
    textarea {
        width: 100%;
        height: 80px;
    }
</style>
<%= form_for(@tournament_plan) do |f| %>
  <% if @tournament_plan.errors.any? %>
    <div id="error_explanation">
      <h2><%= pluralize(@tournament_plan.errors.count, "error") %> prohibited this tournament_plan from being saved:</h2>

      <ul>
      <% @tournament_plan.errors.full_messages.each do |message| %>
        <li><%= message %></li>
      <% end %>
      </ul>
    </div>
  <% end %>

  <div class="field">
    <%= f.label :name %><br>
    <%= f.text_field :name %>
