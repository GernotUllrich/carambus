  </div>
  <div class="field">
    <%= f.label :executor_class %><br>
    <%= f.text_field :executor_class %>
  </div>
  <div class="field">
    <%= f.label :executor_params %><br>
    <%= f.text_area :executor_params %>
  </div>
  <div class="field">
    <%= f.label :players %><br>
    <%= f.number_field :players %>
  </div>
  <div class="field">
    <%= f.label :ngroups %><br>
    <%= f.number_field :ngroups %>
  </div>
