<%#
# Navigation

This partial is used to display the navigation in Administrate.
By default, the navigation contains navigation links
for all resources in the admin dashboard,
as defined by the routes in the `admin/` namespace
%>

<%# Admin-Sidebar: an die User-Sidebar angelehnt, aber bewusst distinkt (ADMIN-Marker + %>
<%# primary-Akzentleiste), damit der Admin-Kontext sofort ablesbar ist. %>
<nav class="admin-nav w-64 shrink-0 flex flex-col bg-surface-sidebar dark:bg-gray-800 border-r-2 border-primary-600 dark:border-primary-500 min-h-screen">
  <%# Kopf: Admin-Marker %>
  <div class="flex items-center gap-2 px-4 py-4 border-b border-gray-200 dark:border-gray-700">
    <span class="inline-flex items-center rounded-pill bg-primary-600 text-white text-xs font-bold uppercase tracking-wide px-2 py-1">Admin</span>
    <span class="font-bold text-gray-900 dark:text-gray-100"><%= Rails.application.class.module_parent_name.titlecase %></span>
  </div>

  <%# Zurück zur App — prominent %>
  <div class="px-3 pt-3">
    <%= link_to root_path, class: "flex items-center gap-2 px-3 py-2 rounded-lg text-sm font-medium text-primary-700 dark:text-primary-300 bg-primary-50 dark:bg-gray-700 hover:bg-primary-100 dark:hover:bg-gray-600 transition-colors" do %>
      <svg xmlns="http://www.w3.org/2000/svg" class="w-4 h-4" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
        <path stroke-linecap="round" stroke-linejoin="round" d="M10 19l-7-7m0 0l7-7m-7 7h18" />
      </svg>
      <%= t("administrate.navigation.back_to_app", default: "Zurück zur App") %>
    <% end %>
  </div>

  <%# Ressourcen (dynamisch aus Administrate) %>
  <div class="flex-1 overflow-y-auto px-3 py-3 space-y-0.5">
    <% resource_link = "block px-3 py-2 rounded-lg text-sm text-gray-700 dark:text-gray-200 hover:bg-gray-200 dark:hover:bg-gray-700 transition-colors" %>
    <% resource_link_active = "block px-3 py-2 rounded-lg text-sm font-semibold text-primary-700 dark:text-primary-300 bg-primary-50 dark:bg-gray-700" %>

    <% Administrate::Namespace.new(namespace).resources_with_index_route.each do |resource| %>
      <% begin %>
        <%= link_to(
          display_resource_name(resource),
          resource_index_route(resource),
          class: (nav_link_state(resource).to_s == "active" ? resource_link_active : resource_link)
        ) if accessible_action?(model_from_resource(resource), :index) %>
      <% rescue NameError => e %>
        <%# Skip resources without dashboards %>
      <% end %>
    <% end %>

    <%# Custom non-Administrate resources — dezent hervorgehoben (Tokens statt greller Inline-Farben) %>
    <div class="mt-3 pt-3 border-t border-gray-200 dark:border-gray-700 space-y-0.5">
      <div class="px-3 pb-1 text-xs font-bold uppercase tracking-wide text-gray-400 dark:text-gray-500">Werkzeuge</div>
      <%= link_to(
        "Duplikate",
        admin_player_duplicates_path,
        class: (controller_name == "player_duplicates" ? resource_link_active : resource_link)
      ) %>
      <%= link_to(
        "Unvollständige Datensätze",
        admin_incomplete_records_path,
        class: (controller_name == "incomplete_records" ? resource_link_active : resource_link)
      ) %>
    </div>
  </div>
</nav>
