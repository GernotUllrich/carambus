<% content_for :javascript_code do %>
  <script>
      $(document).ready(function () {
          $('#games').DataTable({
                  "stateSave": true,
              dom: 'Bfrtip',
              buttons: [
                  'copy', {
                      extend: 'csvHtml5',
                      title: 'Games'
                  }, {
                      extend: 'excelHtml5',
                      title: 'Games'
                  }, {
                      extend: 'pdfHtml5',
                      title: 'Games'
                  }, {
                      extend: 'print',
                      title: 'Games'
                  }
              ],
                  "sPaginationType": "full_numbers",
                  "bJQueryUI": true,
                  "aLengthMenu": [
                      [10, 50],
                      [10, 50]
                  ],
                  "iDisplayLength": 20,

                  "aaSorting": [
                      [0, "desc"]
                  ],
                  "aoColumns": [
                      null,
                      null,
                      null,
                      {"bSortable": false},
                  ],
                  oSearch: {"sSearch": "<%= params[:sSearch].andand.html_safe %>"},
                  bProcessing: true,
                  bServerSide: true,
                  sAjaxSource: $('#games').data('source')
              }
          );
      });
  </script>
<% end %>
<style>
    body {
        margin: 0;
        padding: 0;
    }

    th, td {
        padding-left: 5px;
    }
</style>
<h1>Listing Games</h1>
<h2> => <%= link_to "Listing Game Participations", game_participations_path %></h2>
<table id="games" data-source="<%= games_url(format: 'json') %>" width="100%" style="margin: 0px; width: 100%;" data-turbolinks="false">
  <thead>
  <tr>
    <th colspan=<%= Game::COLUMN_NAMES.keys.count %>><%= link_to "Listing Game Participations", game_participations_path(isearch: params[:iSearch]) %></th>
  </tr>
  <tr>
    <% Game::COLUMN_NAMES.keys.each do |column_name| %>
      <!--      TODO FILTERS-->
      <th><%= column_name %></th>
    <% end %>
    <th width="100px"></th>
  </tr>
  </thead>

  <tbody>
  </tbody>
</table>

<br>

<%= link_to 'New Game', new_game_path %>
