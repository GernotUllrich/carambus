<div class="container mx-auto my-8 px-4">
  <div class="max-w-3xl mx-auto">
    <div class="flex flex-wrap justify-between items-start gap-2 mb-4">
      <div class="min-w-0">
        <h1 class="text-xl font-semibold text-gray-900 dark:text-gray-100 break-words">
          <%= custom_link_to t('player.index.players'), players_path, class: "text-primary-600 hover:text-primary-700" %>
          <span class="text-gray-400 dark:text-gray-500">&gt;</span> <%= @player.fullname %>
        </h1>
      </div>
      <%= button_to('Edit', edit_player_path(@player), method: :get, disabled: !current_user&.admin?, class: "btn btn-link shrink-0") %>
    </div>

    <%- club = @player.season_participations.where(season: Season.current_season).first.andand.club %>
    <%# Detail-Card-Muster (Phase 6): Token-Card + Label/Wert-Grid — Referenz tournaments/_show.html.erb. %>
    <div class="grid grid-cols-2 md:grid-cols-3 gap-x-6 gap-y-4 bg-surface-card dark:bg-gray-800 rounded-card border border-gray-200 dark:border-gray-700 p-6 text-gray-900 dark:text-gray-100">
      <div class="min-w-0">
        <h5 class="text-xs uppercase tracking-wide text-gray-400 dark:text-gray-500 font-normal mb-0.5"><%= t('player.club_id') %></h5>
        <%= custom_link_to club.shortname, club_path(club) if club.present? %>
      </div>
      <%- if @player.is_a? Team %>
        <div class="min-w-0">
          <h5 class="text-xs uppercase tracking-wide text-gray-400 dark:text-gray-500 font-normal mb-0.5"><%= t('player.fullname') %></h5>
          <%= @player.fullname %>
        </div>
        <div class="min-w-0">
          <h5 class="text-xs uppercase tracking-wide text-gray-400 dark:text-gray-500 font-normal mb-0.5"><%= t('player.data') %></h5>
          <%= @player.data.inspect %>
        </div>
      <%- else %>
        <div class="min-w-0">
          <h5 class="text-xs uppercase tracking-wide text-gray-400 dark:text-gray-500 font-normal mb-0.5"><%= t('player.lastname') %></h5>
          <%= @player.lastname %>
        </div>
        <div class="min-w-0">
          <h5 class="text-xs uppercase tracking-wide text-gray-400 dark:text-gray-500 font-normal mb-0.5"><%= t('player.nickname') %></h5>
          <%= @player.nickname %>
        </div>
        <div class="min-w-0">
          <h5 class="text-xs uppercase tracking-wide text-gray-400 dark:text-gray-500 font-normal mb-0.5"><%= t('player.firstname') %></h5>
          <%= @player.firstname %>
        </div>
        <div class="min-w-0">
          <h5 class="text-xs uppercase tracking-wide text-gray-400 dark:text-gray-500 font-normal mb-0.5"><%= t('player.title') %></h5>
          <%= @player.title %>
        </div>
        <div class="min-w-0">
          <h5 class="text-xs uppercase tracking-wide text-gray-400 dark:text-gray-500 font-normal mb-0.5"><%= t('player.source_url') %></h5>
          <%= link_to_if @player.source_url.present?, @player.source_url.present? ? URI.parse(@player.source_url).host : "", @player.source_url, target: :_blank %>
        </div>
        <div class="min-w-0">
          <h5 class="text-xs uppercase tracking-wide text-gray-400 dark:text-gray-500 font-normal mb-0.5"><%= t('player.last_sync') %></h5>
          <%= @player.sync_date.andand.to_date %>
        </div>
      <%- end %>
    </div>
  </div>
</div>
<div class="container mx-auto px-4">
  <div class="max-w-4xl mx-auto mt-6 bg-surface-card dark:bg-gray-800 rounded-card border border-gray-200 dark:border-gray-700 p-6 text-gray-900 dark:text-gray-100">
    <h3 class="text-lg font-semibold text-gray-900 dark:text-gray-100 mb-3"><%= t('player_ranking.index.player_rankings') %></h3>
    <ul class="space-y-3">
      <%- Discipline.joins(:player_rankings => :player).where(players: { id: @player.id }).order("disciplines.name desc").uniq.each do |dis| %>
        <li>
          <div class="font-medium"><%= dis.name %></div>
          <%- dis.player_rankings.joins(:season).joins(:player).where(players: { id: @player.id }).order("seasons.name asc").each do |ranking| %>
            <%- next if ranking.btg.blank? %>
            <div class="pl-6 flex flex-row gap-4 text-sm text-gray-600 dark:text-gray-300">
              <div class="w-1/6"><%= "#{ranking.season.name}: " %></div>
              <div class="w-1/6"><%= "\##{ranking.rank} " %></div>
              <div class="flex-1"><%= "BTG:#{ranking.btg}" %></div>
            </div>
          <%- end %>
        </li>
      <%- end %>
    </ul>
  </div>
</div>

<div class="container mx-auto px-4">
  <div class="max-w-4xl mx-auto mt-6 bg-surface-card dark:bg-gray-800 rounded-card border border-gray-200 dark:border-gray-700 p-6 text-gray-900 dark:text-gray-100">
    <h3 class="text-lg font-semibold text-gray-900 dark:text-gray-100 mb-3"><%= t('seeding.index.seedings') %></h3>
    <div class="overflow-x-auto rounded shadow ring-1 ring-slate-200 dark:ring-slate-800">
      <table class="min-w-full text-sm">
        <thead class="bg-gray-100/80 border-b border-slate-200 text-slate-500 dark:bg-slate-800 dark:border-slate-700 dark:text-slate-400">
        <tr>
          <th class="p-3 text-left font-semibold"><%= t('home.index.season') %></th>
          <th class="p-3 text-left font-semibold"><%= t('home.index.region') %></th>
          <th class="p-3 text-left font-semibold"><%= t('home.index.tournament') %></th>
          <th class="p-3 text-left font-semibold"><%= t('home.index.results') %></th>
        </tr>
        </thead>
        <tbody>
        <% @player.seedings.where("seedings.id < #{Seeding::MIN_ID}").order("seedings.id desc").each do |seeding| %>
          <%- tournament = seeding.tournament %>
          <%- next if tournament.blank? %>
          <%- if tournament.is_a?(Tournament) %>
            <tr class="border-b border-slate-100 dark:border-slate-800">
              <td class="p-3"><%= custom_link_to seeding.tournament.season.name, season_path(seeding.tournament.season) %></td>
              <td class="p-3"><%= custom_link_to seeding.tournament.organizer.shortname, region_path(seeding.tournament.organizer) %></td>
              <td class="p-3"><%= custom_link_to seeding.tournament.title, tournament_path(seeding.tournament) %></td>
              <td class="p-3"><%= custom_link_to(Seeding.result_display(seeding), seeding_path(seeding)) %></td>
            </tr>
          <%- elsif tournament.is_a?(Party) %>
            <tr class="border-b border-slate-100 dark:border-slate-800">
              <td class="p-3"><%= custom_link_to seeding.tournament.league.season.name, season_path(seeding.tournament.league.season) %></td>
              <td class="p-3"><%= custom_link_to seeding.tournament.league.organizer.shortname, region_path(seeding.tournament.league.organizer) %></td>
              <td class="p-3"><%= custom_link_to seeding.tournament.league.name, league_path(seeding.tournament.league) %></td>
              <td class="p-3"><%= custom_link_to(Seeding.result_display(seeding), seeding_path(seeding)) %></td>
            </tr>
          <%- end %>
        <% end %>
        </tbody>
      </table>
    </div>
  </div>
</div>

<div class="container mx-auto px-4">
  <div class="max-w-4xl mx-auto mt-6 bg-surface-card dark:bg-gray-800 rounded-card border border-gray-200 dark:border-gray-700 p-6 text-gray-900 dark:text-gray-100">
    <h3 class="text-lg font-semibold text-gray-900 dark:text-gray-100 mb-3">Seasons</h3>
    <div class="overflow-x-auto rounded shadow ring-1 ring-slate-200 dark:ring-slate-800">
      <table class="min-w-full text-sm">
        <thead class="bg-gray-100/80 border-b border-slate-200 text-slate-500 dark:bg-slate-800 dark:border-slate-700 dark:text-slate-400">
        <tr>
          <th class="p-3 text-left font-semibold">Season</th>
          <th class="p-3 text-left font-semibold">Club</th>
        </tr>
        </thead>
        <tbody>
        <% SeasonParticipation.joins(:club).joins(:player).joins(:season).where(players: { id: @player.id }).order("season_participations.season_id desc").uniq.each do |season_participation| %>
          <tr class="border-b border-slate-100 dark:border-slate-800">
            <td class="p-3"><%= custom_link_to season_participation.season.name, season_path(season_participation.season) %></td>
            <td class="p-3"><%= custom_link_to season_participation.club.shortname, club_path(season_participation.club) %></td>
          </tr>
        <% end %>
        </tbody>
      </table>
    </div>
  </div>
</div>
