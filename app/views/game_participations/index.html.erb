<% content_for :javascript_in_head do %>
  <script>
      $(document).ready(function () {
          $('#game_participations').dataTable({
                  "stateSave": true,
              dom: 'Bfrtip',
              buttons: [
                  'copy', {
                      extend: 'csvHtml5',
                      title: 'GameParticipations'
                  }, {
                      extend: 'excelHtml5',
                      title: 'GameParticipations'
                  }, {
                      extend: 'pdfHtml5',
                      title: 'GameParticipations'
                  }, {
                      extend: 'print',
                      title: 'GameParticipations'
                  }
              ],
                  "sPaginationType": "full_numbers",
                  "bJQueryUI": true,
                  "aLengthMenu": [
                      [10, 50],
                      [10, 50]
                  ],
                  "iDisplayLength": 20,

                  "aaSorting": [
                      [0, "desc"]
                  ],
                  "aoColumns": [
                      null,
                      null,
                      null,
                      null,
                      null,
                      null,
                      null,
                      null,
                      null,
                      null,
                      null,
                      null,
                      null,
                      {"bSortable": false},
                  ],
                  oSearch: {"sSearch": "<%= params[:sSearch].andand.html_safe %>"},
                  bProcessing: true,
                  bServerSide: true,
                  sAjaxSource: $('#game_participations').data('source')
              }
          );
      });
  </script>
<% end %>
<style>
    body {
        margin: 0;
        padding: 0;
    }

    th, td {
        padding-left: 5px;
    }
</style>

<h1>Listing Game Participations</h1>

<table id="game_participations" data-source="<%= game_participations_url(format: 'json') %>" width="100%" style="margin: 0px; width: 100%;" data-turbolinks="false">
  <thead>
  <tr>
    <% GameParticipation::COLUMN_NAMES.keys.each do |column_name| %>
      <!--      TODO FILTERS-->
      <th><%= column_name %></th>
    <% end %>
    <th width="100px"></th>
  </tr>
  </thead>

  <tbody>
  </tbody>
</table>
<br>

<%= link_to 'New Game participation', new_game_participation_path %>
