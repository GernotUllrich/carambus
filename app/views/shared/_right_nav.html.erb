<%# Place any links for the RIGHT side of the nav bar here. Be sure to add class: "nav-link" to each item for proper spacing. %>
<% if I18n.locale.to_s == "en" %>
  <%= link_to image_tag("flag_de.png"), { :locale=>'de' } %>

<% else %>
  <%= link_to image_tag("flag_en.png"), { :locale=>'en' } %>

<%end%>
<% if Jumpstart.config.payments_enabled? && (!user_signed_in? || current_account_admin?) && not_subscribed? %>
  <%= nav_link_to t(".pricing"), pricing_path, class: "nav-link" %>
<% end %>

<%= nav_link_to content_tag(:span, t(".announcements")), announcements_path, class: ["nav-link", unread_announcements_class(current_user)] %>
