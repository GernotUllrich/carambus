<%= form_with(model: party_tournament) do |form| %>
  <%= render "shared/error_messages", resource: form.object %>

  <div class="form-group">
    <%= form.label :party_id %>
    <%= form.number_field :party_id, class: "form-control" %>
  </div>

  <div class="form-group">
    <%= form.label :tournament_id %>
    <%= form.number_field :tournament_id, class: "form-control" %>
  </div>

  <div class="form-group">
    <%= form.label :position %>
    <%= form.number_field :position, class: "form-control" %>
  </div>

  <div class="form-group flex justify-between">
    <%= form.button class: "btn btn-primary" if current_user.andand.admin? %>

    <% if form.object.persisted? %>
      <%= link_to 'Delete', form.object, class: "btn btn-danger outline", method: :delete, data: { remote: true, confirm: "Are you sure?" } %>
    <% end %>
  </div>
<% end %>
