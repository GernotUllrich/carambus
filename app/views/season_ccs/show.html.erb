<div class="container mx-auto my-8 px-4">
  <div class="max-w-3xl mx-auto">
    <div class="flex justify-between items-center mb-4">
      <h1 class="h3"><%= link_to 'Season Ccs', season_ccs_path %> > Season Cc #<%= @season_cc.id %></h1>
      <%= link_to 'Edit', edit_season_cc_path(@season_cc), class: "btn btn-link" %>
    </div>

    <div class="bg-white rounded shadow p-8">
            <div class="mb-4">
        <h5>Cc</h5>
        <%= @season_cc.cc_id %>
      </div>
            <div class="mb-4">
        <h5>Name</h5>
        <%= @season_cc.name %>
      </div>
            <div class="mb-4">
        <h5>Season</h5>
        <%= @season_cc.season_id %>
      </div>
            <div class="mb-4">
        <h5>Competition cc</h5>
        <%= @season_cc.competition_cc_id %>
      </div>
            <div class="mb-4">
        <h5>Context</h5>
        <%= @season_cc.context %>
      </div>
          </div>
  </div>
</div>
