<%# 10-04: generische Detail-Card (09-01) + Leagues-Sub-Tabelle im details-Slot. %>
<% details_html = capture do %>
  <% if @league_ccs.any? %>
    <h3 class="text-lg font-semibold text-gray-900 dark:text-gray-100 mb-3">Leagues</h3>
    <div id="table_wrapper">
      <%= render partial: 'league_ccs/league_ccs_table', locals: { records: @league_ccs } %>
    </div>
  <% end %>
<% end %>
<%= render "shared/detail_card",
      record: @season_cc,
      index_path: season_ccs_path,
      index_label: "Season Ccs",
      details: (details_html.to_s.strip.present? ? details_html : nil) %>
