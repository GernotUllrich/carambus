<%# 10-04: generische Detail-Card (09-01) + Parties-Sub-Tabelle im details-Slot. %>
<% details_html = capture do %>
  <% if @party_ccs.any? %>
    <h3 class="text-lg font-semibold text-gray-900 dark:text-gray-100 mb-3">Parties</h3>
    <div id="table_wrapper">
      <%= render partial: 'party_ccs/party_ccs_table', locals: { records: @party_ccs } %>
    </div>
  <% end %>
<% end %>
<%= render "shared/detail_card",
      record: @league_team_cc,
      index_path: league_team_ccs_path,
      index_label: "League Team Ccs",
      details: (details_html.to_s.strip.present? ? details_html : nil) %>
