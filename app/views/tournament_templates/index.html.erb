<h1>Listing Tournament Templates</h1>

<table style="margin: 0px; width: 70%;">
  <thead>
    <tr>
      <th>Name</th>
      <th>Discipline</th>
      <th>Points</th>
      <th>Innings</th>
      <%- (1..12).each do |i|   -%>
          <th><%= i %> P.</th>
      <%- end -%>
      <th colspan="3"></th>
    </tr>
  </thead>

  <tbody>
    <% @tournament_templates.includes(:discipline).order(:created_at).each do |tournament_template| %>
      <tr>
        <td><%= tournament_template.name %></td>
        <td><%= "#{tournament_template.discipline.name}" if tournament_template.discipline.present? %></td>
        <td><%= tournament_template.points %></td>
        <td><%= tournament_template.innings %></td>
        <%- (1..12).each do |i|   %>
          <td><%= "x" %></td>
        <%- end -%>
        <td>
          <%= link_to image_tag("ansehen.gif", :width => 26, :height => 22, :border => 0), tournament_template %>
          <%= link_to image_tag("bearbeiten.gif", :width => 26, :height => 22, :border => 0), edit_tournament_template_path(tournament_template) %>
          <%= link_to image_tag("loeschen.gif", :width => 26, :height => 22, :border => 0), tournament_template, method: :delete, data: { confirm: 'Are you sure?' } %>
        </td>
      </tr>
    <% end %>
  </tbody>
</table>

<br>

<%= link_to 'New Tournament template', new_tournament_template_path %>
