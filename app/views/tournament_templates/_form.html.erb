<%= form_for(@tournament_template) do |f| %>
  <% if @tournament_template.errors.any? %>
    <div id="error_explanation">
      <h2><%= pluralize(@tournament_template.errors.count, "error") %> prohibited this tournament_template from being saved:</h2>

      <ul>
      <% @tournament_template.errors.full_messages.each do |message| %>
        <li><%= message %></li>
      <% end %>
      </ul>
    </div>
  <% end %>

  <div class="field">
    <%= f.label :name %><br>
    <%= f.text_field :name %>
  </div>
  <div class="field">
    <%= f.label :discipline_id %><br>
    <%= f.select :discipline_id, options_for_select(Discipline.order(:name).all.map{|d| ["#{d.name} - #{d.table_size}", d.id]}) %>
  </div>
  <div class="field">
    <%= f.label :points %><br>
    <%= f.number_field :points %>
  </div>
  <div class="field">
    <%= f.label :innings %><br>
    <%= f.number_field :innings %>
  </div>
  <div class="actions">
    <%= f.submit %>
  </div>
<% end %>
