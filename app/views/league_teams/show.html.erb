<div class="container mx-auto my-8 px-4">
  <div class="max-w-3xl mx-auto">
    <div class="flex justify-between items-center mb-4">
      <h1 class="h3"><%= custom_link_to 'League Teams', league_teams_path %> > League Team #<%= @league_team.id %></h1>
      <%= custom_link_to 'Edit', edit_league_team_path(@league_team), class: "btn btn-link" %>
    </div>

    <dl class="grid grid-cols-2 md:grid-cols-3 gap-x-6 gap-y-4 bg-surface-card dark:bg-gray-800 rounded-card border border-gray-200 dark:border-gray-700 p-6 text-gray-900 dark:text-gray-100">
      <div class="min-w-0">
        <dt class="text-xs uppercase tracking-wide text-gray-400 dark:text-gray-500 font-normal mb-0.5">Name</dt>
        <dd class="break-words"><%= @league_team.name %></dd>
      </div>
      <div class="min-w-0">
        <dt class="text-xs uppercase tracking-wide text-gray-400 dark:text-gray-500 font-normal mb-0.5">Shortname</dt>
        <dd class="break-words"><%= @league_team.shortname %></dd>
      </div>
      <div class="min-w-0">
        <dt class="text-xs uppercase tracking-wide text-gray-400 dark:text-gray-500 font-normal mb-0.5">League</dt>
        <dd class="break-words"><%= custom_link_to @league_team.league.name, league_path(@league_team.league) %></dd>
      </div>
      <div class="min-w-0">
        <dt class="text-xs uppercase tracking-wide text-gray-400 dark:text-gray-500 font-normal mb-0.5">Club</dt>
        <dd class="break-words"><%= custom_link_to @league_team.club.shortname, club_path(@league_team.club) if @league_team.club.present? %></dd>
      </div>
    </dl>
  </div>
  <% if @parties.any? %>
    <h3> Parties</h3>
    <div id="table_wrapper text-base">
      <%= render partial: 'parties/parties_table', locals: { from_index: false, pagy: nil, model_class: Party, records: @parties } %>
    </div>
  <% end %>
</div>
<div class="container mx-auto my-8 px-4">
  <h3><%= custom_link_to "=> Mitglieder", seedings_path(sSearch: "league_team_id:#{@league_team.id}") %></h3>
</div>
