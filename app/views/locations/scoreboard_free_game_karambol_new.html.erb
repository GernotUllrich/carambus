            maxval: 9999999,
            displays: ["keins"] + Discipline::KARAMBOL_POINTS_MAP,
            cols: 8,
            increment: 5
          }
          %>
          <%= render partial: "radio_select", locals: {
            table: table,
            show: "parameters == 1",
            header: "Punktziel (A)",
            varname: "balls_goal_a",
            values: ["0"] + Discipline::KARAMBOL_POINTS_MAP,
            maxval: 9999999,
            displays: ["keins"] + Discipline::KARAMBOL_POINTS_MAP,
