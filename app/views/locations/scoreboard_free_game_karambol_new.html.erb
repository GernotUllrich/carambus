                <span x-text="bk_balls_goal"></span>
              </div>
              <%# For BK-2 / BK-2plus / BK-2kombi: selectable dropdown %>
              <select x-show="!is_bk_fixed_goal" x-model.number="bk_balls_goal"
                      class="px-3 py-2 border rounded text-1-5vw text-gray-900">
                <template x-for="choice in bk_ballziel_choices" :key="choice">
                  <option :value="choice" x-text="choice"></option>
                </template>
              </select>
