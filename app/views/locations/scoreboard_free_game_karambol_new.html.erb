<style>
    .responsive-svg {
        width: 100%;
        height: auto;
    }
</style>
<!--<script defer src="https://cdn.jsdelivr.net/gh/alpinejs/alpine@v2.x.x/dist/alpine.min.js"></script>-->
<script defer src="/alpine.min.js"></script>
<script src="/onscreen-keyboard.js?v=<%= Time.current.to_i %>"></script>
<script type="text/javascript">

  function players_mode() {
    set_players_modal();
  }

  function new_player_mode() {
    set_new_player_modal();
  }

  function set_checked_player(ab, ix, val) {
    document.getElementById("player" + ab + "_" + ix).checked = true
    document.getElementById("player_" + ab + "_id").value = val
  }

  function set_players_modal() {
    document.getElementById("modal-players").classList.toggle("hidden");
    document.getElementById("modal-players" + "-bg").classList.toggle("hidden");
    document.getElementById("modal-players").classList.toggle("flex");
    document.getElementById("modal-players" + "-bg").classList.toggle("flex");
  }

  function set_new_player_modal() {
    document.getElementById("modal-new-player").classList.toggle("hidden");
    document.getElementById("modal-new-player" + "-bg").classList.toggle("hidden");
    document.getElementById("modal-new-player").classList.toggle("flex");
    document.getElementById("modal-new-player" + "-bg").classList.toggle("flex");
  }
</script>
<div style="z-index:900" class="hidden opacity-70 fixed inset-0 bg-black" id="modal-players-bg"></div>
<div style="z-index:910" class="hidden overflow-x-hidden overflow-y-auto fixed inset-0 outline-none focus:outline-none justify-center" id="modal-players">
  <div id="players_modal_setup__2" class="border-2 border-gray-500 rounded-lg shadow-lg relative flex flex-col w-5/6 dark:text-gray-200 bg-white dark:bg-black  outline-none focus:outline-none">
    <div class="flex flex-col">
      <div class="flex justify-around pt-5 space-x-10">
        <%= custom_link_to t('continue'), "javascript:set_players_modal()", data: { turbolinks: false }, class: "focus:outline-none focus:ring-8 focus:ring-green-500 focus:ring-opacity-90 border-0 btn btn-primary text-2vw", id: "cancel", tabindex: "1" %>
      </div>
      <div class="flex justify-around w-full text-3vw">
        <div class="">Spieler A</div>
        <div class="">Spieler B</div>
      </div>
      <%- players = [] %>
      <%- players += [["---Gäste---", ""]] +
        Array(guest_players_default.andand.map { |p| ["#{p.firstname} #{p.lastname}".gsub("Dr. ", "") + (p.firstname =~ /Dr\./ ? ", Dr." : ""), p.id] }) +
        Array(guest_players_other.andand.map { |p| ["#{p.firstname} #{p.lastname}".gsub("Dr. ", "") + (p.firstname =~ /Dr\./ ? ", Dr." : ""), p.id] })
      %>
      <%- players += [["---Club---", ""]] + Array(club_players.andand.map { |p| ["#{p.firstname} #{p.lastname}".gsub("Dr. ", "") + (p.firstname =~ /Dr\./ ? ", Dr." : ""), p.id] }) %>
      <%- count = players.count %>
      <div class="flex justify-between w-full text-2vw">
        <div class="mr-2">
          <%= content_tag :div, id: "player_a_w", tabindex: 1, class: "focus:outline-none focus:ring-8 focus:ring-green-500 focus:ring-opacity-90 border-2 rounded-lg p-3" do %>
            <div class="flex flex-row w-full">
              <div class="flex-col">
                <%- (0..(count / 2 - 1)).each do |ix| %>
                  <div class="flex mb-2">
                    <div class="">
                      <%- if players[ix][1].present? %>
                        <%= radio_button_tag :player_a_id, players[ix][1], nil, class: "mr-4 text-4vw", id: "playera_#{ix}", onclick: "set_checked_player('a', #{ix}, #{players[ix][1]})", ontouch: "set_checked_player('a', #{ix}, #{players[ix][1]})" %>
                      <%- end %>
                    </div>
                    <div class="" onclick="set_checked_player('a', <%= ix %>, <%= players[ix][1] %>)">
                      <%= players[ix][0] %></div>
                  </div>
                <%- end %>
              </div>
              <div class="flex-col">
                <%- ((count / 2)..count - 1).each do |ix| %>
                  <div class="flex mb-2">
                    <div class="">
                      <%- if players[ix][1].present? %>
                        <%= radio_button_tag :player_a_id, players[ix][1], nil, class: "mr-4 text-4vw", id: "playera_#{ix}", onclick: "set_checked_player('a', #{ix}, #{players[ix][1]})", ontouch: "set_checked_player('a', #{ix}, #{players[ix][1]})" %>
                      <%- end %>
                    </div>
                    <div class="" onclick="set_checked_player('a', <%= ix %>, <%= players[ix][1] %>)">
                      <%= players[ix][0] %></div>
                  </div>
                <%- end %>
              </div>
            </div>
          <%- end %>
        </div>
        <div class="">
          <%= content_tag :div, id: "player_b_w", tabindex: 1, class: "focus:outline-none focus:ring-8 focus:ring-green-500 focus:ring-opacity-90 border-2 rounded-lg p-3" do %>
            <div class="flex flex-row w-full">
              <div class="flex-col">
                <%- (0..(count / 2 - 1)).each do |ix| %>
                  <div class="flex mb-2">
                    <div class="">
                      <%- if players[ix][1].present? %>
                        <%= radio_button_tag :player_b_id, players[ix][1], nil, class: "mr-4 text-4vw", id: "playerb_#{ix}", onclick: "set_checked_player('b', #{ix}, #{players[ix][1]})", ontouch: "set_checked_player('b', #{ix}, #{players[ix][1]})" %>
                      <%- end %>
                    </div>
                    <div class="" onclick="set_checked_player('b', <%= ix %>, <%= players[ix][1] %>)">
                      <%= players[ix][0] %></div>
                  </div>
                <%- end %>
              </div>
              <div class="flex-col">
                <%- ((count / 2)..count - 1).each do |ix| %>
                  <div class="flex mb-2">
                    <div class="">
                      <%- if players[ix][1].present? %>
                        <%= radio_button_tag :player_b_id, players[ix][1], nil, class: "mr-4 text-4vw", id: "playerb_#{ix}", onclick: "set_checked_player('b', #{ix}, #{players[ix][1]})", ontouch: "set_checked_player('b', #{ix}, #{players[ix][1]})" %>
                      <%- end %>
                    </div>
                    <div class="" onclick="set_checked_player('b', <%= ix %>, <%= players[ix][1] %>)">
                      <%= players[ix][0] %></div>
                  </div>
                <%- end %>
              </div>
            </div>
          <%- end %>
        </div>
      </div>
    </div>
  </div>
</div>
<div style="z-index:900" class="hidden opacity-70 fixed inset-0 bg-black" id="modal-new-player-bg"></div>
<div style="z-index:910" class="hidden overflow-x-hidden overflow-y-auto fixed inset-0 outline-none focus:outline-none justify-center items-center" id="modal-new-player">
  <div id="new_player_modal_setup__2" class="border-2 border-gray-500 rounded-lg shadow-lg relative flex flex-col p-10 w-5/6 dark:text-gray-200 bg-white dark:bg-black  outline-none focus:outline-none">
    <div class="flex flex-col">
      <h2 class="flex mb-5">Anmeldung eines Gasts im Club <%= club.shortname %></h2>
      <div class="flex justify-around w-full text-3vw">
        <%= form_with(model: Player.new) do |form| %>
          <%= hidden_field_tag :club_id, club.id %>
          <%= hidden_field_tag :location_id, @location.id %>
          <%= hidden_field_tag :season_id, Season.current_season.id %>
          <%= hidden_field_tag :from, "new_guest" %>
          <%= render "error_messages", resource: form.object %>
          <div class="form-group">
            <%= form.text_field :firstname, autocomplete: "off", class: "form-control text-2vw", placeholder: "Vorname" %>
          </div>
          <div class="form-group">
            <%= form.text_field :lastname, autocomplete: "off", class: "form-control text-2vw", placeholder: "Nachname" %>
          </div>
          <div class="form-group">
            <%= custom_link_to t('back'), "javascript:set_new_player_modal()", data: { turbolinks: false }, class: "focus:outline-none focus:ring-8 focus:ring-green-500 focus:ring-opacity-90 border-0 btn btn-primary text-2vw", id: "cancel", tabindex: "1" %>

            <%= form.submit t('save'), class: "btn btn-primary text-2vw" %>
          </div>
          </div>
        <% end %>
        </div>
  </div>
</div>
<div class="inline-flex items-center justify-end mr-4 fixed text-gray-300 hover:text-black text-2vw font-bold" style="right: 10px; top: 10px; gap: 1.2vw;">
  <%= custom_link_to scoreboard_location_path(@location.md5, sb_state: "tournament_scores", :"data-turbo" => false) do %>
    <%= fa_icon "circle-info", weight: "fa-solid", class: "responsive-svg fill-current icon-lg m-0 text-white inline-block", title: "home", style: "font-size:2.2vw !important;width:2.2vw !important;height:2.2vw !important;" %>
  <% end %>
  <%= custom_link_to scoreboard_location_path(@location.md5, sb_state: "welcome", :"data-turbolinks" => false) do %>
    <%= fa_icon "house", weight: "fa-solid", class: "responsive-svg fill-current icon-lg m-0 text-white inline-block", title: "home", style: "font-size:2.2vw !important;width:2.2vw !important;height:2.2vw !important;" %>
  <% end %>
</div>
<div data-controller="table-monitor" class="p-4 w-full m-auto flex
 items-center flex-col bg-cover h-screen bg-center bg-no-repeat"
     style="background-image: url('<%= @location.background_image
     .gsub(".", "-.") %>')">
  <h1 style="text-shadow: 2px 2px #000000" class="text-4vw flex
  text-gray-300 "><%= "#{table.andand.table_kind.andand.name} -
                        #{table.andand.name}" %></h1>
  <%- if @location.present? %>
    <%- table_monitor.get_options!(I18n.locale) %>
    <%- options = table_monitor.options %>
    <!--    <h1 style="text-shadow: 2px 2px #000000" class="text-2vw flex text-gray-300"><%#= @location.name %></h1>-->
    <%# Phase 38.2-02 / UAT-GAP-02 fix: the single Alpine x-data scope is
        lifted onto an outer <div> that WRAPS the form_tag. Hidden inputs
        (free_game_form, set_target_points, discipline_a/b, sets_to_*,
        bk2_dz_max_shots, bk2_sp_max_innings) now live INSIDE this scope so
        their :value bindings actually hydrate — previously they were siblings
        of the x-data container and silently lost Alpine reactivity.
        Phase 38.3-06: first_set_mode state slot removed (moved to shootout
        screen per Plan 38.3-05); replaced by bk2_dz_max_shots +
        bk2_sp_max_innings game-config state slots (D-17 / DR-06). %>
    <div x-data="{
      table_kind: '<%= table.andand.table_kind.andand.name || "Small Billard" %>',
      multiset: 0,
      last_direction: 'r',
      incr_d: {200:50, 100:10, 50:10, 30:10, 20:10, 10:5, 5:1},
      sets: 1, sets_2: 1, parameters: 0,
      gametime: <%= options[:gametime].presence || 30 %>,
      warntime: <%= options[:warntime].presence || 5 %>,
      increment_balls_goal: 5,
      increment_balls_goal_a: 5,
      increment_balls_goal_b: 5,

      balls_goal: <%= options[:player_a][:balls_goal].to_i > 0 ? options[:player_a][:balls_goal] : "80" %>,
      balls_goal_2: <%= options[:player_a][:balls_goal].to_i > 0 ? options[:player_a][:balls_goal] : "80" %>,
      balls_goal_a: <%= options[:player_a][:balls_goal].to_i > 0 ? options[:player_a][:balls_goal] : "80" %>,
      balls_goal_a_2: <%= options[:player_a][:balls_goal].to_i > 0 ? options[:player_a][:balls_goal] : "80" %>,
      balls_goal_b: <%= options[:player_b][:balls_goal].to_i > 0 ? options[:player_b][:balls_goal] : "80" %>,
      balls_goal_b_2: <%= options[:player_b][:balls_goal].to_i > 0 ? options[:player_b][:balls_goal] : "80" %>,
      increment_games: 5,
      games: <%= options[:sets_to_win].presence || 0 %>,
      games_2: <%= options[:sets_to_win].presence || 0 %>,
      increment_innings: 5,
      innings: <%= options[:innings_goal].to_i > 0 ? options[:innings_goal].to_i : 20 %>,
      innings_2: <%= options[:innings_goal].to_i > 0 ? options[:innings_goal].to_i : 20 %>,
      first_break: <%= options[:first_break_choice].presence || "0" %>,
      next_break: <%= %w{winner set}.index(options[:kickoff_switches_with].presence) || 0 %>,
      discipline: <%= Discipline::KARAMBOL_DISCIPLINE_MAP.index(options[:player_a][:discipline].presence || "Freie Partie klein").to_i %>,
      discipline_a: <%= Discipline::KARAMBOL_DISCIPLINE_MAP.index(options[:player_a][:discipline].presence || "Freie Partie klein").to_i %>,
      discipline_b: <%= Discipline::KARAMBOL_DISCIPLINE_MAP.index(options[:player_b][:discipline].presence || "Freie Partie klein").to_i %>,
      increment: 0,
      allow_follow_up: <%= options[:allow_follow_up] ? "true" : "false" %>,
      bk2_choice: null,
      bk2_dz_max_shots: 2,
      bk2_sp_max_innings: 5,
      get bk2_selected() { return this.bk2_choice !== null && this.bk2_choice !== '' && this.bk2_choice !== undefined; },
      get bk2_target() { return [50, 60, 70][this.bk2_choice] || 50; },
      bk_selected_form: null,
      bk_balls_goal: null,
      get is_bk_family() { return ['bk2_kombi','bk_2plus','bk_2','bk50','bk100'].includes(this.bk_selected_form); },
      get is_bk_fixed_goal() { return this.bk_selected_form === 'bk50' || this.bk_selected_form === 'bk100'; },
      get is_bk_dz_configurable() { return this.bk_selected_form === 'bk_2plus' || this.bk_selected_form === 'bk2_kombi'; },
      get is_bk_sp_configurable() { return this.bk_selected_form === 'bk_2' || this.bk_selected_form === 'bk2_kombi'; },
      get bk_ballziel_choices() {
        switch(this.bk_selected_form) {
          case 'bk50':     return [50];
          case 'bk100':    return [100];
          case 'bk_2':     return [50, 60, 70, 80, 90, 100];
          case 'bk_2plus': return [50, 60, 70, 80, 90, 100];
          case 'bk2_kombi': return [50, 60, 70];
          default: return [];
        }
      }
      }">
    <%= form_tag start_game_table_monitor_path(table_monitor), data: {turbo: false}, method: :post, class: "flex flex-col text-gray-300 max-h-screen overflow-y-auto" do %>
      <%# Phase 38.4-06 D-16/D-07: free_game_form driven by bk_selected_form (5 BK-* disciplines).
          Fallback value='karambol' is a safety net if Alpine fails to hydrate.
          Legacy bk2_selected path retained for bk2_choice radio (unused when bk_selected_form is set). %>
      <input name='free_game_form' :value="is_bk_family ? bk_selected_form : (bk2_selected ? 'bk2_kombi' : 'karambol')" value='karambol' type='hidden'/>
      <%# BK-family hidden fields — driven by bk_selected_form; emit empty when not BK-family.
          controller's karambol/pool branch ignores them.
          NOTE: set_target_points removed per D-06 (Plan 04); balls_goal is the canonical field. %>
      <input name='balls_goal' :value="is_bk_family ? (bk_balls_goal || 50) : ''" type='hidden'/>
      <input name='discipline_a' :value="is_bk_family ? ({'bk50':'BK50','bk100':'BK100','bk_2':'BK-2','bk_2plus':'BK-2plus','bk2_kombi':'BK2-Kombi'}[bk_selected_form] || '') : (bk2_selected ? 'BK2-Kombi' : '')" type='hidden'/>
      <input name='discipline_b' :value="is_bk_family ? ({'bk50':'BK50','bk100':'BK100','bk_2':'BK-2','bk_2plus':'BK-2plus','bk2_kombi':'BK2-Kombi'}[bk_selected_form] || '') : (bk2_selected ? 'BK2-Kombi' : '')" type='hidden'/>
      <input name='sets_to_win' :value="is_bk_family ? (bk_selected_form === 'bk2_kombi' ? '2' : '1') : (bk2_selected ? '2' : '')" type='hidden'/>
      <input name='sets_to_play' :value="is_bk_family ? (bk_selected_form === 'bk2_kombi' ? '3' : '1') : (bk2_selected ? '3' : '')" type='hidden'/>
      <%# Phase 38.4-06 D-16: BK-family game-config payload fields. Submitted on form-start.
          Empty string when not BK-family — karambol branch ignores them. %>
      <input name='bk2_options[direkter_zweikampf_max_shots_per_turn]' :value="is_bk_family ? bk2_dz_max_shots : (bk2_selected ? bk2_dz_max_shots : '')" type='hidden'/>
      <input name='bk2_options[serienspiel_max_innings_per_set]' :value="is_bk_family ? bk2_sp_max_innings : (bk2_selected ? bk2_sp_max_innings : '')" type='hidden'/>
      <input name='allow_follow_up' value='<%= allow_follow_up ? '1' : '0' %>' type='hidden'/>

      <%# Phase 38.3-06: Start Game button visible for all selections (BK2 and
          Karambol). BK2 config inputs below replaced the 4-button D-14 matrix
          (Plan 38.3-05 moved first_set_mode to the shootout screen). %>
      <div class="flex justify-center mt-4 text-center sticky top-0 bg-opacity-90 z-10" style="background-image: url('<%= @location.background_image.gsub(".", "-.") %>')">
        <div id="submit" tabindex=1 class="focus:outline-none focus:ring-8 focus:ring-green-500 focus:ring-opacity-90 min-w-min focus:border-0 rounded-lg">
          <%= submit_tag "Start Game", class: "h-full border-4 rounded-lg btn btn-primary text-center text-2vw p-2" %>
        </div>
      </div>
      <div class="mt-8 text-2vw grid grid-cols-6 gap-3 items-center">
        <div class="  flex flex-row">Spieler</div>
        <div class="col-span-4 flex flex-row">
          <div class="grid grid-cols-3 gap-4">
            <div class="flex">
              <%= custom_link_to "Spieler-Auswahl", "javascript:players_mode()", data: { turbolinks: false }, class: "flex w-full h-full border-4 focus:outline-none focus:ring-8 focus:ring-green-500 focus:ring-opacity-90 border-0 rounded-lg btn btn-primary text-white hover:text-white text-2vw", id: "cancel", tabindex: "1" %>
            </div>
            <%= content_tag :div, id: "player_a_w", tabindex: 1, class: "flex focus:outline-none focus:ring-8 focus:ring-green-500 focus:ring-opacity-90 rounded-lg" do %>
              <%= select_tag :player_a_id,
                options_for_select(Array(players), player_a.andand.id || default_guest_a.player.id),
                class: "py-3 px-4 text-2vw w-full bg-white dark:bg-gray-800 text-gray-900 dark:text-white border-2 border-gray-300 dark:border-gray-600 rounded-lg focus:border-green-500 focus:ring-2 focus:ring-green-500" %>
            <%- end %>
            <%= content_tag :div, id: "player_b_w", tabindex: 1, class: "flex focus:outline-none focus:ring-8 focus:ring-green-500 focus:ring-opacity-90 rounded-lg" do %>
              <%= select_tag :player_b_id,
                options_for_select(Array(players), player_a.andand.id || default_guest_b.player.id),
                class: "py-3 px-4 text-2vw w-full bg-white dark:bg-gray-800 text-gray-900 dark:text-white border-2 border-gray-300 dark:border-gray-600 rounded-lg focus:border-green-500 focus:ring-2 focus:ring-green-500" %>
            <%- end %>
          </div>
        </div>
        <div class="col-span-1">

          <div class="flex">
            <%= custom_link_to "Neuer Spieler", "javascript:new_player_mode()", data: { turbolinks: false }, class: "flex w-full h-full border-4 dark:text-white focus:outline-none focus:ring-8 focus:ring-green-500 focus:ring-opacity-90 border-0 rounded-lg btn btn-primary text-2vw", id: "cancel", tabindex: "1" %>
          </div>
        </div>
        <form>
          <%= render partial: "radio_select", locals: {
            table: table,
            show: "true",
            header: "Disziplin + Punktziel",
            varname: "parameters",
            values: [0, 1, 2],
            maxval: 2,
            displays: ["für beide", "für ↑", "für ↑"],
            cols: 3,
            increment: 1,
            no_counter: true }
          %>
          <%= render partial: "radio_select", locals: {
            table: table,
            show: "table_kind == 'Small Billard' && parameters == 0",
            header: "Disziplin",
            varname: "discipline",
            values: [0, 1, 2, 3, 4, 5],
            maxval: 5,
            displays: ["3Band".html_safe, "Frei", "1Band".html_safe, "52/2", "35/2", "Eurok"],
            cols: 6,
            increment: 1,
            no_counter: true }
          %>
          <%# Phase 38.4-06 D-16/D-07: BK-family discipline selector + Ballziel + conditional DZ/SP inputs.
              Replaces the old BK2-Kombi 50/60/70 radio_select + config block from 38.3-06.
              MUST sit inside the singular x-data wrapper (GAP-02 constraint — no second x-data here). %>
          <div x-show="table_kind == 'Small Billard' && parameters == 0" class="col-span-6 mt-4 space-y-3">
            <%# 5-radio BK-family discipline selector — binds bk_selected_form %>
            <div class="flex flex-col gap-2">
              <label class="text-2vw font-bold text-white">BK — Variante wählen</label>
              <div class="grid grid-cols-5 gap-2 text-gray-900">
                <label class="cursor-pointer">
                  <input type="radio" name="bk_form_choice" value="bk50"
                         x-model="bk_selected_form"
                         @change="bk_balls_goal = 50">
                  <span class="inline-block px-3 py-2 rounded border text-1-5vw"
                        :class="bk_selected_form === 'bk50' ? 'bg-blue-100 border-blue-500' : 'bg-white'">BK50</span>
                </label>
                <label class="cursor-pointer">
                  <input type="radio" name="bk_form_choice" value="bk100"
                         x-model="bk_selected_form"
                         @change="bk_balls_goal = 100">
                  <span class="inline-block px-3 py-2 rounded border text-1-5vw"
                        :class="bk_selected_form === 'bk100' ? 'bg-blue-100 border-blue-500' : 'bg-white'">BK100</span>
                </label>
                <label class="cursor-pointer">
                  <input type="radio" name="bk_form_choice" value="bk_2"
                         x-model="bk_selected_form"
                         @change="bk_balls_goal = bk_ballziel_choices[0]">
                  <span class="inline-block px-3 py-2 rounded border text-1-5vw"
                        :class="bk_selected_form === 'bk_2' ? 'bg-blue-100 border-blue-500' : 'bg-white'">BK-2</span>
                </label>
                <label class="cursor-pointer">
                  <input type="radio" name="bk_form_choice" value="bk_2plus"
                         x-model="bk_selected_form"
                         @change="bk_balls_goal = bk_ballziel_choices[0]">
                  <span class="inline-block px-3 py-2 rounded border text-1-5vw"
                        :class="bk_selected_form === 'bk_2plus' ? 'bg-blue-100 border-blue-500' : 'bg-white'">BK-2plus</span>
                </label>
                <label class="cursor-pointer">
                  <input type="radio" name="bk_form_choice" value="bk2_kombi"
                         x-model="bk_selected_form"
                         @change="bk_balls_goal = bk_ballziel_choices[0]">
                  <span class="inline-block px-3 py-2 rounded border text-1-5vw"
                        :class="bk_selected_form === 'bk2_kombi' ? 'bg-blue-100 border-blue-500' : 'bg-white'">BK-2kombi</span>
                </label>
              </div>
            </div>

            <%# Ballziel — shown only when a BK-family form is selected (D-07) %>
            <div x-show="is_bk_family" class="flex flex-col gap-2">
              <label class="text-2vw font-bold text-white">Ballziel (Kegel pro Satz)</label>
