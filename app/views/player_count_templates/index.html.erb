<h1>Listing Player Count Templates</h1>

<table style="margin: 0px; width: 50%;">
  <thead>
    <tr>
      <th>Tournament template</th>
      <th>Players</th>
      <th>Template</th>
      <th colspan="3"></th>
    </tr>
  </thead>

  <tbody>
    <% @player_count_templates.each do |player_count_template| %>
      <tr>
        <td><%= link_to player_count_template.tournament_template.name,tournament_template_path(player_count_template.tournament_template) %></td>
        <td><%= player_count_template.players %></td>
        <td><%= link_to player_count_template.template.name, template_path(player_count_template.template) %></td>
        <td>
          <%= link_to image_tag("ansehen.gif", :width => 26, :height => 22, :border => 0), player_count_template %>
          <%= link_to image_tag("bearbeiten.gif", :width => 26, :height => 22, :border => 0), edit_player_count_template_path(player_count_template) %>
          <%= link_to image_tag("loeschen.gif", :width => 26, :height => 22, :border => 0), player_count_template, method: :delete, data: { confirm: 'Are you sure?' } %></td>
      </tr>
    <% end %>
  </tbody>
</table>

<br>

<%= link_to 'New Player count template', new_player_count_template_path %>
