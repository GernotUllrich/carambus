<div class="overflow-x-auto rounded shadow ring-1 ring-slate-200 dark:ring-slate-800">
  <table class="min-w-full text-sm">
    <thead class="bg-gray-100/80 border-b border-slate-200 text-slate-500 dark:bg-slate-800 dark:border-slate-700 dark:text-slate-400">
      <tr>
        <th class="p-3 text-left font-semibold"><%= t("league.standings.rank") %></th>
        <th class="p-3 text-left font-semibold"><%= t("league.standings.team") %></th>
        <th class="p-3 text-left font-semibold"><%= t("league.standings.matches") %></th>
        <th class="p-3 text-left font-semibold"><%= t("league.standings.won") %></th>
        <th class="p-3 text-left font-semibold"><%= t("league.standings.drawn") %></th>
        <th class="p-3 text-left font-semibold"><%= t("league.standings.lost") %></th>
        <th class="p-3 text-left font-semibold"><%= t("league.standings.points") %></th>
        <th class="p-3 text-left font-semibold"><%= t("league.standings.diff") %></th>
        <th class="p-3 text-left font-semibold"><%= t("league.standings.games") %></th>
      </tr>
    </thead>
    <tbody>
      <% standings.each do |row| %>
        <tr class="border-b border-slate-100 dark:border-slate-800">
          <td class="p-3"><%= row[:platz] %></td>
          <td class="p-3"><%= link_to row[:name], league_team_path(row[:team]) %></td>
          <td class="p-3"><%= row[:spiele] %></td>
          <td class="p-3"><%= row[:gewonnen] %></td>
          <td class="p-3"><%= row[:unentschieden] %></td>
          <td class="p-3"><%= row[:verloren] %></td>
          <td class="p-3"><strong><%= row[:punkte] %></strong></td>
          <td class="p-3"><%= row[:diff] > 0 ? "+#{row[:diff]}" : row[:diff] %></td>
          <td class="p-3"><%= row[:partien] %></td>
        </tr>
      <% end %>
    </tbody>
  </table>
</div>
