<%# 14-04: auf die generische Detail-Card migriert. Stammdaten kuratiert (only:, ohne rohe Technik-
    Spalten/CC/Sync); die reichen Sektionen (Mannschaften-Drill, disziplin-abhängige Ligatabelle,
    Spielplan, Datenabgleich) im details-Slot. Erbt H1 (leere Felder), H5 (Titel=Name), H30 (Edit-Gate);
    organizer wird polymorph verlinkt (behebt den hardcodeten region_path-Bug). %>
<% details = capture do %>
  <div class="flex flex-wrap gap-4">
    <%= custom_link_to "=> #{t('league_league_teams')}", league_teams_path(drill: { league_id: @league.id }), class: "text-primary-600 hover:text-primary-700 font-medium" %>
  </div>

  <% if @league.discipline&.name == "Snooker" %>
    <div class="mt-6 bg-surface-card dark:bg-gray-800 rounded-card border border-gray-200 dark:border-gray-700 p-6 text-gray-900 dark:text-gray-100">
      <h2 class="text-lg font-semibold text-gray-900 dark:text-gray-100 mb-3">Ligatabelle</h2>
      <%= render partial: "standings_table_snooker", locals: { standings: @league.standings_table_snooker } %>
    </div>
  <% elsif @league.discipline&.name&.match?(/Karambol/i) %>
    <div class="mt-6 bg-surface-card dark:bg-gray-800 rounded-card border border-gray-200 dark:border-gray-700 p-6 text-gray-900 dark:text-gray-100">
      <h2 class="text-lg font-semibold text-gray-900 dark:text-gray-100 mb-3">Ligatabelle</h2>
      <%= render partial: "standings_table_karambol", locals: { standings: @league.standings_table_karambol } %>
    </div>
  <% elsif @league.discipline&.name&.match?(/Pool/i) %>
    <div class="mt-6 bg-surface-card dark:bg-gray-800 rounded-card border border-gray-200 dark:border-gray-700 p-6 text-gray-900 dark:text-gray-100">
      <h2 class="text-lg font-semibold text-gray-900 dark:text-gray-100 mb-3">Ligatabelle</h2>
      <%= render partial: "standings_table_pool", locals: { standings: @league.standings_table_pool } %>
    </div>
  <% end %>

  <div class="mt-6 bg-surface-card dark:bg-gray-800 rounded-card border border-gray-200 dark:border-gray-700 p-6 text-gray-900 dark:text-gray-100">
    <h2 class="text-lg font-semibold text-gray-900 dark:text-gray-100 mb-3">Spielplan</h2>
    <%= render partial: "schedule_table", locals: { schedule_by_rounds: @league.schedule_by_rounds } %>
  </div>

  <% if current_user&.data_sync_access? %>
    <div class="mt-8 pt-4 border-t border-gray-200 dark:border-gray-700">
      <p class="text-sm text-gray-500 dark:text-gray-400 mb-2">Datenabgleich</p>
      <div class="flex flex-wrap gap-2">
        <%= button_to I18n.t("league.show.reload_from_club_cloud", source: @league.source), reload_from_cc_league_path(@league), method: :post, class: "btn btn-flat btn-primary" %>
        <%= button_to I18n.t("league.show.reload_from_club_cloud_with_details", source: @league.source), reload_from_cc_with_details_league_path(@league), method: :post, class: "btn btn-flat btn-primary" %>
        <%= button_to I18n.t("league.show.reload_from_club_cloud_all_new", source: @league.source), reload_from_cc_all_new_league_path(@league), method: :post, class: "btn btn-flat btn-primary" %>
      </div>
    </div>
  <% end %>
<% end %>
<%= render "shared/detail_card", record: @league,
      only: %w[name registration_until organizer_id season_id discipline_id game_plan_id source_url sync_date],
      details: details %>
