<div class="overflow-x-auto rounded shadow ring-1 ring-slate-200 dark:ring-slate-800">
  <table class="min-w-full text-sm">
    <% schedule_by_rounds.each do |runde, parties| %>
      <thead class="bg-gray-100/80 border-b border-slate-200 text-slate-500 dark:bg-slate-800 dark:border-slate-700 dark:text-slate-400">
      <tr>
        <th colspan="<%= Rails.env.production? ? 6 : 7 %>" class="p-3 text-left font-semibold bg-primary-50 dark:bg-slate-700 text-gray-700 dark:text-gray-200"><%= runde %></th>
      </tr>
      <tr>
        <% unless Rails.env.production? %>
          <th class="p-3 text-left font-semibold">id</th>
        <% end %>
        <th class="p-3 text-left font-semibold"><%= t("league.schedule.matchday") %></th>
        <th class="p-3 text-left font-semibold"><%= t("league.schedule.date") %></th>
        <th class="p-3 text-left font-semibold"><%= t("league.schedule.home") %></th>
        <th class="p-3 text-left font-semibold"><%= t("league.schedule.result") %></th>
        <th class="p-3 text-left font-semibold"><%= t("league.schedule.guest") %></th>
        <th class="p-3 text-left font-semibold"><%= t("league.schedule.host") %></th>
      </tr>
      </thead>
      <tbody>
      <% parties.each do |party| %>
        <tr class="border-b border-slate-100 dark:border-slate-800">
          <% unless Rails.env.production? %>
            <td class="p-3"><%= party.id %></td>
          <% end %>
          <td class="p-3"><%= party.day_seqno %></td>
          <td class="p-3"><%= l(party.date, format: :short) if party.date %></td>
          <td class="p-3"><%= link_to party.league_team_a.name, league_team_path(party.league_team_a) if party.league_team_a %></td>
          <td class="p-3">
            <% if party.data["result"].present? %>
              <%= link_to party.data["result"], party_path(party), class: 'fw-bold' %>
            <% else %>
              &ndash;
            <% end %>
          </td>
          <td class="p-3"><%= link_to party.league_team_b.name, league_team_path(party.league_team_b) if party.league_team_b %></td>
          <td class="p-3"><%= party.host_league_team&.name %></td>
        </tr>
      <% end %>
      </tbody>
    <% end %>
  </table>
</div>
