<div class="container mx-auto my-8 px-4">
  <div class="flex justify-between items-center mb-4">
    <h1 class="h3">Branch Ccs</h1>

    <% if @branch_ccs.any? %>
      <%= link_to 'New Branch Cc', new_branch_cc_path, class: "btn btn-primary" %>
    <% end %>
  </div>

  <% if @branch_ccs.any? %>
    <div class="bg-white rounded shadow table-responsive">
      <table class="table">
        <thead>
          <tr>
            <th class="p-3 uppercase text-left text-xs"><%= sortable @branch_ccs, :cc_id, 'Cc', class: 'text-gray-700' %></th>
            <th class="p-3 uppercase text-left text-xs"><%= sortable @branch_ccs, :context, 'Context', class: 'text-gray-700' %></th>
            <th class="p-3 uppercase text-left text-xs"><%= sortable @branch_ccs, :region_cc_id, 'Region cc', class: 'text-gray-700' %></th>
            <th class="p-3 uppercase text-left text-xs"><%= sortable @branch_ccs, :discipline_id, 'Discipline', class: 'text-gray-700' %></th>
            <th class="p-3 uppercase text-left text-xs"><%= sortable @branch_ccs, :name, 'Name', class: 'text-gray-700' %></th>
            <th class="p-3 uppercase text-left text-xs text-gray-700 w-20">Actions</th>
          </tr>
        </thead>

        <tbody>
        <% @branch_ccs.each do |branch_cc| %>
          <tr class="group border-t border-gray-400 hover:bg-gray-100">
                      <td class="p-3"><%= branch_cc.cc_id %></td>
                      <td class="p-3"><%= branch_cc.context %></td>
                      <td class="p-3"><%= branch_cc.region_cc_id %></td>
                      <td class="p-3"><%= branch_cc.discipline_id %></td>
                      <td class="p-3"><%= branch_cc.name %></td>
          
            <td>
              <%= link_to "View", branch_cc, class: "btn btn-link no-underline" %>
            </td>
          </tr>
        <% end %>
        </tbody>
      </table>
    </div>

    <% if @pagy.pages > 1 %>
      <div class="text-center my-6">
        <%== pagy_nav(@pagy) %>
      </div>
    <% end %>

  <% else %>
    <div class="bg-white rounded shadow flex flex-col items-center justify-between p-8 lg:flex-row">
      <%= image_tag "empty.svg", class: "mb-4 lg:w-1/2" %>
      <div class="flex-1 text-center">
        <p class="h3 mb-4">Create your first Branch Cc</p>
        <%= link_to 'New Branch Cc', new_branch_cc_path, class: "btn btn-primary" %>
      </div>
    </div>
  <% end %>
</div>
