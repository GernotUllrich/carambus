<div class="container mx-auto my-8 px-4">
  <div class="max-w-3xl mx-auto">
    <div class="flex justify-between items-center mb-4">
      <h1 class="h3"><%= link_to 'Branch Ccs', branch_ccs_path %> > Branch Cc #<%= @branch_cc.id %></h1>
      <%= link_to 'Edit', edit_branch_cc_path(@branch_cc), class: "btn btn-link" %>
    </div>

    <div class="bg-white rounded shadow p-8">
            <div class="mb-4">
        <h5>Cc</h5>
        <%= @branch_cc.cc_id %>
      </div>
            <div class="mb-4">
        <h5>Context</h5>
        <%= @branch_cc.context %>
      </div>
            <div class="mb-4">
        <h5>Region cc</h5>
        <%= @branch_cc.region_cc_id %>
      </div>
            <div class="mb-4">
        <h5>Discipline</h5>
        <%= @branch_cc.discipline_id %>
      </div>
            <div class="mb-4">
        <h5>Name</h5>
        <%= @branch_cc.name %>
      </div>
          </div>
  </div>
</div>
