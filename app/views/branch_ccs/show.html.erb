<%# 10-02: generische Detail-Card (09-01) mit details:-Slot für die verwandte Competitions-Sub-Tabelle
    (Pilot-Rezept „details:-Slot via capture" für Show-Seiten mit verwandten Tabellen). %>
<% details_html = capture do %>
  <% if @competition_ccs.any? %>
    <h3 class="text-lg font-semibold text-gray-900 dark:text-gray-100 mb-3">Competitions</h3>
    <div id="table_wrapper">
      <%= render partial: 'competition_ccs/competition_ccs_table', locals: { records: @competition_ccs } %>
    </div>
  <% end %>
<% end %>
<%= render "shared/detail_card",
      record: @branch_cc,
      index_path: branch_ccs_path,
      index_label: "Branch Ccs",
      details: (details_html.to_s.strip.present? ? details_html : nil) %>
