<h1>Listing Innings</h1>

<table>
  <thead>
    <tr>
      <th>Game</th>
      <th>Sequence number</th>
      <th>Player a count</th>
      <th>Player b count</th>
      <th>Player c count</th>
      <th>Player d count</th>
      <th>Remarks</th>
      <th colspan="3"></th>
    </tr>
  </thead>

  <tbody>
    <% @innings.each do |inning| %>
      <tr>
        <td><%= inning.game_id %></td>
        <td><%= inning.sequence_number %></td>
        <td><%= inning.player_a_count %></td>
        <td><%= inning.player_b_count %></td>
        <td><%= inning.player_c_count %></td>
        <td><%= inning.player_d_count %></td>
        <td><%= inning.remarks %></td>
        <td><%= link_to image_tag("ansehen.gif", :width => 26, :height => 22, :border => 0), inning %></td>
        <td><%= link_to image_tag("bearbeiten.gif", :width => 26, :height => 22, :border => 0), edit_inning_path(inning) %></td>
        <td><%= link_to image_tag("loeschen.gif", :width => 26, :height => 22, :border => 0), inning, method: :delete, data: { confirm: 'Are you sure?' } %></td>
      </tr>
    <% end %>
  </tbody>
</table>

<br>

<%= link_to 'New Inning', new_inning_path %>
