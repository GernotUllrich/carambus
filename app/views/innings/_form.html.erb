<%= form_with(model: inning) do |form| %>
  <%= render "shared/error_messages", resource: form.object %>

  <div class="form-group">
    <%= form.label :game_id %>
    <%= form.number_field :game_id, class: "form-control" %>
  </div>

  <div class="form-group">
    <%= form.label :sequence_number %>
    <%= form.number_field :sequence_number, class: "form-control" %>
  </div>

  <div class="form-group">
    <%= form.label :player_a_count %>
    <%= form.text_field :player_a_count, class: "form-control" %>
  </div>

  <div class="form-group">
    <%= form.label :player_b_count %>
    <%= form.text_field :player_b_count, class: "form-control" %>
  </div>

  <div class="form-group">
    <%= form.label :player_c_count %>
    <%= form.text_field :player_c_count, class: "form-control" %>
  </div>

  <div class="form-group">
    <%= form.label :player_d_count %>
    <%= form.text_field :player_d_count, class: "form-control" %>
  </div>

  <div class="form-group">
    <%= form.label :date %>
    <%= form.text_area :date, class: "form-control" %>
  </div>

  <div class="form-group flex justify-between">
    <%= form.button class: "btn btn-primary" %>

    <% if form.object.persisted? %>
      <%= link_to 'Delete', form.object, class: "btn btn-danger outline", method: :delete, data: { remote: true, confirm: "Are you sure?" } %>
    <% end %>
  </div>
<% end %>
