<%# 10-04: generische Detail-Card (09-01) + League-Teams- und Parties-Sub-Tabellen im details-Slot. %>
<% details_html = capture do %>
  <% if @league_team_ccs.any? %>
    <h3 class="text-lg font-semibold text-gray-900 dark:text-gray-100 mb-3">League Teams</h3>
    <div id="table_wrapper">
      <%= render partial: 'league_team_ccs/league_team_ccs_table', locals: { records: @league_team_ccs } %>
    </div>
  <% end %>
  <% if @party_ccs.any? %>
    <h3 class="text-lg font-semibold text-gray-900 dark:text-gray-100 mb-3 mt-6">Parties</h3>
    <div id="table_wrapper">
      <%= render partial: 'party_ccs/party_ccs_table', locals: { records: @party_ccs } %>
    </div>
  <% end %>
<% end %>
<%= render "shared/detail_card",
      record: @league_cc,
      index_path: league_ccs_path,
      index_label: "League Ccs",
      details: (details_html.to_s.strip.present? ? details_html : nil) %>
