<style>
    td, th {
        border: 1px solid #dddddd;
        text-align: left;
        padding: 8px;
    }
    th, tr:nth-child(even) {
        background-color: #dddddd;
    }
</style>
<h1><%= image_tag @region.logo if @region.logo.present? %><%= @region.name %></h1>

<p>
  <strong>Name:</strong>
  <%= @region.name %>
</p>

<p>
  <strong>Shortname:</strong>
  <%= link_to(@region.shortname, "https://#{@region.shortname.downcase}.billardarea.de") %>
</p>

<p>
  <strong>Logo:</strong>
  <%= @region.logo %>
</p>

<p>
  <strong>Email:</strong>
  <%= mail_to @region.email %>
</p>

<p>
  <strong>Address:</strong>
  <%= @region.address.split("\n").select{|s| s.present?}.join(", ") %>
</p>

<p>
  <strong>Country:</strong>
  <%= link_to @region.country.andand.code, country_path(@region.country) %>
</p>

<%= link_to 'Edit', edit_region_path(@region) %> |
<%= link_to 'Back', regions_path %>
<h3>Tournaments Season <%= Season.last.name %></h3>
<table>
  <thead>
  <tr>
    <th>BaId</th>
    <th>Date</th>
    <th>Title</th>
    <th>Shortname</th>
    <th>Discipline</th>
    <th>Region</th>
    <th>Season</th>
    <th>SingleOrLeague</th>
  </tr>
  </thead>

  <tbody>
  <%- Tournament.where(season_id: Season.last.id, region_id: @region.id).order("tournaments.date asc").each do |tournament| %>
    <tr>
      <td><%= link_to(tournament.ba_id, tournament_path(tournament)) %></td>
      <td><%= tournament.date_str %></td>
      <td><%= link_to(tournament.title, tournament_path(tournament)) %></td>
      <td><%= link_to(tournament.shortname, tournament_path(tournament)) if tournament.shortname.present? %></td>
      <td><%= link_to(tournament.discipline.name, discipline_path(tournament.discipline)) if tournament.discipline.present? %></td>
      <td><%= link_to(tournament.region.shortname, region_path(tournament.region)) if tournament.region.present? %></td>
      <td><%= link_to(tournament.season.name, season_path(tournament.season)) %></td>
      <td><%= tournament.single_or_league %></td>
    </tr>
  <% end %>
  </tbody>
</table>

<h3>Clubs</h3>
<table>
  <thead>
  <tr>
    <th>BaId</th>
    <th>Region</th>
    <th>Name</th>
    <th>Shortname</th>
    <th>Address</th>
    <th>Homepage</th>
    <th>Email</th>
    <th>Logo</th>
    <th>Status</th>
    <th>Founded</th>
    <th>Dbu entry</th>
  </tr>
  </thead>

  <tbody>
  <% @region.clubs.order(:name).each do |club| %>
    <tr>
      <td><%= link_to club.ba_id, "https://nbv.billardarea.de/cms_clubs/details/#{club.ba_id}" %></td>
      <td><%= link_to club.region.name, region_path(club.region) if club.region.present? %></td>
      <td><%= link_to club.name, club_path(club) %></td>
      <td><%= club.shortname %></td>
      <td><%= club.address %></td>
      <td><%= link_to club.homepage, club.homepage %></td>
      <td><%= club.email %></td>
      <td><%= club.logo %></td>
      <td><%= club.status %></td>
      <td><%= club.founded %></td>
      <td><%= club.dbu_entry %></td>
    </tr>
  <% end %>
  </tbody>
</table>

