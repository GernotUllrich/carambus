<div class="container mx-auto my-8 px-4">
  <div class="max-w-3xl mx-auto">
    <!-- Header -->
    <div class="flex justify-between items-start mb-6 gap-4">
      <div class="flex items-center gap-4">
        <% if @region.logo.present? %>
          <%= image_tag @region.logo, class: "max-h-16 w-auto object-contain" %>
        <% end %>
        <div>
          <div class="text-sm text-gray-500 dark:text-gray-400">
            <%= custom_link_to t('home.index.region'), regions_path %>
          </div>
          <h1 class="text-2xl font-bold text-gray-800 dark:text-gray-100"><%= @region.display_shortname %></h1>
        </div>
      </div>
      <%= button_to('Edit', edit_region_path(@region), method: :get, disabled: !current_user&.admin?,
            class: "shrink-0 inline-block px-4 py-2 rounded text-sm font-medium ring-1 ring-gray-300 dark:ring-gray-600 text-gray-700 dark:text-gray-200 hover:bg-gray-100 dark:hover:bg-gray-800 disabled:opacity-40") %>
    </div>

    <!-- Stammdaten-Card -->
    <div class="ring-1 ring-gray-200 dark:ring-gray-700 bg-white dark:bg-gray-900 rounded-xl p-6">
      <dl class="grid grid-cols-1 sm:grid-cols-[10rem_1fr] gap-x-4 gap-y-4">
        <dt class="text-sm font-medium text-gray-500 dark:text-gray-400"><%= t('region.name') %></dt>
        <dd class="text-gray-800 dark:text-gray-100 flex items-center gap-2">
          <% if @region.logo.present? %>
            <%= image_tag @region.logo, class: "h-6 w-auto object-contain" %>
          <% end %>
          <%= @region.name %>
        </dd>

        <dt class="text-sm font-medium text-gray-500 dark:text-gray-400"><%= t('region.shortname') %></dt>
        <dd class="text-gray-800 dark:text-gray-100">
          <%= @region.shortname %>
          <%- if @region.region_cc.present? %>
            (-> <%= custom_link_to('Club Cloud', @region.public_cc_url_base.presence || @region.region_cc.public_url.presence || @region.region_cc.base_url, class: "green_link") %>
<!--  TODO Migration Check to be fixed        , <%#= custom_link_to 'Migration Check', migration_cc_region_path(@region) %>-->
            )
          <%- else %>
            (-> <%= custom_link_to 'Migrate to Club Cloud', migration_cc_region_path(@region) %> )
          <%- end %>
        </dd>

        <dt class="text-sm font-medium text-gray-500 dark:text-gray-400"><%= t('region.email') %></dt>
        <dd class="text-gray-800 dark:text-gray-100"><%= my_sanitize @region.email =~ /kontakt.php/ ? @region.email : mail_to(@region.email) %></dd>

        <dt class="text-sm font-medium text-gray-500 dark:text-gray-400"><%= t('region.address') %></dt>
        <dd class="text-gray-800 dark:text-gray-100"><%= @region.address.andand.split("\n").andand.select { |s| s.present? }.andand.join(", ").andand.html_safe %></dd>

        <dt class="text-sm font-medium text-gray-500 dark:text-gray-400"><%= t('region.country_id') %></dt>
        <dd class="text-gray-800 dark:text-gray-100"><%= custom_link_to @region.country.andand.code, country_path(@region.country) %></dd>
      </dl>
    </div>
  </div>

  <!-- Sektions-Links (Drilldown in DIESE Region): region_focus überschreibt die Scope-Region temporär
       (höhere Prio als der Scope-Band-Default), OHNE den persistenten Wert umzuschalten. -->
  <div class="max-w-3xl mx-auto mt-8 space-y-3">
    <%= custom_link_to "→ #{t('tournaments_season')} #{Season.current_season.name}",
          tournaments_path(region_focus: @region.id, sSearch: "Season:#{Season.current_season.name} Date:>heute-2w"),
          class: "block font-medium text-primary-600 dark:text-primary-400 hover:underline" %>
    <%= custom_link_to "→ #{t('leagues_season')} #{Season.current_season.name}",
          parties_path(region_focus: @region.id, sSearch: "Season:#{Season.current_season.name} Date:>heute-2w"),
          class: "block font-medium text-primary-600 dark:text-primary-400 hover:underline" %>
    <%= custom_link_to "→ Clubs", clubs_path(region_focus: @region.id),
          class: "block font-medium text-primary-600 dark:text-primary-400 hover:underline" %>
  </div>

  <!-- Quick Load für anstehende Events -->
  <% if current_user&.admin? %>
    <div class="max-w-3xl mx-auto my-4 p-4 bg-info-50 dark:bg-info-900/20 border border-info-200 dark:border-info-800 rounded-lg">
      <h4 class="text-sm font-semibold text-info-800 dark:text-info-300 mb-2">⚡ Schnell-Aktualisierung</h4>
      <p class="text-sm text-info-800 dark:text-info-300 mb-3">
        Lädt nur unmittelbar anstehende Events vom API Server (schneller als komplette Synchronisation)
      </p>
      <div class="flex gap-2 items-center">
        <%= button_to '🔄 Anstehende Turniere (30 Tage)',
            reload_upcoming_tournaments_region_path(@region),
            method: :post,
            class: 'inline-block px-3 py-2 rounded text-white text-sm bg-primary-600 hover:bg-primary-700',
            data: { disable_with: 'API Server scraped...' },
            params: { days_ahead: 30 } %>
        <span class="text-xs text-gray-500 dark:text-gray-400">⏱️ 10-30 Sek</span>
      </div>
    </div>
  <% end %>

  <div class="max-w-3xl mx-auto">
    <%= render partial: "rankings" %>
  </div>

  <% if current_user&.admin? %>
    <div class="max-w-3xl mx-auto grid grid-cols-1 sm:grid-cols-2 gap-3 mt-8">
      <%= button_to I18n.t("region.show.reload_from_club_cloud", source: @region.source), reload_from_cc_region_path(@region), method: :post, disabled: !current_user&.admin?, class: "inline-block px-4 py-2 rounded text-white text-sm bg-primary-600 hover:bg-primary-700 disabled:opacity-40" %>
      <%= button_to I18n.t("region.show.reload_tournaments", source: @region.shortname), reload_tournaments_region_path(@region), method: :post, disabled: !current_user&.admin?, class: "inline-block px-4 py-2 rounded text-white text-sm bg-primary-600 hover:bg-primary-700 disabled:opacity-40" %>
      <%= button_to I18n.t("region.show.reload_from_club_cloud_with_details", source: @region.source), reload_from_cc_with_details_region_path(@region), method: :post, disabled: !current_user&.admin?, class: "inline-block px-4 py-2 rounded text-white text-sm bg-primary-600 hover:bg-primary-700 disabled:opacity-40" %>
      <%= button_to I18n.t("region.show.reload_leagues", source: @region.shortname), reload_leagues_region_path(@region), method: :post, disabled: !current_user&.admin?, class: "inline-block px-4 py-2 rounded text-white text-sm bg-primary-600 hover:bg-primary-700 disabled:opacity-40" %>
      <%= button_to I18n.t("region.show.reload_leagues_with_details", source: @region.shortname), reload_leagues_with_details_region_path(@region), method: :post, disabled: !current_user&.admin?, class: "inline-block px-4 py-2 rounded text-white text-sm bg-primary-600 hover:bg-primary-700 disabled:opacity-40" %>
    </div>
  <% end %>
</div>
