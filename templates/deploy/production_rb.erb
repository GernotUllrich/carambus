# server-based syntax
# ======================
# Defines a single server with a list of roles and multiple properties.
# You can define all roles on a single server, or split them:

#server '192.168.178.48', user: 'www-data', roles: %w{app db web}, ssh_options: {port: "8910"} # carambus gernot local
#server 'bc-wedel-duckdns.org', user: 'www-data', roles: %w{app db web}, ssh_options: {port: "8910"} # carambus gernot local
#server 'carambus.de', user: 'www-data', roles: %w{app db web}, ssh_options: {port: "8910"} # carambus global local and api
server '<%= @config['ssh_host'] %>', user: 'www-data', roles: %w{app db web <%= @config['cap_role'] || 'api' %>}, ssh_options: {port: "<%= @config['ssh_port'] %>"} # carambus global (Plan 21-10: :app universal Capistrano-Standard + cap_role-Sub-Property 'api'/'local')

# Puma auf Port ...
set :puma_port, "<%= @config['webserver_port'] %>"
set :rails_env, '<%= @environment %>'
set :branch, '<%= @scenario['branch'] %>'
set :basename, "<%= @scenario['basename'] %>"

# Whenever settings (Plan 21-10: variants in stage-file, not deploy.rb)
set :whenever_roles, ->{ [:<%= @config['cap_role'] || 'api' %>] }
set :whenever_identifier, ->{ fetch(:basename) }
set :whenever_variables, -> {
  "'environment=#{fetch(:rails_env, 'production')}&" \
  "path=#{fetch(:deploy_to)}/current&" \
  "scenarioname=#{fetch(:basename)}&" \
  "location_id=<%= @scenario['location_id'] || '1' %>'"
}

# Configuration
# =============
# You can set any configuration variable like in config/deploy.rb
# These variables are then only loaded and set in this stage.
# For server-based syntax, see `man capistrano`