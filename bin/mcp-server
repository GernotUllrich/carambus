#!/usr/bin/env ruby
# frozen_string_literal: true
# Carambus MCP-Server entrypoint — gespawnt von MCP-Clients (Claude Desktop / Code) als Subprocess.
# JSON-RPC läuft über STDIN/STDOUT — daher MUSS STDOUT sauber bleiben (Pitfall 1).
#
# Plan 10-02 Task 2 (Befund #2 v0.2.0-Vertrauens-Blocker Fix):
# Phase 10 Plan 10-01 Walkthrough zeigte in Claude Desktop regelmäßig
# `MCP carambus: Unexpected token 'I', "I, [2026-0"... is not valid JSON`.
# Root cause: Rails-Boot-Initializer (z.B. config/initializers/docs_auto_rebuild.rb
# in development mode) schreibt Rails.logger.info-Output auf STDOUT BEVOR
# transport/boot.rb den Logger auf STDERR umleitet.
#
# Plan 10-05 Task 1 (Befund #2b D-10-03-1 Root-Cause-Fix):
# Plan 10-02 setzte ENV["RAILS_LOG_TO_STDOUT"] = "false" als String — Ruby-Bool-Bug:
# Rails-Initializer prüft `ENV["RAILS_LOG_TO_STDOUT"].present?` (String "false" ist truthy
# in Ruby!), schaltet damit STDOUT-Logger AN statt AUS. ActiveRecord SQL DEBUG-Lines
# pollutten weiterhin STDOUT (Sub-Befund #2b im Plan 10-03 Re-Walkthrough).
# Fix: ENV.delete("RAILS_LOG_TO_STDOUT") entfernt den Key komplett, Rails fällt auf
# Default-File-Logger (log/<env>.log) zurück. Belt-and-Suspenders mit transport/boot.rb
# (AR-Logger explizit auf Rails.logger setzen).
ENV["RAILS_ENV"] ||= "production"
ENV["DOCS_AUTO_REBUILD"] = "0"
ENV.delete("RAILS_LOG_TO_STDOUT")
require_relative "../config/environment"

require "mcp_server/transport/boot"
McpServer::Transport::Boot.run
