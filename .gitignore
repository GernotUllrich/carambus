# See https://help.github.com/articles/ignoring-files for more about ignoring files.
#
# If you find yourself ignoring temporary files generated by your text editor
# or operating system, you probably want to add a global ignore instead:
#   git config --global core.excludesfile '~/.gitignore_global'

# Ignore bundler config.
/.bundle

# Ignore all logfiles and tempfiles.
/log/*
/tmp/*
!/log/.keep
!/tmp/.keep

# Ignore pidfiles, but keep the directory.
/tmp/pids/*
!/tmp/pids/
!/tmp/pids/.keep

# Ignore uploaded files in development.
/storage/*
!/storage/.keep
/tmp/storage/*
!/tmp/storage/
!/tmp/storage/.keep

/public/assets

# Ignore master key for decrypting credentials and more.
/config/master.key

/public/packs
/public/packs-test
/node_modules
/yarn-error.log
yarn-debug.log*
.yarn-integrity

# Ignore test coverage
/coverage/

# Ignore SimpleCov coverage reports
/coverage.data

# Ignore VCR cassettes with real credentials (keep .gitkeep)
# Note: Committed cassettes should have filtered credentials
# If you need to ignore specific cassettes:
# /test/snapshots/vcr/sensitive_*.yml

# Ignore editor-specific files
/.vscode/
/.idea/
*.swp
*.swo
*~

# Ignore OS files
.DS_Store
Thumbs.db

# Ignore local environment files
.env.local
.env.*.local

# .planning/ workflow byproducts (regenerable; kept locally for GSD tooling).
# Tracked: STATE.md, ROADMAP.md, PROJECT.md, REQUIREMENTS.md, MILESTONES.md,
# RETROSPECTIVE.md, HISTORY.md, BROADCAST-GAP-REPORT.md, v7.0-scope-evolution.md,
# clubcloud-admin-appendix-DRAFT.md, config.json, seeds/, todos/.
# Untracked (local-only audit trail): per-quick / per-phase / per-research /
# per-codebase / per-debug detail + reek baselines + archived milestones.
/.planning/quick/
/.planning/phases/
/.planning/research/
/.planning/codebase/
/.planning/intel/
/.planning/debug/
/.planning/milestones/
/.planning/reek_*.txt

# Ignore database files
/*.sqlite3
/*.sqlite3-*
*.sql.gz
*.sql
/doc/doc-local/docker/**/*.sql.gz
/doc/doc-local/docker/**/*.sql

# Ignore MkDocs generated site
/site/

# Ignore uploaded files
/public/uploads

# Ignore scenario-specific generated files (generated from carambus_data/*/config.yml)
/config/deploy/production.rb
/config/environments/development.rb
/config/scoreboard_url
/env.development
/doc/doc-local/**/*.log
/doc/doc-local/**/*.md
import_all.log
/app/assets/builds/**/*
config/cable.yml
.paul/
.claude/paul-framework/
.claude/commands/paul/
.mcp.json
db/schema_baseline_*.backup

# MCP-Client-Konfiguration (enthält CC-Zugangsdaten — NICHT einchecken).
# Vorlage: .mcp.json.example (tracked).
/.mcp.json
