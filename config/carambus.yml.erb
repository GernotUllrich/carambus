---
default:
  carambus_api_url: http://api.carambus.de
  location_id: 1
  application_name: carambus
  basename: carambus
  support_email: gernot.ullrich@gmx.de
  business_name: Ullrich IT Consulting
  business_address: 22869 Schenefeld, Sandstückenweg 15
  carambus_domain: carambus.de
  queue_adapter: async
  small_table_no: 0
  large_table_no: 0
  pool_table_no: 0
  snooker_table_no: 0
  season_name: 2025/2026
  force_update: 'true'
  no_local_protection: 'false'
  club_id: nil
  # Wenn true, zeigt der Scoreboard im Training-Mode (kein tournament_monitor)
  # für registrierte Nicht-Team-Nicht-Gast-Spieler den vollständigen Namen
  # statt der disambiguierten Kurzform. Default false → unverändertes Verhalten.
  # Aktivieren z. B. bei BCW-Grand-Prix mit gemischtem Gast/Mitglieder-Feld
  # via per-scenario carambus.yml(.erb) override.
  training_mode_show_fullname: false
  # Quick Game Presets - TableKind specific (90% use cases)
  quick_game_presets:
    small_billard:
      - category: "Freie Partie"
        buttons:
          - { balls: 40, innings: 20, discipline: "Freie Partie klein", allow_follow_up: true }
          - { balls: 80, innings: 20, discipline: "Freie Partie klein", allow_follow_up: true }
          - { balls: 100, innings: 20, discipline: "Freie Partie klein", allow_follow_up: true }
          - { balls: 0, innings: 20, discipline: "Freie Partie klein", label: "-/20", allow_follow_up: true }
      - category: "Dreiband"
        buttons:
          - { balls: 30, innings: 25, discipline: "Dreiband klein", allow_follow_up: true }
          - { balls: 20, innings: 20, discipline: "Dreiband klein", allow_follow_up: true }
      - category: "Eurokegel"
        buttons:
          - { balls: 80, innings: 0, discipline: "Eurokegel", label: "80/-", allow_follow_up: false }
          - { balls: 100, innings: 0, discipline: "Eurokegel", label: "100/-", allow_follow_up: false }
          - { balls: 120, innings: 0, discipline: "Eurokegel", label: "120/-", allow_follow_up: false }
      - category: "BK2-Kombi"
        buttons:
          # 38.4-12 O5: canonical BK-2kombi shortcut with the recommended defaults
          # (BK-2plus max 2 Stöße / Aufnahme, BK-2 max 5 Aufnahmen / Satz, balls_goal 70,
          # Nachstoß enabled via discipline.data — Plan 11). Sits at index 0 so BCW
          # scorers see it first on tournament day.
          - { discipline: "BK2-Kombi", balls_goal: 70, sets_to_win: 2, sets_to_play: 3, label: "BK-2kombi 2/5/70+NS", bk2_sp_max_innings: 5 }
          - { discipline: "BK2-Kombi", balls_goal: 50, sets_to_win: 2, sets_to_play: 3, label: "50/Best of 3" }
          - { discipline: "BK2-Kombi", balls_goal: 60, sets_to_win: 2, sets_to_play: 3, label: "60/Best of 3" }
          - { discipline: "BK2-Kombi", balls_goal: 70, sets_to_win: 2, sets_to_play: 3, label: "70/Best of 3" }
      - category: "BK-2"
        buttons:
          - { discipline: "BK-2", balls_goal: 50, sets_to_win: 1, sets_to_play: 1, label: "BK-2 50" }
          - { discipline: "BK-2", balls_goal: 70, sets_to_win: 1, sets_to_play: 1, label: "BK-2 70" }
          - { discipline: "BK-2", balls_goal: 100, sets_to_win: 1, sets_to_play: 1, label: "BK-2 100" }
      - category: "BK-2plus"
        buttons:
          - { discipline: "BK-2plus", balls_goal: 50, sets_to_win: 1, sets_to_play: 1, label: "BK-2plus 50" }
          - { discipline: "BK-2plus", balls_goal: 70, sets_to_win: 1, sets_to_play: 1, label: "BK-2plus 70" }
          - { discipline: "BK-2plus", balls_goal: 100, sets_to_win: 1, sets_to_play: 1, label: "BK-2plus 100" }
    match_billard:
      - category: "Dreiband"
        buttons:
          - { balls: 20, innings: 30, discipline: "Dreiband groß", allow_follow_up: true }
          - { balls: 15, innings: 0, discipline: "Dreiband groß", label: "15/-", allow_follow_up: true }
      - category: "Vierball"
        buttons:
          - { balls: 120, innings: 0, discipline: "4 Ball", label: "120/-", allow_follow_up: false }
    pool:
      - category: "8-Ball"
        buttons:
          - { sets_to_win: 3, discipline: "8-Ball", kickoff_switches_with: "winner", label: "3 (W)" }
          - { sets_to_win: 4, discipline: "8-Ball", kickoff_switches_with: "winner", label: "4 (W)" }
          - { sets_to_win: 5, discipline: "8-Ball", kickoff_switches_with: "winner", label: "5 (W)" }
          - { sets_to_win: 3, discipline: "8-Ball", kickoff_switches_with: "set", label: "3 (A)" }
          - { sets_to_win: 4, discipline: "8-Ball", kickoff_switches_with: "set", label: "4 (A)" }
          - { sets_to_win: 5, discipline: "8-Ball", kickoff_switches_with: "set", label: "5 (A)" }
      - category: "9-Ball"
        buttons:
          - { sets_to_win: 5, discipline: "9-Ball", kickoff_switches_with: "winner", label: "5 (W)" }
          - { sets_to_win: 7, discipline: "9-Ball", kickoff_switches_with: "winner", label: "7 (W)" }
          - { sets_to_win: 9, discipline: "9-Ball", kickoff_switches_with: "winner", label: "9 (W)" }
          - { sets_to_win: 5, discipline: "9-Ball", kickoff_switches_with: "set", label: "5 (A)" }
          - { sets_to_win: 7, discipline: "9-Ball", kickoff_switches_with: "set", label: "7 (A)" }
          - { sets_to_win: 9, discipline: "9-Ball", kickoff_switches_with: "set", label: "9 (A)" }
      - category: "10-Ball"
        buttons:
          - { sets_to_win: 5, discipline: "10-Ball", kickoff_switches_with: "winner", label: "5 (W)" }
          - { sets_to_win: 7, discipline: "10-Ball", kickoff_switches_with: "winner", label: "7 (W)" }
          - { sets_to_win: 5, discipline: "10-Ball", kickoff_switches_with: "set", label: "5 (A)" }
          - { sets_to_win: 7, discipline: "10-Ball", kickoff_switches_with: "set", label: "7 (A)" }
      - category: "14.1 endlos"
        buttons:
          - { balls: 50, innings: 0, discipline: "14.1 endlos", label: "50" }
          - { balls: 75, innings: 0, discipline: "14.1 endlos", label: "75" }
          - { balls: 100, innings: 0, discipline: "14.1 endlos", label: "100" }
          - { balls: 125, innings: 0, discipline: "14.1 endlos", label: "125" }
          - { balls: 150, innings: 0, discipline: "14.1 endlos", label: "150" }
          - { balls: 100, innings: 20, discipline: "14.1 endlos", label: "100/20" }
    snooker:
      - category: "Snooker"
        buttons:
          - { frames_to_win: 2, discipline: "Snooker", label: "Best of 3" }
          - { frames_to_win: 3, discipline: "Snooker", label: "Best of 5" }
          - { frames_to_win: 4, discipline: "Snooker", label: "Best of 7" }
          - { frames_to_win: 5, discipline: "Snooker", label: "Best of 9" }
